use "../std/io.cst" as io;
use "../src/ir/opt_mem.cst" as om;
use "elf_reader.cst" as reader;
use "linker.cst" as linker;
use "pdb_writer.cst" as pdbw;
use "../caustic-shared/debug_proto.cst" as dbgproto;

// ============================================================
// pe_writer.cst — PE32+ executable writer (Windows x86_64)
//
// write_minimal_exit42(fd) emits a complete hardcoded PE executable
// whose entry point calls ExitProcess(42). Used to bootstrap-test the
// PE format machinery (DOS header, PE/COFF, optional header, section
// table, import table, IAT, ILT, hint/name table).
//
// write_pe_executable(ls, output_path) is the real linker entry: it
// emits a PE32+ binary from a populated LinkerState with .text/.idata/
// optional .rdata/.data/.pdata/.xdata/.reloc and Windows DLL imports
// resolved via the cstimport directive.
// ============================================================

// === PE/COFF constants ===
let is i32 as IMAGE_FILE_MACHINE_AMD64 with imut = 34404;   // 0x8664
let is i32 as IMAGE_FILE_EXECUTABLE_IMAGE with imut = 2;
let is i32 as IMAGE_FILE_LARGE_ADDRESS_AWARE with imut = 32;  // 0x20
let is i32 as PE_OPT_MAGIC_PE32PLUS with imut = 523;        // 0x20B
let is i32 as IMAGE_SUBSYSTEM_WINDOWS_CUI with imut = 3;
let is i64 as IMAGE_SCN_CNT_CODE with imut = 32;            // 0x00000020
let is i64 as IMAGE_SCN_CNT_INITIALIZED_DATA with imut = 64; // 0x00000040
let is i64 as IMAGE_SCN_MEM_EXECUTE with imut = 536870912;   // 0x20000000
let is i64 as IMAGE_SCN_MEM_READ with imut = 1073741824;     // 0x40000000
let is i64 as IMAGE_SCN_MEM_WRITE with imut = 2147483648;    // 0x80000000

// File / section layout for the minimal exe
let is i64 as FILE_ALIGN with imut = 512;       // 0x200
let is i64 as SECTION_ALIGN with imut = 4096;   // 0x1000
let is i64 as IMAGE_BASE with imut = 5368709120; // 0x140000000

// Headers end at 0x1D8 → padded to FILE_ALIGN = 0x200.
let is i64 as HEADERS_FILE_SIZE with imut = 512;   // 0x200
let is i64 as SIZE_OF_HEADERS with imut = 512;     // value written into opt header

// .text: RVA 0x1000, raw at file 0x200, raw size 0x200 (one page padded)
let is i64 as TEXT_RVA with imut = 4096;          // 0x1000
let is i64 as TEXT_FILE with imut = 512;          // 0x200
let is i64 as TEXT_RAW_SIZE with imut = 512;      // 0x200
let is i64 as TEXT_VIRT_SIZE with imut = 16;      // sub rsp + mov ecx + call = 4+5+6 + room

// .idata defaults to RVA 0x2000 in write_minimal_exit42's hand-rolled layout.
// write_pe_executable computes its own .idata RVA dynamically based on which
// sections are present.
let is i64 as IDATA_RVA with imut = 8192;         // 0x2000
let is i64 as IDATA_FILE with imut = 1024;        // 0x400
let is i64 as IDATA_RAW_SIZE with imut = 512;     // 0x200

// SizeOfImage covers up to end of last section's virtual area, aligned
let is i64 as SIZE_OF_IMAGE with imut = 12288;    // 0x3000 (idata + section_align)

// Layout inside .idata (offsets relative to IDATA_RVA):
//   0x00  IAT slot for ExitProcess (8 bytes) + null (8 bytes) = 16
//   0x10  IID for kernel32 (20) + null IID (20) = 40
//   0x38  ILT entry for ExitProcess (8) + null (8) = 16
//   0x48  Hint(2) + "ExitProcess\0" + pad = 16
//   0x58  "kernel32.dll\0" + pad = 16
//   0x68  end (104 bytes virtual)
let is i64 as IDATA_IAT_OFF with imut = 0;
let is i64 as IDATA_IID_OFF with imut = 16;     // 0x10
let is i64 as IDATA_ILT_OFF with imut = 56;     // 0x38
let is i64 as IDATA_HINT_OFF with imut = 72;    // 0x48
let is i64 as IDATA_DLLNAME_OFF with imut = 88; // 0x58
let is i64 as IDATA_VIRT_SIZE with imut = 104;  // 0x68

// === Helpers ===

fn pad_to(b as *reader.ByteBuffer, target as i64) as void {
    while (b.len < target) { reader.buf_emit8(b, 0); }
}

fn emit_str(b as *reader.ByteBuffer, s as *u8, n as i64) as void {
    let is i64 as i with mut = 0;
    while (i < n) { reader.buf_emit8(b, cast(i32, s[i])); i = i + 1; }
}

// === Public entry: write hardcoded ExitProcess(42) PE ===

fn write_minimal_exit42(fd as i64) as i32 {
    let is reader.ByteBuffer as out = reader.buf_init(4096);

    // --- DOS header (64 bytes) ---
    reader.buf_emit8(&out, 77);   // 'M'
    reader.buf_emit8(&out, 90);   // 'Z'
    // pad to 0x3C
    pad_to(&out, 60);
    reader.buf_emit32_le(&out, 128);  // e_lfanew = 0x80
    pad_to(&out, 64);

    // DOS stub (64 bytes): zero-filled. Real Windows ignores this in PE mode.
    pad_to(&out, 128);

    // --- PE signature ---
    reader.buf_emit8(&out, 80);   // 'P'
    reader.buf_emit8(&out, 69);   // 'E'
    reader.buf_emit8(&out, 0);
    reader.buf_emit8(&out, 0);

    // --- COFF file header (20 bytes) ---
    reader.buf_emit16_le(&out, IMAGE_FILE_MACHINE_AMD64);  // Machine
    reader.buf_emit16_le(&out, 2);                          // NumberOfSections = .text + .idata
    reader.buf_emit32_le(&out, 0);                          // TimeDateStamp
    reader.buf_emit32_le(&out, 0);                          // PointerToSymbolTable (stripped)
    reader.buf_emit32_le(&out, 0);                          // NumberOfSymbols
    reader.buf_emit16_le(&out, 240);                        // SizeOfOptionalHeader (PE32+)
    reader.buf_emit16_le(&out, IMAGE_FILE_EXECUTABLE_IMAGE + IMAGE_FILE_LARGE_ADDRESS_AWARE);

    // --- Optional header PE32+ (240 bytes) ---
    reader.buf_emit16_le(&out, PE_OPT_MAGIC_PE32PLUS);     // Magic = 0x20B
    reader.buf_emit8(&out, 1);                              // MajorLinkerVersion
    reader.buf_emit8(&out, 0);                              // MinorLinkerVersion
    reader.buf_emit32_le(&out, TEXT_RAW_SIZE);              // SizeOfCode
    reader.buf_emit32_le(&out, IDATA_RAW_SIZE);             // SizeOfInitializedData
    reader.buf_emit32_le(&out, 0);                          // SizeOfUninitializedData
    reader.buf_emit32_le(&out, TEXT_RVA);                   // AddressOfEntryPoint
    reader.buf_emit32_le(&out, TEXT_RVA);                   // BaseOfCode
    reader.buf_emit64_le(&out, IMAGE_BASE);                 // ImageBase
    reader.buf_emit32_le(&out, SECTION_ALIGN);              // SectionAlignment
    reader.buf_emit32_le(&out, FILE_ALIGN);                 // FileAlignment
    reader.buf_emit16_le(&out, 6);                          // MajorOSVersion
    reader.buf_emit16_le(&out, 0);                          // MinorOSVersion
    reader.buf_emit16_le(&out, 0);                          // MajorImageVersion
    reader.buf_emit16_le(&out, 0);                          // MinorImageVersion
    reader.buf_emit16_le(&out, 6);                          // MajorSubsystemVersion
    reader.buf_emit16_le(&out, 0);                          // MinorSubsystemVersion
    reader.buf_emit32_le(&out, 0);                          // Win32VersionValue (reserved)
    reader.buf_emit32_le(&out, SIZE_OF_IMAGE);              // SizeOfImage
    reader.buf_emit32_le(&out, SIZE_OF_HEADERS);            // SizeOfHeaders
    reader.buf_emit32_le(&out, 0);                          // CheckSum (loader doesn't enforce for EXEs)
    reader.buf_emit16_le(&out, IMAGE_SUBSYSTEM_WINDOWS_CUI); // Subsystem
    reader.buf_emit16_le(&out, 0);                          // DllCharacteristics
    reader.buf_emit64_le(&out, 1048576);                    // SizeOfStackReserve = 0x100000
    reader.buf_emit64_le(&out, 4096);                       // SizeOfStackCommit  = 0x1000
    reader.buf_emit64_le(&out, 1048576);                    // SizeOfHeapReserve  = 0x100000
    reader.buf_emit64_le(&out, 4096);                       // SizeOfHeapCommit   = 0x1000
    reader.buf_emit32_le(&out, 0);                          // LoaderFlags
    reader.buf_emit32_le(&out, 16);                         // NumberOfRvaAndSizes

    // Data directories (16 × 8 = 128 bytes). Only Import (1) and IAT (12) are non-zero.
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [0] Export
    reader.buf_emit32_le(&out, IDATA_RVA + IDATA_IID_OFF); reader.buf_emit32_le(&out, 40); // [1] Import (2 IID entries)
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [2] Resource
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [3] Exception
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [4] Certificate
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [5] Base Relocation
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [6] Debug
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [7] Architecture
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [8] Global Ptr
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [9] TLS
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [10] Load Config
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [11] Bound Import
    reader.buf_emit32_le(&out, IDATA_RVA + IDATA_IAT_OFF); reader.buf_emit32_le(&out, 16); // [12] IAT
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [13] Delay Import
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [14] CLR
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0); // [15] Reserved

    // --- Section table (2 entries × 40 bytes = 80 bytes) ---
    // .text
    emit_str(&out, ".text", 5); pad_to(&out, out.len + 3);  // name pad to 8 bytes
    reader.buf_emit32_le(&out, TEXT_VIRT_SIZE);             // VirtualSize
    reader.buf_emit32_le(&out, TEXT_RVA);                   // VirtualAddress
    reader.buf_emit32_le(&out, TEXT_RAW_SIZE);              // SizeOfRawData
    reader.buf_emit32_le(&out, TEXT_FILE);                  // PointerToRawData
    reader.buf_emit32_le(&out, 0);                          // PointerToRelocations
    reader.buf_emit32_le(&out, 0);                          // PointerToLinenumbers
    reader.buf_emit16_le(&out, 0);                          // NumberOfRelocations
    reader.buf_emit16_le(&out, 0);                          // NumberOfLinenumbers
    reader.buf_emit32_le(&out, IMAGE_SCN_CNT_CODE + IMAGE_SCN_MEM_EXECUTE + IMAGE_SCN_MEM_READ);

    // .idata
    emit_str(&out, ".idata", 6); pad_to(&out, out.len + 2);  // name pad to 8 bytes
    reader.buf_emit32_le(&out, IDATA_VIRT_SIZE);
    reader.buf_emit32_le(&out, IDATA_RVA);
    reader.buf_emit32_le(&out, IDATA_RAW_SIZE);
    reader.buf_emit32_le(&out, IDATA_FILE);
    reader.buf_emit32_le(&out, 0);
    reader.buf_emit32_le(&out, 0);
    reader.buf_emit16_le(&out, 0);
    reader.buf_emit16_le(&out, 0);
    reader.buf_emit32_le(&out, IMAGE_SCN_CNT_INITIALIZED_DATA + IMAGE_SCN_MEM_READ + IMAGE_SCN_MEM_WRITE);

    // Pad headers to FileAlignment (0x200)
    pad_to(&out, HEADERS_FILE_SIZE);

    // --- .text raw data (at file 0x200, RVA 0x1000) ---
    // sub rsp, 0x28     ; 48 83 EC 28        (shadow space + alignment)
    reader.buf_emit8(&out, 72);   // 0x48
    reader.buf_emit8(&out, 131);  // 0x83
    reader.buf_emit8(&out, 236);  // 0xEC
    reader.buf_emit8(&out, 40);   // 0x28
    // mov ecx, 42       ; B9 2A 00 00 00
    reader.buf_emit8(&out, 185);  // 0xB9
    reader.buf_emit32_le(&out, 42);
    // call qword ptr [rip+disp32]  ; FF 15 disp32
    // RVA of this call = TEXT_RVA + 4 + 5 = 0x1009
    // Next instruction RVA = 0x1009 + 6 = 0x100F
    // Target = IDATA_RVA + IDATA_IAT_OFF = 0x2000
    // disp32 = 0x2000 - 0x100F = 0xFF1
    reader.buf_emit8(&out, 255);  // 0xFF
    reader.buf_emit8(&out, 21);   // 0x15
    let is i64 as call_next_rva = TEXT_RVA + 4 + 5 + 6;     // 0x100F
    let is i64 as iat_slot_rva = IDATA_RVA + IDATA_IAT_OFF;  // 0x2000
    reader.buf_emit32_le(&out, iat_slot_rva - call_next_rva);

    // Pad .text raw to TEXT_RAW_SIZE (next section at file 0x400)
    pad_to(&out, TEXT_FILE + TEXT_RAW_SIZE);

    // --- .idata raw (at file 0x400, RVA 0x2000) ---
    // [IAT slot for ExitProcess] = RVA to hint/name (loader patches at load time)
    let is i64 as hint_rva = IDATA_RVA + IDATA_HINT_OFF;
    reader.buf_emit64_le(&out, hint_rva);    // 8 bytes — IAT entry
    reader.buf_emit64_le(&out, 0);            // 8 bytes — IAT null terminator

    // [IID for kernel32] (20 bytes)
    reader.buf_emit32_le(&out, IDATA_RVA + IDATA_ILT_OFF);  // OriginalFirstThunk (ILT RVA)
    reader.buf_emit32_le(&out, 0);                          // TimeDateStamp
    reader.buf_emit32_le(&out, 0);                          // ForwarderChain
    reader.buf_emit32_le(&out, IDATA_RVA + IDATA_DLLNAME_OFF); // Name (DLL name RVA)
    reader.buf_emit32_le(&out, IDATA_RVA + IDATA_IAT_OFF);  // FirstThunk (IAT RVA)
    // [Null IID] (20 zero bytes)
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
    reader.buf_emit32_le(&out, 0);

    // [ILT entry for ExitProcess] (8 bytes) = RVA to hint/name (bit 63 = 0 → by-name import)
    reader.buf_emit64_le(&out, hint_rva);
    // [ILT null] (8 bytes)
    reader.buf_emit64_le(&out, 0);

    // [Hint(2) + "ExitProcess\0" + pad to 16 bytes]
    reader.buf_emit16_le(&out, 0);  // hint
    emit_str(&out, "ExitProcess", 11);
    reader.buf_emit8(&out, 0);      // NUL
    reader.buf_emit8(&out, 0);      // pad
    // Total: 2 + 11 + 1 + 1 = 15. Should be 16 to land at IDATA_DLLNAME_OFF.
    reader.buf_emit8(&out, 0);      // pad to 16

    // ["kernel32.dll\0" + pad to 16 bytes]
    emit_str(&out, "kernel32.dll", 12);
    reader.buf_emit8(&out, 0);      // NUL
    pad_to(&out, IDATA_FILE + IDATA_DLLNAME_OFF + 16);  // pad name area to 16

    // Pad .idata raw to IDATA_RAW_SIZE
    pad_to(&out, IDATA_FILE + IDATA_RAW_SIZE);

    // --- Write to file ---
    io._write_fd(fd, out.data, out.len);
    return 0;
}

// ============================================================
// write_pe_executable — generic PE writer driven by LinkerState
//
// Layout for compiler-driven hello-world / small programs:
//   0x000  DOS header + zero stub                          (128 bytes)
//   0x080  PE\\0\\0 signature                                 (4 bytes)
//   0x084  COFF header                                     (20 bytes)
//   0x098  Optional header PE32+                          (240 bytes)
//   0x188  Section table: .text, .idata                    (80 bytes)
//   0x200  .text raw data — from ls.text
//   0x400  .idata raw data — IAT region, IID, ILT, hint/name, DLL names
//          (.idata layout described in compute_idata_layout below)
//
// Caller must have run apply_relocations BEFORE calling here so that any
// __imp_<sym> reference in .text has been patched to point at the IAT slot
// (assigned via pre-register-imports-as-gsyms below).
// ============================================================

// --- Layout state, populated by compute_idata_layout ---
struct ImportLayout {
    // arrays of size ls.cstimport_count, parallel to ls.cstimport_*
    iat_slot_rvas as *u8;     // i64[] — RVA of each symbol's IAT slot
    ilt_slot_rvas as *u8;     // i64[] — RVA of each symbol's ILT slot
    hint_rvas as *u8;         // i64[] — RVA of each symbol's hint/name entry
    // per-DLL grouping (one entry per UNIQUE DLL, in first-seen order):
    dll_name_ptrs as *u8;     // i64[] — *u8 dll name from ls
    dll_name_lens as *u8;     // i32[] — i32 dll name len
    dll_name_rvas as *u8;     // i64[] — RVA where DLL name string sits
    dll_iat_first_rvas as *u8;// i64[] — RVA of first IAT entry for this DLL
    dll_ilt_first_rvas as *u8;// i64[] — RVA of first ILT entry for this DLL
    dll_iid_offset as *u8;    // i32[] — offset within IID array
    dll_count as i32;
    // overall layout
    iat_total_size as i64;
    iid_size as i64;
    ilt_total_size as i64;
    hint_total_size as i64;
    dllname_total_size as i64;
    idata_virt_size as i64;
    idata_raw_size as i64;
}

// Helper: linear find dll index in layout's dll_name_ptrs (returns -1 if not present)
fn _find_dll_idx(lay as *ImportLayout, dll as *u8, dll_len as i32) as i32 {
    let is *i64 as dnp = cast(*i64, lay.dll_name_ptrs);
    let is *i32 as dnl = cast(*i32, lay.dll_name_lens);
    let is i32 as i with mut = 0;
    while (i < lay.dll_count) {
        let is i32 as eq with mut = 1;
        if (dnl[i] != dll_len) { eq = 0; }
        if (eq == 1) {
            let is i32 as k with mut = 0;
            let is *u8 as nm = cast(*u8, dnp[i]);
            while (k < dll_len) {
                if (nm[k] != dll[k]) { eq = 0; k = dll_len; }
                k = k + 1;
            }
        }
        if (eq == 1) { return i; }
        i = i + 1;
    }
    return cast(i32, 0 - 1);
}

fn compute_idata_layout(ls as *linker.LinkerState, idata_rva as i64) as ImportLayout {
    let is ImportLayout as lay;
    let is i32 as n = ls.cstimport_count;
    lay.iat_slot_rvas = om.opt_alloc(cast(i64, n) * 8);
    lay.ilt_slot_rvas = om.opt_alloc(cast(i64, n) * 8);
    lay.hint_rvas = om.opt_alloc(cast(i64, n) * 8);
    lay.dll_name_ptrs = om.opt_alloc(cast(i64, n) * 8);
    lay.dll_name_lens = om.opt_alloc(cast(i64, n) * 4);
    lay.dll_name_rvas = om.opt_alloc(cast(i64, n) * 8);
    lay.dll_iat_first_rvas = om.opt_alloc(cast(i64, n) * 8);
    lay.dll_ilt_first_rvas = om.opt_alloc(cast(i64, n) * 8);
    lay.dll_iid_offset = om.opt_alloc(cast(i64, n) * 4);
    lay.dll_count = 0;

    // First, group the cstimport entries by DLL — record unique DLL list in
    // first-seen order, plus the per-DLL count of symbols.
    let is *i64 as ldp = cast(*i64, ls.cstimport_dll_ptrs);
    let is *i32 as ldl = cast(*i32, ls.cstimport_dll_lens);
    let is *i32 as lsl = cast(*i32, ls.cstimport_sym_lens);

    let is *i64 as dnp = cast(*i64, lay.dll_name_ptrs);
    let is *i32 as dnl = cast(*i32, lay.dll_name_lens);
    let is i32 as i with mut = 0;
    while (i < n) {
        let is *u8 as d = cast(*u8, ldp[i]);
        let is i32 as didx = _find_dll_idx(&lay, d, ldl[i]);
        if (didx < 0) {
            let is i32 as idx = lay.dll_count;
            dnp[idx] = cast(i64, d);
            dnl[idx] = ldl[i];
            lay.dll_count = lay.dll_count + 1;
        }
        i = i + 1;
    }

    // Layout: IAT region first, then IID, then ILT, then hint/name, then DLL names.
    // Each DLL's IAT block is (count_of_syms_in_this_dll + 1) × 8 (with null term).
    // Same for ILT.

    // Pre-compute per-DLL sym count
    let is *u8 as dll_sym_counts = om.opt_alloc(cast(i64, lay.dll_count) * 4);
    let is *i32 as dsc = cast(*i32, dll_sym_counts);
    let is i32 as di with mut = 0;
    while (di < lay.dll_count) { dsc[di] = 0; di = di + 1; }
    i = 0;
    while (i < n) {
        let is i32 as didx = _find_dll_idx(&lay, cast(*u8, ldp[i]), ldl[i]);
        dsc[didx] = dsc[didx] + 1;
        i = i + 1;
    }

    // IAT region: sum over DLLs of (count+1)*8
    let is i64 as iat_off with mut = 0;
    let is *i64 as diatf = cast(*i64, lay.dll_iat_first_rvas);
    di = 0;
    while (di < lay.dll_count) {
        diatf[di] = idata_rva + iat_off;
        iat_off = iat_off + cast(i64, dsc[di] + 1) * 8;
        di = di + 1;
    }
    lay.iat_total_size = iat_off;

    // IID array: (dll_count + 1) * 20 bytes
    let is i64 as iid_start = lay.iat_total_size;
    lay.iid_size = cast(i64, lay.dll_count + 1) * 20;
    let is *i32 as diido = cast(*i32, lay.dll_iid_offset);
    di = 0;
    while (di < lay.dll_count) { diido[di] = cast(i32, iid_start + cast(i64, di) * 20); di = di + 1; }

    // ILT region: mirrors IAT
    let is i64 as ilt_start = iid_start + lay.iid_size;
    let is i64 as ilt_off with mut = ilt_start;
    let is *i64 as diltf = cast(*i64, lay.dll_ilt_first_rvas);
    di = 0;
    while (di < lay.dll_count) {
        diltf[di] = idata_rva + ilt_off;
        ilt_off = ilt_off + cast(i64, dsc[di] + 1) * 8;
        di = di + 1;
    }
    lay.ilt_total_size = ilt_off - ilt_start;

    // Per-symbol IAT/ILT slot RVAs: fill in by walking imports in input
    // order but assigning to per-DLL counters.
    let is *u8 as dll_iat_cur = om.opt_alloc(cast(i64, lay.dll_count) * 8);
    let is *u8 as dll_ilt_cur = om.opt_alloc(cast(i64, lay.dll_count) * 8);
    let is *i64 as diatc = cast(*i64, dll_iat_cur);
    let is *i64 as diltc = cast(*i64, dll_ilt_cur);
    di = 0;
    while (di < lay.dll_count) {
        diatc[di] = diatf[di];
        diltc[di] = diltf[di];
        di = di + 1;
    }
    let is *i64 as iatr = cast(*i64, lay.iat_slot_rvas);
    let is *i64 as iltr = cast(*i64, lay.ilt_slot_rvas);
    i = 0;
    while (i < n) {
        let is i32 as didx = _find_dll_idx(&lay, cast(*u8, ldp[i]), ldl[i]);
        iatr[i] = diatc[didx];
        diatc[didx] = diatc[didx] + 8;
        iltr[i] = diltc[didx];
        diltc[didx] = diltc[didx] + 8;
        i = i + 1;
    }

    // Hint/name table: per symbol, 2-byte hint + name + NUL, padded so the
    // total entry size is a multiple of 16. Matches the conventional layout
    // produced by MSVC/lld-link — Wine's import resolver is happier when
    // each hint/name entry sits on a 16-byte boundary.
    let is i64 as hint_start = ilt_off;
    let is i64 as hint_off with mut = hint_start;
    let is *i64 as hr = cast(*i64, lay.hint_rvas);
    i = 0;
    while (i < n) {
        hr[i] = idata_rva + hint_off;
        let is i64 as entry_sz with mut = 2 + cast(i64, lsl[i]) + 1;
        // Pad up to next multiple of 16
        if ((entry_sz & 15) != 0) { entry_sz = entry_sz + (16 - (entry_sz & 15)); }
        hint_off = hint_off + entry_sz;
        i = i + 1;
    }
    lay.hint_total_size = hint_off - hint_start;

    // DLL name strings: per DLL, name + NUL, padded to multiple of 16.
    let is i64 as dlln_start = hint_off;
    let is i64 as dlln_off with mut = dlln_start;
    let is *i64 as dnr = cast(*i64, lay.dll_name_rvas);
    di = 0;
    while (di < lay.dll_count) {
        dnr[di] = idata_rva + dlln_off;
        let is i64 as entry_sz with mut = cast(i64, dnl[di]) + 1;
        if ((entry_sz & 15) != 0) { entry_sz = entry_sz + (16 - (entry_sz & 15)); }
        dlln_off = dlln_off + entry_sz;
        di = di + 1;
    }
    lay.dllname_total_size = dlln_off - dlln_start;

    lay.idata_virt_size = dlln_off;
    // Round raw size to FILE_ALIGN
    lay.idata_raw_size = lay.idata_virt_size;
    if (lay.idata_raw_size % FILE_ALIGN != 0) {
        lay.idata_raw_size = lay.idata_raw_size + (FILE_ALIGN - lay.idata_raw_size % FILE_ALIGN);
    }
    if (lay.idata_raw_size < FILE_ALIGN) { lay.idata_raw_size = FILE_ALIGN; }
    return lay;
}

// Pre-register every __imp_<sym> as a global symbol whose vaddr is its IAT
// slot's absolute virtual address. apply_relocations() (existing core code)
// will then resolve PC32 relocations against __imp_<sym> to the IAT slot,
// so the indirect call `call qword ptr [rip+__imp_X]` lands correctly.
fn register_imp_gsyms(ls as *linker.LinkerState, lay as *ImportLayout) as void {
    let is *i64 as lsp = cast(*i64, ls.cstimport_sym_ptrs);
    let is *i32 as lsl = cast(*i32, ls.cstimport_sym_lens);
    let is *i64 as iatr = cast(*i64, lay.iat_slot_rvas);
    let is *linker.GlobalSymTab as gsyms = linker.get_gsyms(ls);
    let is i32 as i with mut = 0;
    while (i < ls.cstimport_count) {
        // Build "__imp_<sym>"
        let is i32 as sl = lsl[i];
        let is *u8 as full = om.opt_alloc(cast(i64, sl) + 7);
        full[0] = 95; full[1] = 95; full[2] = 105; full[3] = 109; full[4] = 112; full[5] = 95;
        let is *u8 as sn = cast(*u8, lsp[i]);
        let is i32 as k with mut = 0;
        while (k < sl) { full[6 + k] = sn[k]; k = k + 1; }
        full[6 + sl] = cast(u8, 0);
        let is i32 as full_len = sl + 6;
        let is i64 as vaddr = ls.base_addr + iatr[i];
        // Upsert: if a __imp_<sym> entry already exists (placed by the
        // obj-symbol-merge pass with defined=0), patch its vaddr and mark
        // defined. Otherwise add fresh. This avoids the linker's
        // "undefined symbol" warning AND ensures relocations resolve.
        let is i32 as existing = linker.gsym_find(gsyms, full, full_len);
        if (existing >= 0) {
            let is *linker.GlobalSym as g = linker.gsym_get(gsyms, existing);
            g.vaddr = vaddr;
            g.section = reader.SECIDX_DATA;
            g.defined = 1;
        } else {
            linker.gsym_add(gsyms, full, full_len, reader.SECIDX_DATA, vaddr, 0, 1);
        }
        i = i + 1;
    }
}

// Look up the IAT slot RVA for an imported symbol by name (e.g. "ExitProcess").
// Returns -1 if not found in the collected cstimport list.
fn _has_cstimport(ls as *linker.LinkerState, name as *u8, name_len as i32) as i32 {
    let is *i64 as lsp = cast(*i64, ls.cstimport_sym_ptrs);
    let is *i32 as lsl = cast(*i32, ls.cstimport_sym_lens);
    let is i32 as i with mut = 0;
    while (i < ls.cstimport_count) {
        if (lsl[i] == name_len) {
            let is i32 as eq with mut = 1;
            let is *u8 as sn = cast(*u8, lsp[i]);
            let is i32 as k with mut = 0;
            while (k < name_len) {
                if (sn[k] != name[k]) { eq = 0; k = name_len; }
                k = k + 1;
            }
            if (eq == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

fn _find_iat_rva(ls as *linker.LinkerState, lay as *ImportLayout, name as *u8, name_len as i32) as i64 {
    let is *i64 as lsp = cast(*i64, ls.cstimport_sym_ptrs);
    let is *i32 as lsl = cast(*i32, ls.cstimport_sym_lens);
    let is *i64 as iatr = cast(*i64, lay.iat_slot_rvas);
    let is i32 as i with mut = 0;
    while (i < ls.cstimport_count) {
        if (lsl[i] == name_len) {
            let is i32 as eq with mut = 1;
            let is *u8 as sn = cast(*u8, lsp[i]);
            let is i32 as k with mut = 0;
            while (k < name_len) {
                if (sn[k] != name[k]) { eq = 0; k = name_len; }
                k = k + 1;
            }
            if (eq == 1) { return iatr[i]; }
        }
        i = i + 1;
    }
    return cast(i64, 0 - 1);
}

// Emit the Windows entry stub at the START of .text. The stub
//   1. allocates 0x428 stack bytes (shadow space + 0x400 argv buffer)
//   2. calls GetCommandLineA → rax = cmdline
//   3. calls __caustic_parse_argv(rcx=cmdline, rdx=argv_buf) → rax = argc
//   4. sets rdi/rsi (SysV argc/argv) and calls user's main
//   5. passes main's return to ExitProcess
//
// Caustic functions use SysV ABI internally (rdi/rsi for first two args),
// so we deliberately do *not* place args in MS-x64 rcx/rdx for the
// `call main` — only for the kernel32 imports.
//
// Stub bytes (47 total):
//   00  48 81 EC 28 04 00 00            sub  rsp, 0x428                (7)
//   07  FF 15 disp32                    call [rip+__imp_GetCommandLineA] (6)
//   0D  48 89 C1                        mov  rcx, rax                  (3) cmdline
//   10  48 8D 54 24 28                  lea  rdx, [rsp+0x28]           (5) argv buf
//   15  E8 disp32                       call rel32 __caustic_parse_argv (5)
//   1A  48 89 C7                        mov  rdi, rax                  (3) argc → SysV
//   1D  48 8D 74 24 28                  lea  rsi, [rsp+0x28]           (5) argv → SysV
//   22  E8 disp32                       call rel32 main                (5)
//   27  89 C1                           mov  ecx, eax                  (2) exit code
//   29  FF 15 disp32                    call [rip+__imp_ExitProcess]   (6)
fn emit_win_entry_stub(out as *reader.ByteBuffer, main_rva as i64,
                       getcmdline_iat_rva as i64, parse_argv_rva as i64,
                       exitproc_iat_rva as i64, stub_rva as i64) as i64 {
    // sub rsp, 0x428
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 129); reader.buf_emit8(out, 236);
    reader.buf_emit8(out, 40); reader.buf_emit8(out, 4); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    // call qword ptr [rip+__imp_GetCommandLineA]
    reader.buf_emit8(out, 255); reader.buf_emit8(out, 21);
    let is i64 as call_gcl_next = stub_rva + 7 + 6;
    reader.buf_emit32_le(out, getcmdline_iat_rva - call_gcl_next);
    // mov rcx, rax
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 137); reader.buf_emit8(out, 193);
    // lea rdx, [rsp+0x28]
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 141); reader.buf_emit8(out, 84);
    reader.buf_emit8(out, 36); reader.buf_emit8(out, 40);
    // call rel32 __caustic_parse_argv
    reader.buf_emit8(out, 232);
    let is i64 as call_pa_next = stub_rva + 7 + 6 + 3 + 5 + 5;
    reader.buf_emit32_le(out, parse_argv_rva - call_pa_next);
    // mov rdi, rax
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 137); reader.buf_emit8(out, 199);
    // lea rsi, [rsp+0x28]
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 141); reader.buf_emit8(out, 116);
    reader.buf_emit8(out, 36); reader.buf_emit8(out, 40);
    // call rel32 main
    reader.buf_emit8(out, 232);
    let is i64 as call_main_next = stub_rva + 7 + 6 + 3 + 5 + 5 + 3 + 5 + 5;
    reader.buf_emit32_le(out, main_rva - call_main_next);
    // mov ecx, eax
    reader.buf_emit8(out, 137); reader.buf_emit8(out, 193);
    // call qword ptr [rip+__imp_ExitProcess]
    reader.buf_emit8(out, 255); reader.buf_emit8(out, 21);
    let is i64 as call_exit_next = stub_rva + 7 + 6 + 3 + 5 + 5 + 3 + 5 + 5 + 2 + 6;
    reader.buf_emit32_le(out, exitproc_iat_rva - call_exit_next);
    return 47;
}


// 228-byte CommandLineToArgvA-equivalent parser. Layout/offsets verified by
// hand; jumps use rel8 where the target fits, rel32 otherwise. See the
// trailing comment in this file for the full byte-by-byte annotation.
fn emit_caustic_parse_argv(out as *reader.ByteBuffer) as i64 {
    // 00  push rbx; push rsi; push rdi
    reader.buf_emit8(out, 83); reader.buf_emit8(out, 86); reader.buf_emit8(out, 87);
    // 03  xor eax, eax
    reader.buf_emit8(out, 49); reader.buf_emit8(out, 192);
    // 05 .skip_ws:  mov bl, [rcx]; test bl, bl
    reader.buf_emit8(out, 138); reader.buf_emit8(out, 25);
    reader.buf_emit8(out, 132); reader.buf_emit8(out, 219);
    // 09  jz .done   (rel32 +0xD1)
    reader.buf_emit8(out, 15); reader.buf_emit8(out, 132);
    reader.buf_emit8(out, 209); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    // 0F  cmp bl, 32; je .ws_step (+5)
    reader.buf_emit8(out, 128); reader.buf_emit8(out, 251); reader.buf_emit8(out, 32);
    reader.buf_emit8(out, 116); reader.buf_emit8(out, 5);
    // 14  cmp bl, 9; jne .new_arg (+5)
    reader.buf_emit8(out, 128); reader.buf_emit8(out, 251); reader.buf_emit8(out, 9);
    reader.buf_emit8(out, 117); reader.buf_emit8(out, 5);
    // 19 .ws_step:  inc rcx; jmp .skip_ws (-0x19)
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 193);
    reader.buf_emit8(out, 235); reader.buf_emit8(out, 231);
    // 1E .new_arg:  cmp eax, 128; jae .done (rel32 +0xB7)
    reader.buf_emit8(out, 61); reader.buf_emit8(out, 128); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    reader.buf_emit8(out, 15); reader.buf_emit8(out, 131);
    reader.buf_emit8(out, 183); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    // 29  mov [rdx], rcx; add rdx, 8; inc rax
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 137); reader.buf_emit8(out, 10);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 131); reader.buf_emit8(out, 194); reader.buf_emit8(out, 8);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 192);
    // 33  mov rsi, rcx; xor edi, edi; xor r10d, r10d
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 137); reader.buf_emit8(out, 206);
    reader.buf_emit8(out, 49); reader.buf_emit8(out, 255);
    reader.buf_emit8(out, 69); reader.buf_emit8(out, 49); reader.buf_emit8(out, 210);
    // 3B .arg_loop:  mov bl, [rcx]; test bl, bl
    reader.buf_emit8(out, 138); reader.buf_emit8(out, 25);
    reader.buf_emit8(out, 132); reader.buf_emit8(out, 219);
    // 3F  jz .arg_end (rel32 +0x7A)
    reader.buf_emit8(out, 15); reader.buf_emit8(out, 132);
    reader.buf_emit8(out, 122); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    // 45  test edi, edi; jnz .check_special (+0x12)
    reader.buf_emit8(out, 133); reader.buf_emit8(out, 255);
    reader.buf_emit8(out, 117); reader.buf_emit8(out, 18);
    // 49  cmp bl, 32; je .arg_end (rel32 +0x6D)
    reader.buf_emit8(out, 128); reader.buf_emit8(out, 251); reader.buf_emit8(out, 32);
    reader.buf_emit8(out, 15); reader.buf_emit8(out, 132);
    reader.buf_emit8(out, 109); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    // 52  cmp bl, 9; je .arg_end (rel32 +0x64)
    reader.buf_emit8(out, 128); reader.buf_emit8(out, 251); reader.buf_emit8(out, 9);
    reader.buf_emit8(out, 15); reader.buf_emit8(out, 132);
    reader.buf_emit8(out, 100); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    // 5B .check_special:  cmp bl, 92; je .got_bs (+0x22)
    reader.buf_emit8(out, 128); reader.buf_emit8(out, 251); reader.buf_emit8(out, 92);
    reader.buf_emit8(out, 116); reader.buf_emit8(out, 34);
    // 60  cmp bl, 34; je .got_quote (+0x28)
    reader.buf_emit8(out, 128); reader.buf_emit8(out, 251); reader.buf_emit8(out, 34);
    reader.buf_emit8(out, 116); reader.buf_emit8(out, 40);
    // 65  test r10d, r10d; jz .emit_ch (+0x0B)
    reader.buf_emit8(out, 69); reader.buf_emit8(out, 133); reader.buf_emit8(out, 210);
    reader.buf_emit8(out, 116); reader.buf_emit8(out, 11);
    // 6A .flush_bs:  mov byte [rsi], 92; inc rsi; dec r10d; jnz .flush_bs (-11)
    reader.buf_emit8(out, 198); reader.buf_emit8(out, 6); reader.buf_emit8(out, 92);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 198);
    reader.buf_emit8(out, 65); reader.buf_emit8(out, 255); reader.buf_emit8(out, 202);
    reader.buf_emit8(out, 117); reader.buf_emit8(out, 245);
    // 75 .emit_ch:  mov [rsi], bl; inc rsi; inc rcx; jmp .arg_loop (rel32 -0x47)
    reader.buf_emit8(out, 136); reader.buf_emit8(out, 30);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 198);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 193);
    reader.buf_emit8(out, 233); reader.buf_emit8(out, 185); reader.buf_emit8(out, 255); reader.buf_emit8(out, 255); reader.buf_emit8(out, 255);
    // 82 .got_bs:  inc r10d; inc rcx; jmp .arg_loop (rel32 -0x52)
    reader.buf_emit8(out, 65); reader.buf_emit8(out, 255); reader.buf_emit8(out, 194);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 193);
    reader.buf_emit8(out, 233); reader.buf_emit8(out, 174); reader.buf_emit8(out, 255); reader.buf_emit8(out, 255); reader.buf_emit8(out, 255);
    // 8D .got_quote:  mov r11d, r10d; shr r11d, 1; test r11d, r11d; jz .q_parity (+0x0B)
    reader.buf_emit8(out, 69); reader.buf_emit8(out, 137); reader.buf_emit8(out, 211);
    reader.buf_emit8(out, 65); reader.buf_emit8(out, 209); reader.buf_emit8(out, 235);
    reader.buf_emit8(out, 69); reader.buf_emit8(out, 133); reader.buf_emit8(out, 219);
    reader.buf_emit8(out, 116); reader.buf_emit8(out, 11);
    // 98 .q_emit_bs:  mov byte [rsi], 92; inc rsi; dec r11d; jnz .q_emit_bs (-11)
    reader.buf_emit8(out, 198); reader.buf_emit8(out, 6); reader.buf_emit8(out, 92);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 198);
    reader.buf_emit8(out, 65); reader.buf_emit8(out, 255); reader.buf_emit8(out, 203);
    reader.buf_emit8(out, 117); reader.buf_emit8(out, 245);
    // A3 .q_parity:  test r10b, 1; jnz .q_literal (+5)
    reader.buf_emit8(out, 65); reader.buf_emit8(out, 246); reader.buf_emit8(out, 194); reader.buf_emit8(out, 1);
    reader.buf_emit8(out, 117); reader.buf_emit8(out, 5);
    // A9  xor edi, 1; jmp .q_done (+6)
    reader.buf_emit8(out, 131); reader.buf_emit8(out, 247); reader.buf_emit8(out, 1);
    reader.buf_emit8(out, 235); reader.buf_emit8(out, 6);
    // AE .q_literal:  mov byte [rsi], 34; inc rsi
    reader.buf_emit8(out, 198); reader.buf_emit8(out, 6); reader.buf_emit8(out, 34);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 198);
    // B4 .q_done:  xor r10d, r10d; inc rcx; jmp .arg_loop (rel32 -0x84)
    reader.buf_emit8(out, 69); reader.buf_emit8(out, 49); reader.buf_emit8(out, 210);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 193);
    reader.buf_emit8(out, 233); reader.buf_emit8(out, 124); reader.buf_emit8(out, 255); reader.buf_emit8(out, 255); reader.buf_emit8(out, 255);
    // BF .arg_end:  test r10d, r10d; jz .arg_term (+0x0B)
    reader.buf_emit8(out, 69); reader.buf_emit8(out, 133); reader.buf_emit8(out, 210);
    reader.buf_emit8(out, 116); reader.buf_emit8(out, 11);
    // C4 .drain_bs:  mov byte [rsi], 92; inc rsi; dec r10d; jnz .drain_bs (-11)
    reader.buf_emit8(out, 198); reader.buf_emit8(out, 6); reader.buf_emit8(out, 92);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 198);
    reader.buf_emit8(out, 65); reader.buf_emit8(out, 255); reader.buf_emit8(out, 202);
    reader.buf_emit8(out, 117); reader.buf_emit8(out, 245);
    // CF .arg_term:  mov bl, [rcx]; mov byte [rsi], 0; test bl, bl
    //   Read [rcx] FIRST: in-place parsing keeps rsi == rcx for plain args,
    //   so writing the NUL at [rsi] before the read would trash the very
    //   byte we need to inspect (whitespace or NUL).
    reader.buf_emit8(out, 138); reader.buf_emit8(out, 25);
    reader.buf_emit8(out, 198); reader.buf_emit8(out, 6); reader.buf_emit8(out, 0);
    reader.buf_emit8(out, 132); reader.buf_emit8(out, 219);
    // D6  jz .done (+8); inc rcx; jmp .skip_ws (rel32 -0xDB)
    reader.buf_emit8(out, 116); reader.buf_emit8(out, 8);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 255); reader.buf_emit8(out, 193);
    reader.buf_emit8(out, 233); reader.buf_emit8(out, 37); reader.buf_emit8(out, 255); reader.buf_emit8(out, 255); reader.buf_emit8(out, 255);
    // E0 .done:  pop rdi; pop rsi; pop rbx; ret
    reader.buf_emit8(out, 95); reader.buf_emit8(out, 94); reader.buf_emit8(out, 91); reader.buf_emit8(out, 195);
    return 228;
}

// Emit __caustic_chkstk — a stack-probe trampoline called by every function
// whose frame is ≥ 4 KiB. Windows reserves the stack lazily: writing past
// the current commit limit without first touching every guard page raises
// a fault. This routine walks down from the caller's rsp in 4 KiB steps,
// touching one byte per page so the kernel commits the next guard page.
//
// Convention (matches what emit_driver.cst generates at the call site):
//   in : rax = total frame bytes about to be allocated
//   out: rax preserved (caller does `sub rsp, rax` right after returning)
//        rcx/rdx clobbered are saved/restored
//
// Bytes (57 total):
//   push rdx                          ; 52
//   push rcx                          ; 51
//   mov  rcx, rsp                     ; 48 89 E1
//   add  rcx, 24                      ; 48 83 C1 18    skip 2 pushes + ret addr
//   mov  rdx, rax                     ; 48 89 C2
//   add  rdx, 4095                    ; 48 81 C2 FF 0F 00 00   round rax up to
//   and  rdx, 0xFFFFF000              ; 48 81 E2 00 F0 FF FF   next 4 KiB
// .probe:
//   cmp  rdx, 4096                    ; 48 81 FA 00 10 00 00
//   jb   .done                        ; 72 13
//   sub  rdx, 4096                    ; 48 81 EA 00 10 00 00
//   sub  rcx, 4096                    ; 48 81 E9 00 10 00 00
//   mov  byte ptr [rcx], 0            ; C6 01 00
//   jmp  .probe                       ; EB E4
// .done:
//   pop  rcx                          ; 59
//   pop  rdx                          ; 5A
//   ret                               ; C3
//
// The round-up ensures we probe ceil(rax/4096) pages so the last partial
// page also gets touched (avoids an access fault if the OS hasn't committed
// it yet when the caller's first store lands there).
fn emit_caustic_chkstk(out as *reader.ByteBuffer) as i64 {
    reader.buf_emit8(out, 82);                                                      // push rdx
    reader.buf_emit8(out, 81);                                                      // push rcx
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 137); reader.buf_emit8(out, 225); // mov rcx, rsp
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 131); reader.buf_emit8(out, 193); reader.buf_emit8(out, 24); // add rcx, 24
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 137); reader.buf_emit8(out, 194); // mov rdx, rax
    // add rdx, 4095  (0xFFF)
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 129); reader.buf_emit8(out, 194);
    reader.buf_emit8(out, 255); reader.buf_emit8(out, 15); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    // and rdx, 0xFFFFF000  (sign-extended from imm32 0xFFFFF000)
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 129); reader.buf_emit8(out, 226);
    reader.buf_emit8(out, 0); reader.buf_emit8(out, 240); reader.buf_emit8(out, 255); reader.buf_emit8(out, 255);
    // .probe:
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 129); reader.buf_emit8(out, 250); // cmp rdx, imm32
    reader.buf_emit8(out, 0); reader.buf_emit8(out, 16); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);  // 4096
    reader.buf_emit8(out, 114); reader.buf_emit8(out, 19);                          // jb +0x13
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 129); reader.buf_emit8(out, 234); // sub rdx, imm32
    reader.buf_emit8(out, 0); reader.buf_emit8(out, 16); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    reader.buf_emit8(out, 72); reader.buf_emit8(out, 129); reader.buf_emit8(out, 233); // sub rcx, imm32
    reader.buf_emit8(out, 0); reader.buf_emit8(out, 16); reader.buf_emit8(out, 0); reader.buf_emit8(out, 0);
    reader.buf_emit8(out, 198); reader.buf_emit8(out, 1); reader.buf_emit8(out, 0); // mov byte [rcx], 0
    reader.buf_emit8(out, 235); reader.buf_emit8(out, 228);                         // jmp -0x1c
    // .done:
    reader.buf_emit8(out, 89);                                                       // pop rcx
    reader.buf_emit8(out, 90);                                                       // pop rdx
    reader.buf_emit8(out, 195);                                                      // ret
    return 57;
}

// Build the .reloc section. Iterates over every R_X86_64_64 relocation in
// every input obj, computes the final RVA of the patched 8 bytes, then
// groups by 4 KiB page and emits the standard PE base-relocation blocks:
//
//   PageRVA (4) | BlockSize (4) | entries[N] (2 each, padded to 4-byte align)
//
// Each entry is `(type << 12) | offset_in_page`, where type 10 is
// IMAGE_REL_BASED_DIR64 and type 0 is IMAGE_REL_BASED_ABSOLUTE (used as a
// no-op padding entry to keep BlockSize a multiple of 4).
//
// Returns the number of bytes written into `out`. Result may be 0 if the
// program contains no absolute addresses (typical for our hello-world).
fn build_reloc_blob(ls as *linker.LinkerState, out as *reader.ByteBuffer,
                    text_rva_base as i64, rodata_rva as i64, data_rva as i64) as i64 {
    // Capacity: 4096 ADDR64 sites should fit any realistic program.
    let is i32 as MAX = 4096;
    let is *i64 as rvas = cast(*i64, om.opt_alloc(cast(i64, MAX) * 8));
    let is i32 as count with mut = 0;

    // Collect all ADDR64 reloc RVAs.
    let is i32 as oi with mut = 0;
    while (oi < ls.obj_count) {
        let is *reader.ObjFile as obj = linker.get_obj(ls, oi);
        let is i32 as ri with mut = 0;
        while (ri < obj.reloc_count) {
            let is *reader.ObjReloc as rel = reader.reloc_get(obj, ri);
            if (rel.rtype == reader.R_X86_64_64 && count < MAX) {
                let is i64 as rva with mut = 0 - 1;
                if (rel.section == reader.SECIDX_TEXT) {
                    rva = text_rva_base + obj.text_offset + rel.offset;
                } else if (rel.section == reader.SECIDX_RODATA) {
                    rva = rodata_rva + obj.rodata_offset + rel.offset;
                } else if (rel.section == reader.SECIDX_DATA) {
                    rva = data_rva + obj.data_offset + rel.offset;
                }
                if (rva >= 0) {
                    rvas[count] = rva;
                    count = count + 1;
                }
            }
            ri = ri + 1;
        }
        oi = oi + 1;
    }

    if (count == 0) { return 0; }

    // Insertion sort (small N; keeps the page-grouping pass simple).
    let is i32 as a with mut = 1;
    while (a < count) {
        let is i64 as key = rvas[a];
        let is i32 as b with mut = a - 1;
        while (b >= 0 && rvas[b] > key) {
            rvas[b + 1] = rvas[b];
            b = b - 1;
        }
        rvas[b + 1] = key;
        a = a + 1;
    }

    // Emit per-page blocks.
    let is i64 as written with mut = 0;
    let is i32 as cur with mut = 0;
    while (cur < count) {
        let is i64 as page_rva = rvas[cur] - (rvas[cur] % 4096);
        let is i32 as end with mut = cur;
        while (end < count && rvas[end] - (rvas[end] % 4096) == page_rva) {
            end = end + 1;
        }
        let is i32 as n_in_page = end - cur;
        let is i32 as needs_pad with mut = 0;
        if (n_in_page % 2 != 0) { needs_pad = 1; }
        let is i32 as block_size = 8 + n_in_page * 2 + needs_pad * 2;

        reader.buf_emit32_le(out, page_rva);
        reader.buf_emit32_le(out, cast(i64, block_size));
        // Each entry packs IMAGE_REL_BASED_DIR64 (type 10) in the high
        // 4 bits with the offset-in-page in the low 12 bits.
        let is i64 as DIR64_TAG = 40960;       // 10 << 12
        let is i32 as k with mut = cur;
        while (k < end) {
            reader.buf_emit16_le(out, DIR64_TAG + (rvas[k] % 4096));
            k = k + 1;
        }
        if (needs_pad == 1) {
            reader.buf_emit16_le(out, 0);    // IMAGE_REL_BASED_ABSOLUTE
        }
        written = written + cast(i64, block_size);
        cur = end;
    }
    return written;
}

// ============================================================
// SEH (.pdata / .xdata) support
// ============================================================
//
// Windows x64 requires every non-leaf function in .text to have a
// RUNTIME_FUNCTION entry in .pdata plus a matching UNWIND_INFO blob in
// .xdata, so the OS can unwind the stack for SEH, debugging, and
// `RtlVirtualUnwind` consumers (profilers, ETW). Without these, programs
// that never throw still work, but exception filters in OS code (e.g.
// invalid-handle teardown) take a slow/wrong path and may abort.
//
// UNWIND_INFO header (4 bytes):
//   byte 0: (Flags:5)<<3 | (Version:3)          version=1, flags=0
//   byte 1: SizeOfProlog                          prolog byte count
//   byte 2: CountOfCodes                          number of UNWIND_CODE slots
//   byte 3: (FrameOffset:4)<<4 | FrameRegister:4  0 = no frame register
// then CountOfCodes × UNWIND_CODE slots (2 bytes each):
//   slot byte 0: CodeOffset (prolog byte offset where the op completes)
//   slot byte 1: (OpInfo:4)<<4 | UnwindOp:4
// Padded to a 4-byte boundary so the optional ExceptionHandler / chained
// info that may follow lands aligned.
//
// UnwindOp codes used here:
//   UWOP_PUSH_NONVOL (0): OpInfo = reg number (rbx=3, rbp=5, r12=12..r15=15)
//   UWOP_ALLOC_LARGE (1): info=0 → next u16 slot holds (alloc/8)
//                         info=1 → next two slots hold the alloc bytes (u32)
//   UWOP_ALLOC_SMALL (2): info = (alloc/8) - 1 (range 8..128, step 8)

// Decode the standard Caustic prolog from raw .text bytes. Recognized
// patterns (in this order):
//
//   push rbp         (55)
//   mov rbp, rsp     (48 89 E5)
//   {push rbx | push r12..r15}*
//   one of:
//     - mov rax, N; call __caustic_chkstk; sub rsp, rax  (chkstk path)
//     - sub rsp, imm8                                   (frame ≤ 128)
//     - sub rsp, imm32                                  (frame > 128)
//
// Writes up to N=8 operations into the parallel arrays. Each operation
// gets: offsets[i] = prolog byte offset *after* the op completes,
//        ops[i]    = unwind op code (PUSH_NONVOL/ALLOC_LARGE/ALLOC_SMALL),
//        infos[i]  = op info (reg number or sub-op),
//        extras[i] = ALLOC_LARGE value (0 for other ops).
// Returns number of operations recorded. *out_prolog_size = bytes consumed.
fn decode_user_prologue(text as *u8, max_bytes as i32,
                        offsets as *u8, ops as *u8, infos as *u8, extras as *i32,
                        out_prolog_size as *i32) as i32 {
    let is i32 as pos with mut = 0;
    let is i32 as n with mut = 0;

    // push rbp
    if (pos < max_bytes && text[pos] == cast(u8, 85)) {
        pos = pos + 1;
        offsets[n] = cast(u8, pos);
        ops[n] = cast(u8, 0);    // PUSH_NONVOL
        infos[n] = cast(u8, 5);  // rbp
        extras[n] = 0;
        n = n + 1;
    }
    // mov rbp, rsp  (no unwind code emitted since FrameRegister is unset)
    if (pos + 2 < max_bytes && text[pos] == cast(u8, 72) && text[pos+1] == cast(u8, 137) && text[pos+2] == cast(u8, 229)) {
        pos = pos + 3;
    }
    // push rbx / push r12..r15
    while (n < 8 && pos < max_bytes) {
        if (text[pos] == cast(u8, 83)) {                      // push rbx (0x53)
            pos = pos + 1;
            offsets[n] = cast(u8, pos);
            ops[n] = cast(u8, 0);
            infos[n] = cast(u8, 3);
            extras[n] = 0;
            n = n + 1;
        } else if (pos + 1 < max_bytes && text[pos] == cast(u8, 65)
                   && text[pos+1] >= cast(u8, 84) && text[pos+1] <= cast(u8, 87)) {
            let is i32 as reg = 12 + cast(i32, text[pos+1]) - 84;
            pos = pos + 2;
            offsets[n] = cast(u8, pos);
            ops[n] = cast(u8, 0);
            infos[n] = cast(u8, reg);
            extras[n] = 0;
            n = n + 1;
        } else {
            // Not a push we recognise — end the push-run scan.
            break;
        }
    }
    // chkstk path: 48 C7 C0 NN NN NN NN | E8 NN NN NN NN | 48 29 C4
    if (pos + 15 <= max_bytes
        && text[pos] == cast(u8, 72) && text[pos+1] == cast(u8, 199) && text[pos+2] == cast(u8, 192)
        && text[pos+7] == cast(u8, 232)
        && text[pos+12] == cast(u8, 72) && text[pos+13] == cast(u8, 41) && text[pos+14] == cast(u8, 196)) {
        let is i32 as N = cast(i32, text[pos+3])
                          + cast(i32, text[pos+4]) * 256
                          + cast(i32, text[pos+5]) * 65536
                          + cast(i32, text[pos+6]) * 16777216;
        pos = pos + 15;
        offsets[n] = cast(u8, pos);
        ops[n] = cast(u8, 1);    // ALLOC_LARGE
        if (N % 8 == 0 && N >= 8 && N <= 524280) {
            infos[n] = cast(u8, 0);
            extras[n] = N / 8;
        } else {
            infos[n] = cast(u8, 1);
            extras[n] = N;
        }
        n = n + 1;
    }
    // sub rsp, imm8  (48 83 EC NN)
    else if (pos + 4 <= max_bytes && text[pos] == cast(u8, 72) && text[pos+1] == cast(u8, 131) && text[pos+2] == cast(u8, 236)) {
        let is i32 as N = cast(i32, text[pos+3]);
        pos = pos + 4;
        if (N % 8 == 0 && N >= 8 && N <= 128) {
            offsets[n] = cast(u8, pos);
            ops[n] = cast(u8, 2);    // ALLOC_SMALL
            infos[n] = cast(u8, (N / 8) - 1);
            extras[n] = 0;
            n = n + 1;
        }
    }
    // sub rsp, imm32  (48 81 EC NN NN NN NN)
    else if (pos + 7 <= max_bytes && text[pos] == cast(u8, 72) && text[pos+1] == cast(u8, 129) && text[pos+2] == cast(u8, 236)) {
        let is i32 as N = cast(i32, text[pos+3])
                          + cast(i32, text[pos+4]) * 256
                          + cast(i32, text[pos+5]) * 65536
                          + cast(i32, text[pos+6]) * 16777216;
        pos = pos + 7;
        offsets[n] = cast(u8, pos);
        ops[n] = cast(u8, 1);    // ALLOC_LARGE
        if (N % 8 == 0 && N >= 8 && N <= 524280) {
            infos[n] = cast(u8, 0);
            extras[n] = N / 8;
        } else {
            infos[n] = cast(u8, 1);
            extras[n] = N;
        }
        n = n + 1;
    }
    *out_prolog_size = pos;
    return n;
}

// Compute UNWIND_CODE slot count for a given set of unwind ops.
// PUSH_NONVOL / ALLOC_SMALL → 1 slot each
// ALLOC_LARGE info=0        → 2 slots (op + 1×u16 extras)
// ALLOC_LARGE info=1        → 3 slots (op + 2×u16 extras = u32)
fn count_unwind_slots(ops as *u8, infos as *u8, n as i32) as i32 {
    let is i32 as slots with mut = 0;
    let is i32 as i with mut = 0;
    while (i < n) {
        if (ops[i] == cast(u8, 1) && infos[i] == cast(u8, 0)) {
            slots = slots + 2;
        } else if (ops[i] == cast(u8, 1) && infos[i] == cast(u8, 1)) {
            slots = slots + 3;
        } else {
            slots = slots + 1;
        }
        i = i + 1;
    }
    return slots;
}

// Emit one UNWIND_INFO blob into the .xdata buffer. Returns the offset
// within `out` where the blob starts — store this in the RUNTIME_FUNCTION's
// UnwindInfoAddress (after adding xdata_rva).
fn emit_unwind_info(out as *reader.ByteBuffer, prolog_size as i32,
                    offsets as *u8, ops as *u8, infos as *u8, extras as *i32,
                    n_ops as i32) as i64 {
    let is i64 as off = out.len;
    let is i32 as slots = count_unwind_slots(ops, infos, n_ops);

    // Header
    reader.buf_emit8(out, 1);                       // Version=1, Flags=0
    reader.buf_emit8(out, cast(i32, prolog_size));
    reader.buf_emit8(out, slots);
    reader.buf_emit8(out, 0);                       // FrameReg/FrameOffset = 0

    // Codes — must be in REVERSE chronological order (last prolog op first).
    let is i32 as k with mut = n_ops - 1;
    while (k >= 0) {
        reader.buf_emit8(out, cast(i32, offsets[k]));
        reader.buf_emit8(out, cast(i32, infos[k]) * 16 + cast(i32, ops[k]));
        if (ops[k] == cast(u8, 1) && infos[k] == cast(u8, 0)) {
            reader.buf_emit16_le(out, cast(i64, extras[k]));
        } else if (ops[k] == cast(u8, 1) && infos[k] == cast(u8, 1)) {
            reader.buf_emit32_le(out, cast(i64, extras[k]));
        }
        k = k - 1;
    }
    // Pad to even slot count (UNWIND_INFO is 4-byte aligned overall).
    if (slots % 2 != 0) {
        reader.buf_emit16_le(out, 0);
    }
    return off;
}

// Convenience: emit a hand-built UNWIND_INFO for the entry stub. The stub
// prolog is exactly `sub rsp, 0x428` (7 bytes). One op: ALLOC_LARGE info=0
// with extras = 0x428/8 = 0x85.
fn emit_entry_stub_unwind(out as *reader.ByteBuffer) as i64 {
    let is i64 as off = out.len;
    reader.buf_emit8(out, 1);                       // ver=1, flags=0
    reader.buf_emit8(out, 7);                       // prolog size
    reader.buf_emit8(out, 2);                       // 2 slots
    reader.buf_emit8(out, 0);
    reader.buf_emit8(out, 7); reader.buf_emit8(out, 1);   // slot 0: offset=7, op=1
    reader.buf_emit16_le(out, 133);                 // slot 1: 0x85 = 0x428/8
    return off;
}

// __caustic_chkstk's first two instructions are push rdx (52) and push rcx
// (51). The rest of its prolog (mov rcx,rsp; add rcx,24; mov rdx,rax; round
// rdx up to next 4 KiB) doesn't touch the stack, so we don't describe it.
fn emit_chkstk_unwind(out as *reader.ByteBuffer) as i64 {
    let is i64 as off = out.len;
    reader.buf_emit8(out, 1);                       // ver=1, flags=0
    reader.buf_emit8(out, 2);                       // prolog size
    reader.buf_emit8(out, 2);                       // 2 slots
    reader.buf_emit8(out, 0);
    // reverse order: push rcx (offset 2, reg=1) first, then push rdx (offset 1, reg=2)
    reader.buf_emit8(out, 2); reader.buf_emit8(out, 16);   // info=1 (rcx) << 4 | op=0
    reader.buf_emit8(out, 1); reader.buf_emit8(out, 32);   // info=2 (rdx) << 4 | op=0
    return off;
}

// __caustic_parse_argv pushes rbx as its only stack-touching prolog op.
fn emit_parse_argv_unwind(out as *reader.ByteBuffer) as i64 {
    let is i64 as off = out.len;
    reader.buf_emit8(out, 1);
    reader.buf_emit8(out, 1);                       // prolog size
    reader.buf_emit8(out, 1);                       // 1 slot
    reader.buf_emit8(out, 0);
    reader.buf_emit8(out, 1); reader.buf_emit8(out, 48);   // offset=1, info=3 (rbx) << 4 | op=0
    reader.buf_emit16_le(out, 0);                   // padding for 4-byte alignment
    return off;
}

// ============================================================
// CodeView debug directory + .pdb sidecar
// ============================================================
// Layout written into the trailing slice of .rdata:
//
//   IMAGE_DEBUG_DIRECTORY (28 bytes):
//     u32 Characteristics  = 0
//     u32 TimeDateStamp    = 0
//     u16 MajorVersion     = 0
//     u16 MinorVersion     = 0
//     u32 Type             = 2 (IMAGE_DEBUG_TYPE_CODEVIEW)
//     u32 SizeOfData       = size of the CodeView record below
//     u32 AddressOfRawData = RVA of CodeView record (patched after layout)
//     u32 PointerToRawData = file offset of CodeView record (patched)
//
//   CodeView "RSDS" record (24 + path_len + 1 bytes):
//     u32 Signature        = 0x53445352 ("RSDS")
//     u8[16] GUID
//     u32 Age              = 1
//     u8[] Path            = null-terminated PDB path
//
// DataDirectory[6] is set to (debug_dir_rva, 28). The PDB path is what
// the loader/debugger uses to find the sidecar; the GUID + Age must match
// the .pdb's PDB Info stream for the debugger to accept the symbols.

let is i32 as DEBUG_DIR_SIZE with imut = 28;

// FNV-1a 64-bit hash of (path) used to seed a deterministic GUID. Reproducible
// builds get the same GUID for the same output path; matching .pdb is
// generated against the same hash so the two always agree.
fn _fnv64(s as *u8, len as i64) as i64 {
    let is i64 as h with mut = 0 - 3750763034362895579;  // 0xcbf29ce484222325 as signed
    let is i64 as i with mut = 0;
    while (i < len) {
        h = h ^ cast(i64, s[i]);
        h = h * 1099511628211;
        i = i + 1;
    }
    return h;
}

// Compute a deterministic 16-byte GUID from output_path's basename. Hashing
// the basename (not the full path) keeps reproducible builds reproducible:
// the same `-o foo.exe` from any cwd yields the same GUID. EXE-side and
// PDB-side both call this helper so they always agree.
fn _compute_guid(out_buf as *u8, output_path as *u8) as void {
    let is i64 as plen with mut = 0;
    while (output_path[plen] != cast(u8, 0)) { plen = plen + 1; }
    let is i64 as base_start with mut = 0;
    let is i64 as si2 with mut = plen - 1;
    while (si2 >= 0) {
        if (output_path[si2] == 47 || output_path[si2] == 92) {
            base_start = si2 + 1;
            si2 = 0 - 1;
        } else {
            si2 = si2 - 1;
        }
    }
    let is *u8 as base_ptr = cast(*u8, cast(i64, output_path) + base_start);
    let is i64 as base_len = plen - base_start;
    let is i64 as h1 = _fnv64(base_ptr, base_len);
    // Salt by appending one byte for second half — gives a distinct hash.
    let is *u8 as scratch = om.opt_alloc(base_len + 1);
    let is i64 as si with mut = 0;
    while (si < base_len) { scratch[si] = base_ptr[si]; si = si + 1; }
    scratch[base_len] = cast(u8, 1);
    let is i64 as h2 = _fnv64(scratch, base_len + 1);

    // Microsoft GUID on-disk encoding: Data1 (u32 LE), Data2 (u16 LE),
    // Data3 (u16 LE), Data4 (u8[8] BE). Storing all 16 bytes as one big LE
    // blob works for binding (both EXE-side and PDB-side mirror the same
    // bytes), but tools like dumpbin/llvm-pdbutil display a different-looking
    // GUID — emit mixed-endian so the displayed string matches reality.
    // Data1 = low 32 bits of h1, Data2 = next 16, Data3 = next 16,
    // Data4 = high 16 of h1 + 6 bytes of h2 (taken big-endian).
    out_buf[0]  = cast(u8, h1 & 255);
    out_buf[1]  = cast(u8, (h1 >> 8) & 255);
    out_buf[2]  = cast(u8, (h1 >> 16) & 255);
    out_buf[3]  = cast(u8, (h1 >> 24) & 255);
    out_buf[4]  = cast(u8, (h1 >> 32) & 255);
    out_buf[5]  = cast(u8, (h1 >> 40) & 255);
    out_buf[6]  = cast(u8, (h1 >> 48) & 255);
    out_buf[7]  = cast(u8, (h1 >> 56) & 255);
    // Data4 big-endian: byte 0 is high byte of h2.
    out_buf[8]  = cast(u8, (h2 >> 56) & 255);
    out_buf[9]  = cast(u8, (h2 >> 48) & 255);
    out_buf[10] = cast(u8, (h2 >> 40) & 255);
    out_buf[11] = cast(u8, (h2 >> 32) & 255);
    out_buf[12] = cast(u8, (h2 >> 24) & 255);
    out_buf[13] = cast(u8, (h2 >> 16) & 255);
    out_buf[14] = cast(u8, (h2 >> 8) & 255);
    out_buf[15] = cast(u8, h2 & 255);
}

// Derive PDB path from output_path: strip directory prefix and a trailing
// ".exe", then append ".pdb". Embedding only the basename keeps the RSDS
// record stable across invocations from different cwd, so `-o stage.exe`
// and `-o /tmp/build/stage.exe` produce byte-identical binaries.
// Returns a freshly-allocated null-terminated buffer; out_len receives its
// length (not counting the null).
fn _compute_pdb_path(output_path as *u8, out_len as *i32) as *u8 {
    let is i32 as plen with mut = 0;
    while (output_path[plen] != cast(u8, 0)) { plen = plen + 1; }
    // Find basename start: last '/' or '\\' in the path.
    let is i32 as base_start with mut = 0;
    let is i32 as si with mut = plen - 1;
    while (si >= 0) {
        if (output_path[si] == 47 || output_path[si] == 92) {
            base_start = si + 1;
            si = cast(i32, 0 - 1);
        } else {
            si = si - 1;
        }
    }
    let is i32 as base_len with mut = plen - base_start;
    if (base_len >= 4) {
        let is i32 as tail = base_start + base_len - 4;
        if (output_path[tail] == 46
            && (output_path[tail + 1] == 101 || output_path[tail + 1] == 69)
            && (output_path[tail + 2] == 120 || output_path[tail + 2] == 88)
            && (output_path[tail + 3] == 101 || output_path[tail + 3] == 69)) {
            base_len = base_len - 4;
        }
    }
    let is i32 as total = base_len + 4;
    let is *u8 as buf = om.opt_alloc(cast(i64, total + 1));
    let is i32 as i with mut = 0;
    while (i < base_len) { buf[i] = output_path[base_start + i]; i = i + 1; }
    buf[base_len]     = cast(u8, 46);   // '.'
    buf[base_len + 1] = cast(u8, 112);  // 'p'
    buf[base_len + 2] = cast(u8, 100);  // 'd'
    buf[base_len + 3] = cast(u8, 98);   // 'b'
    buf[total]        = cast(u8, 0);
    *out_len = total;
    return buf;
}

// Append IMAGE_DEBUG_DIRECTORY + RSDS to rodata_buf. RVA/file fields written
// as placeholder zeros; _patch_debug_dir fills them once rodata's final
// position is known. Returns the rsds_size (used for SizeOfData later).
//
// Side effect: out_guid is filled with the 16-byte GUID so the PDB writer
// can use the same value.
fn _emit_debug_entries(rodata_buf as *reader.ByteBuffer,
                       output_path as *u8,
                       out_dir_off as *i64,
                       out_rsds_off as *i64,
                       out_guid as *u8,
                       out_pdb_path as **u8,
                       out_pdb_path_len as *i32) as i32 {
    *out_dir_off = rodata_buf.len;
    // IMAGE_DEBUG_DIRECTORY (28 bytes) — AddressOfRawData / PointerToRawData
    // are placeholders; _patch_debug_dir patches them after layout.
    reader.buf_emit32_le(rodata_buf, 0);                  // Characteristics
    reader.buf_emit32_le(rodata_buf, 0);                  // TimeDateStamp
    reader.buf_emit16_le(rodata_buf, 0);                  // MajorVersion
    reader.buf_emit16_le(rodata_buf, 0);                  // MinorVersion
    reader.buf_emit32_le(rodata_buf, 2);                  // Type = CODEVIEW
    reader.buf_emit32_le(rodata_buf, 0);                  // SizeOfData (patched)
    reader.buf_emit32_le(rodata_buf, 0);                  // AddressOfRawData (patched)
    reader.buf_emit32_le(rodata_buf, 0);                  // PointerToRawData (patched)

    *out_rsds_off = rodata_buf.len;
    // RSDS record
    _compute_guid(out_guid, output_path);
    let is i32 as pdb_path_len with mut = 0;
    let is *u8 as pdb_path = _compute_pdb_path(output_path, &pdb_path_len);
    *out_pdb_path = pdb_path;
    *out_pdb_path_len = pdb_path_len;

    reader.buf_emit8(rodata_buf, 82);                     // 'R'
    reader.buf_emit8(rodata_buf, 83);                     // 'S'
    reader.buf_emit8(rodata_buf, 68);                     // 'D'
    reader.buf_emit8(rodata_buf, 83);                     // 'S'
    let is i32 as gi with mut = 0;
    while (gi < 16) {
        reader.buf_emit8(rodata_buf, cast(i32, out_guid[gi]));
        gi = gi + 1;
    }
    reader.buf_emit32_le(rodata_buf, 1);                  // Age = 1
    let is i32 as pi with mut = 0;
    while (pi < pdb_path_len) {
        reader.buf_emit8(rodata_buf, cast(i32, pdb_path[pi]));
        pi = pi + 1;
    }
    reader.buf_emit8(rodata_buf, 0);                      // null terminator

    // 4-byte align so subsequent rodata content stays aligned.
    while ((rodata_buf.len & 3) != 0) { reader.buf_emit8(rodata_buf, 0); }

    let is i32 as rsds_size = 24 + pdb_path_len + 1;
    return rsds_size;
}

// ============================================================
// PDB Publics builders
// ============================================================
// Walk the linker's global symbol table and produce two buffers:
//
//   symrec_buf  — sequence of S_PUB32 records, each 4-byte aligned with
//                 padding bytes 0xF1/0xF2/0xF3. This is the "Symbol
//                 Records Stream" referenced by the DBI header's
//                 SymRecordStream field.
//
//   publics_buf — PSGSI header (28B) + an empty GSI hash header (16B,
//                 NumBuckets=0 so the on-disk format has no buckets
//                 or hash records) + an address map: u32[N] of offsets
//                 into symrec_buf, sorted by RVA. This is what
//                 PublicStreamIndex points at.
//
// We deliberately ship an empty hash table — name-based lookup falls
// back to a linear scan of the address map. Sufficient for v1; the
// IPHR_HASH bucket layout is intricate enough that getting it right
// deserves its own pass.

let is i64 as S_PUB32 with imut = 4366;     // 0x110E
let is i64 as PUB32_FLAG_FUNCTION with imut = 2;
let is i64 as GSI_HEADER_VERSIG with imut = 4294967295;     // -1 as u32
let is i64 as GSI_HEADER_VERHDR with imut = 4046391578;     // 0xeffe0000 + 19990810 = 0xF12F091A

// CodeView/PDB GSI V1 hash function. Folds the byte string four-bytes-at-
// a-time into a 32-bit accumulator, masks to lowercase ASCII, mixes, and
// reduces mod IPHR_HASH (4096). Matches MS PDB toolchain hashStringV1.
let is i64 as IPHR_HASH with imut = 4096;
let is i64 as MASK32   with imut = 4294967295;       // 0xFFFFFFFF
let is i64 as TOLOWER  with imut = 538976288;        // 0x20202020

fn _gsi_hash_v1(name as *u8, len as i32) as i32 {
    let is i64 as result with mut = 0;
    let is i32 as size with mut = len;
    let is i32 as i with mut = 0;
    while (size >= 4) {
        let is i64 as chunk = cast(i64, name[i])
                            + (cast(i64, name[i + 1]) << 8)
                            + (cast(i64, name[i + 2]) << 16)
                            + (cast(i64, name[i + 3]) << 24);
        result = (result ^ chunk) & MASK32;
        i = i + 4;
        size = size - 4;
    }
    if (size >= 2) {
        let is i64 as chunk = cast(i64, name[i])
                            + (cast(i64, name[i + 1]) << 8);
        result = (result ^ chunk) & MASK32;
        i = i + 2;
        size = size - 2;
    }
    if (size > 0) {
        result = (result ^ cast(i64, name[i])) & MASK32;
    }
    result = (result | TOLOWER) & MASK32;
    result = (result ^ (result >> 11)) & MASK32;
    result = (result ^ (result >> 16)) & MASK32;
    return cast(i32, result & 4095);
}

// Insertion-sort the i-th and j-th elements of three parallel arrays so
// that buckets[] is non-decreasing. Stable — preserves the relative order
// of equal-bucket records (which arrive in VA order, the address map's
// invariant).
fn _sort_by_bucket(buckets as *i32, offsets as *i32, vaddrs as *i64, n as i32) as void {
    let is i32 as i with mut = 1;
    while (i < n) {
        let is i32 as cur_b = buckets[i];
        let is i32 as cur_o = offsets[i];
        let is i64 as cur_v = vaddrs[i];
        let is i32 as j with mut = i - 1;
        while (j >= 0 && buckets[j] > cur_b) {
            buckets[j + 1] = buckets[j];
            offsets[j + 1] = offsets[j];
            vaddrs[j + 1]  = vaddrs[j];
            j = j - 1;
        }
        buckets[j + 1] = cur_b;
        offsets[j + 1] = cur_o;
        vaddrs[j + 1]  = cur_v;
        i = i + 1;
    }
}

// Sort an array of (vaddr, symrec_offset) pairs by vaddr ascending.
// Used to build the publics address map in monotonic order.
fn _sort_addr_map(vaddrs as *i64, offsets as *i32, n as i32) as void {
    let is i32 as i with mut = 1;
    while (i < n) {
        let is i64 as cur_v = vaddrs[i];
        let is i32 as cur_o = offsets[i];
        let is i32 as j with mut = i - 1;
        while (j >= 0 && vaddrs[j] > cur_v) {
            vaddrs[j + 1] = vaddrs[j];
            offsets[j + 1] = offsets[j];
            j = j - 1;
        }
        vaddrs[j + 1] = cur_v;
        offsets[j + 1] = cur_o;
        i = i + 1;
    }
}

// Build the Symbol Records + Publics buffers from the linker's gsyms.
// Returns the number of functions emitted; the caller uses this to set
// AddrMap byte size in the PSGSI header.
fn build_publics_buffers(ls as *linker.LinkerState,
                         text_section_va as i64,
                         out_symrec as *reader.ByteBuffer,
                         out_publics as *reader.ByteBuffer) as i32 {
    let is *linker.GlobalSymTab as gsyms = linker.get_gsyms(ls);

    // First pass: count + capture (vaddr, symrec_off) per text-section gsym.
    let is *i64 as vaddrs = cast(*i64, om.opt_alloc(8192));   // up to 1024 entries
    let is *i32 as offsets = cast(*i32, om.opt_alloc(4096));
    let is i32 as count with mut = 0;

    let is i32 as gi with mut = 0;
    while (gi < gsyms.count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, gi);
        if (g.defined == 1 && g.section == reader.SECIDX_TEXT && count < 1024) {
            // Total record size: 14 fixed header bytes (incl. RecLen) + name
            // + nul, aligned up to 4. RecLen value reports total-minus-RecLen
            // field (2 bytes), so the consumer reads `RecLen` bytes following
            // the RecLen field itself.
            let is i32 as total_unaligned = 14 + g.name_len + 1;
            let is i32 as total with mut = total_unaligned;
            while ((total & 3) != 0) { total = total + 1; }

            let is i32 as symrec_off = cast(i32, out_symrec.len);
            reader.buf_emit16_le(out_symrec, total - 2);
            reader.buf_emit16_le(out_symrec, S_PUB32);
            reader.buf_emit32_le(out_symrec, PUB32_FLAG_FUNCTION);
            reader.buf_emit32_le(out_symrec, g.vaddr - text_section_va);
            reader.buf_emit16_le(out_symrec, 1);              // segment = .text
            let is i32 as ni with mut = 0;
            while (ni < g.name_len) {
                reader.buf_emit8(out_symrec, cast(i32, g.name[ni]));
                ni = ni + 1;
            }
            reader.buf_emit8(out_symrec, 0);
            // Pad with the CV pad bytes 0xF1, 0xF2, 0xF3 (incremented per byte).
            let is i32 as pad_byte with mut = 241;  // 0xF1
            while ((cast(i32, out_symrec.len) & 3) != 0) {
                reader.buf_emit8(out_symrec, pad_byte);
                pad_byte = pad_byte + 1;
            }

            vaddrs[count] = g.vaddr;
            offsets[count] = symrec_off;
            count = count + 1;
        }
        gi = gi + 1;
    }

    _sort_addr_map(vaddrs, offsets, count);

    // Build the GSI hash table for name-based symbol lookup. Records are
    // grouped by bucket (the GSI hash mod IPHR_HASH=4096), then within
    // each bucket kept in VA order. The on-disk layout is:
    //
    //   GSIHashHeader (16B) — VerSig | VerHdr | HrSize | NumBuckets
    //   HashRecord[count]   — { u32 Off; u32 CRef } per record, sorted by bucket
    //   PresentBitmap       — u32[129] (4097 bits + slack zero)
    //   BucketOffsets       — u32 per set bucket, value = first_record_in_bucket * 12
    //                         (the 12 is an MSVC compat quirk — records are 8 bytes
    //                          on disk but offsets are scaled by 12).
    //
    // For 0 records we keep the empty form (HrSize=0, NumBuckets=0) — the
    // GSIHashHeader still emits since the consumer always reads it.
    let is *i32 as buckets   = cast(*i32, om.opt_alloc(cast(i64, count) * 4));
    let is *i32 as hr_offs   = cast(*i32, om.opt_alloc(cast(i64, count) * 4));
    let is *i64 as hr_vaddrs = cast(*i64, om.opt_alloc(cast(i64, count) * 8));

    // Recover (name, vaddr) for each record so we can hash. Walk gsyms in
    // VA-sorted order — that's the order the records were emitted.
    let is *i32 as sorted_vaddr_to_gsym = cast(*i32, om.opt_alloc(cast(i64, count) * 4));
    let is i32 as si with mut = 0;
    while (si < count) {
        let is i32 as gj with mut = 0;
        while (gj < gsyms.count) {
            let is *linker.GlobalSym as gg = linker.gsym_get(gsyms, gj);
            if (gg.defined == 1 && gg.section == reader.SECIDX_TEXT
                && gg.vaddr == vaddrs[si]) {
                sorted_vaddr_to_gsym[si] = gj;
                gj = gsyms.count;
            }
            gj = gj + 1;
        }
        let is *linker.GlobalSym as gh = linker.gsym_get(gsyms, sorted_vaddr_to_gsym[si]);
        buckets[si]   = _gsi_hash_v1(gh.name, gh.name_len);
        hr_offs[si]   = offsets[si];
        hr_vaddrs[si] = vaddrs[si];
        si = si + 1;
    }
    _sort_by_bucket(buckets, hr_offs, hr_vaddrs, count);

    // Count distinct buckets and build present bitmap. PresentBitmap is
    // 129 u32 words (covers 4128 bits, of which 4097 are meaningful).
    let is [129]i64 as bitmap;
    let is i32 as bi with mut = 0;
    while (bi < 129) { bitmap[bi] = 0; bi = bi + 1; }
    let is i32 as num_used_buckets with mut = 0;
    let is i32 as last_bucket with mut = 0;
    last_bucket = last_bucket - 1;
    let is i32 as bj with mut = 0;
    while (bj < count) {
        if (buckets[bj] != last_bucket) {
            last_bucket = buckets[bj];
            bitmap[last_bucket / 32] = bitmap[last_bucket / 32]
                                       | (cast(i64, 1) << (last_bucket & 31));
            num_used_buckets = num_used_buckets + 1;
        }
        bj = bj + 1;
    }

    let is i32 as hr_size = count * 8;
    let is i32 as buckets_size with mut = 0;
    if (count > 0) { buckets_size = 516 + num_used_buckets * 4; }
    let is i32 as sym_hash_size = 16 + hr_size + buckets_size;
    let is i32 as addr_map_size = count * 4;

    // PSGSI header
    reader.buf_emit32_le(out_publics, cast(i64, sym_hash_size));
    reader.buf_emit32_le(out_publics, cast(i64, addr_map_size));
    reader.buf_emit32_le(out_publics, 0);                 // NumThunks
    reader.buf_emit32_le(out_publics, 0);                 // SizeOfThunk
    reader.buf_emit16_le(out_publics, 0);                 // ISectThunkTable
    reader.buf_emit16_le(out_publics, 0);                 // Padding
    reader.buf_emit32_le(out_publics, 0);                 // OffThunkTable
    reader.buf_emit32_le(out_publics, 0);                 // NumSections

    // GSI hash header (16B)
    reader.buf_emit32_le(out_publics, GSI_HEADER_VERSIG);
    reader.buf_emit32_le(out_publics, GSI_HEADER_VERHDR);
    reader.buf_emit32_le(out_publics, cast(i64, hr_size));
    reader.buf_emit32_le(out_publics, cast(i64, buckets_size));

    // HashRecord array (8 bytes each, sorted by bucket).
    let is i32 as hi with mut = 0;
    while (hi < count) {
        reader.buf_emit32_le(out_publics, cast(i64, hr_offs[hi] + 1));     // Off (1-based)
        reader.buf_emit32_le(out_publics, 1);                              // CRef
        hi = hi + 1;
    }

    if (count > 0) {
        // PresentBitmap: 129 u32s (516 bytes).
        let is i32 as bw with mut = 0;
        while (bw < 129) {
            reader.buf_emit32_le(out_publics, bitmap[bw]);
            bw = bw + 1;
        }

        // Bucket offsets in ascending bucket order. value = first-record-
        // index * 12 (MSVC compat — see header comment).
        last_bucket = 0;
        last_bucket = last_bucket - 1;
        let is i32 as bk with mut = 0;
        while (bk < count) {
            if (buckets[bk] != last_bucket) {
                reader.buf_emit32_le(out_publics, cast(i64, bk * 12));
                last_bucket = buckets[bk];
            }
            bk = bk + 1;
        }
    }

    // Address map: sorted offsets into symrec stream.
    let is i32 as ai with mut = 0;
    while (ai < count) {
        reader.buf_emit32_le(out_publics, cast(i64, offsets[ai]));
        ai = ai + 1;
    }

    return count;
}

// ============================================================
// CodeView module symbol stream builder (line tables)
// ============================================================
// The assembler emitted a `.cstdebug` custom section per .obj with
// (text_offset, line_number) records captured from `.loc` directives.
// Here we read that data back, correlate with the sorted gsym table to
// determine per-function line ranges, and emit a CodeView module
// symbol stream:
//
//   u32 CV_SIGNATURE_C13 = 4
//   Subsection SYMBOLS (0xF1):
//     S_OBJNAME (0x1101)
//     S_COMPILE3 (0x113C)
//     per function:
//       S_GPROC32 (0x1110) + S_FRAMEPROC (0x1012) + S_END (0x0006)
//   Subsection LINES (0xF2) per function:
//     header { offCon, segCon, flags, cbCon }
//     file block { offFile, nLines, cbBlock }
//     line entries { offset, flags = line | 0x80000000 (statement) }
//   Subsection STRINGTABLE (0xF3): null-term strings (just the source path)
//   Subsection FILECHKSMS (0xF4): one entry (offFile=0, cbChecksum=0, kind=0)
//
// Output is one buffer the PDB writer drops into its module stream.

let is i32 as CV_SIGNATURE_C13 with imut = 4;
let is i32 as DEBUG_S_SYMBOLS with imut = 241;       // 0xF1
let is i32 as DEBUG_S_LINES   with imut = 242;       // 0xF2
let is i32 as DEBUG_S_STRINGTABLE with imut = 243;   // 0xF3
let is i32 as DEBUG_S_FILECHKSMS with imut = 244;    // 0xF4
let is i32 as S_END         with imut = 6;
let is i32 as S_FRAMEPROC   with imut = 4114;        // 0x1012
let is i32 as S_OBJNAME     with imut = 4353;        // 0x1101
let is i32 as S_GPROC32     with imut = 4368;        // 0x1110
let is i32 as S_GPROC32_ID  with imut = 4423;        // 0x1147
let is i32 as S_COMPILE3    with imut = 4412;        // 0x113C
let is i32 as S_BUILDINFO   with imut = 4428;        // 0x114C
let is i32 as S_LOCAL       with imut = 4414;        // 0x113E
let is i32 as S_DEFRANGE_FPR with imut = 4418;       // 0x1142  S_DEFRANGE_FRAMEPOINTER_REL
let is i32 as LF_POINTER    with imut = 4098;        // 0x1002
let is i32 as LF_ARRAY      with imut = 5379;        // 0x1503
let is i32 as LF_STRUCTURE  with imut = 5381;        // 0x1505
let is i32 as LF_FIELDLIST  with imut = 4611;        // 0x1203
let is i32 as LF_MEMBER     with imut = 5389;        // 0x150D
let is i32 as LF_ARGLIST    with imut = 4609;        // 0x1201
let is i32 as LF_PROCEDURE  with imut = 4104;        // 0x1008
let is i32 as LF_FUNC_ID    with imut = 5633;        // 0x1601
let is i32 as LF_BUILDINFO  with imut = 5635;        // 0x1603
let is i32 as LF_STRING_ID  with imut = 5637;        // 0x1605
let is i32 as TYPE_INDEX_BEGIN_LINKER with imut = 4096;   // 0x1000

// CV PointerAttributes for 64-bit near data pointer:
//   PtrType=0x0C (Near64) | Size=8 (in field starting at bit 13).
let is i32 as CV_PTR_ATTR_NEAR64 with imut = 65548;  // 0x1000C
// TPI type index of the universal int(*)() LF_PROCEDURE pdb_writer publishes
// at TYPE_INDEX_BEGIN+1. Must match the layout in caustic-linker/pdb_writer.cst.
let is i32 as TYPE_IDX_UNIVERSAL_FN with imut = 4097;  // 0x1001
// IPI item indices start here; the i-th defined TEXT gsym (in VA-sorted order)
// gets index IPI_INDEX_BEGIN + i. S_GPROC32_ID records reference these.
let is i32 as IPI_INDEX_BEGIN with imut = 4096;       // 0x1000
// CSTDEBUG_MAGIC lives in caustic-shared/debug_proto.cst — assembler writes
// it, linker reads it; centralizing prevents silent drift.

// Locate .cstdebug section in this obj. Returns the section pointer or null.
fn _find_cstdebug(obj as *reader.ObjFile) as *reader.ObjSection {
    let is *i64 as names = cast(*i64, obj.csec_names);
    let is *i32 as nlens = cast(*i32, obj.csec_name_lens);
    let is i32 as i with mut = 0;
    while (i < obj.csec_count) {
        let is *u8 as nm = cast(*u8, names[i]);
        if (nlens[i] == 9 && reader.streq(nm, 9, ".cstdebug", 9) == 1) {
            return cast(*reader.ObjSection,
                cast(i64, obj.csec_data) + cast(i64, i) * sizeof(reader.ObjSection));
        }
        i = i + 1;
    }
    return cast(*reader.ObjSection, 0);
}

fn _read_u32_at(p as *u8, off as i64) as i64 {
    return cast(i64, p[off])
         + (cast(i64, p[off + 1]) << 8)
         + (cast(i64, p[off + 2]) << 16)
         + (cast(i64, p[off + 3]) << 24);
}

// Insertion-sort indices by gsym vaddr. Used to walk text-section gsyms in
// ascending RVA order so we can derive function sizes as
// (next_func_vaddr - this_func_vaddr).
fn _sort_indices(idx as *i32, vaddrs as *i64, n as i32) as void {
    let is i32 as i with mut = 1;
    while (i < n) {
        let is i32 as cur_idx = idx[i];
        let is i64 as cur_v = vaddrs[i];
        let is i32 as j with mut = i - 1;
        while (j >= 0 && vaddrs[j] > cur_v) {
            idx[j + 1] = idx[j];
            vaddrs[j + 1] = vaddrs[j];
            j = j - 1;
        }
        idx[j + 1] = cur_idx;
        vaddrs[j + 1] = cur_v;
        i = i + 1;
    }
}

// Emit a CodeView subsection header: u32 kind, u32 size, then payload.
// Caller writes the payload and we patch the size field at the end via
// _patch_subsec_size.
fn _start_subsec(out as *reader.ByteBuffer, kind as i32) as i64 {
    reader.buf_emit32_le(out, cast(i64, kind));
    let is i64 as size_off = out.len;
    reader.buf_emit32_le(out, 0);                  // size placeholder
    return size_off;
}

fn _patch_subsec_size(out as *reader.ByteBuffer, size_off as i64) as void {
    let is i64 as size = out.len - size_off - 4;
    let is *u8 as p = out.data;
    p[size_off]     = cast(u8, size & 255);
    p[size_off + 1] = cast(u8, (size >> 8) & 255);
    p[size_off + 2] = cast(u8, (size >> 16) & 255);
    p[size_off + 3] = cast(u8, (size >> 24) & 255);
    // CodeView subsections are 4-byte aligned.
    while ((out.len & 3) != 0) { reader.buf_emit8(out, 0); }
}

// Emit a CodeView symbol record: u16 len, u16 kind, payload, then 0xF1 pad.
// Returns the offset where the length field was written so the caller can
// patch it once the payload is complete.
fn _start_sym(out as *reader.ByteBuffer, kind as i32) as i64 {
    let is i64 as len_off = out.len;
    reader.buf_emit16_le(out, 0);                  // length placeholder
    reader.buf_emit16_le(out, cast(i64, kind));
    return len_off;
}

fn _patch_sym_size(out as *reader.ByteBuffer, len_off as i64) as void {
    // CodeView RecordLen must include the pad bytes — consumers compute the
    // next record's offset as (current + RecLen + 2), so pad first and only
    // then write the length so it accounts for the padding.
    let is i32 as pad_byte with mut = 241;
    while ((out.len & 3) != 0) {
        reader.buf_emit8(out, pad_byte);
        pad_byte = pad_byte + 1;
    }
    let is i64 as total = out.len - len_off;
    let is i64 as len_val = total - 2;
    let is *u8 as p = out.data;
    p[len_off]     = cast(u8, len_val & 255);
    p[len_off + 1] = cast(u8, (len_val >> 8) & 255);
}

// Build the per-module symbol stream blob. Returns 0 if no .cstdebug data
// is present (out_buf left empty); caller treats it as "no line info".
// Stream layout (per LLVM PDB spec):
//   u32 Signature = CV_SIGNATURE_C13 (4)
//   u8[SymByteSize - 4] raw symbol records (no subsection wrapper)
//   u8[C11ByteSize=0]
//   u8[C13ByteSize] DEBUG_S_* subsections (LINES, STRINGTABLE, FILECHKSMS)
//   u32 GlobalRefsSize = 0
//
// out_sym_size / out_c13_size are filled in so the DBI ModuleInfo header
// can describe the layout boundaries.
fn build_module_stream(ls as *linker.LinkerState,
                       text_section_va as i64,
                       out_buf as *reader.ByteBuffer,
                       out_source as **u8, out_source_len as *i32,
                       out_sym_size as *i32, out_c13_size as *i32,
                       struct_indices as *i32, num_structs as i32,
                       typemap_keys as *i64, typemap_vals as *i32,
                       typemap_count as i32) as i32 {
    // 1. Read .cstdebug from EVERY .obj and merge into a single loc table.
    //    Each .cstdebug entry's text_offset is obj-local; we add the obj's
    //    final text_offset so all entries live in the merged-.text frame the
    //    gsym vaddrs use. The first obj's source filename becomes the
    //    module's reported source (multi-source-file support would require
    //    a STRINGTABLE/FILECHKSMS rewrite — tracked separately).
    if (ls.obj_count == 0) { return 0; }
    let is i32 as MERGED_LOC_CAP = 65536;
    let is *i32 as merged_offsets = cast(*i32, om.opt_alloc(cast(i64, MERGED_LOC_CAP) * 4));
    let is *i32 as merged_lines   = cast(*i32, om.opt_alloc(cast(i64, MERGED_LOC_CAP) * 4));
    let is i32 as merged_count with mut = 0;
    *out_source = cast(*u8, 0);
    *out_source_len = 0;

    let is i32 as oi with mut = 0;
    while (oi < ls.obj_count) {
        let is *reader.ObjFile as o = linker.get_obj(ls, oi);
        let is *reader.ObjSection as ds = _find_cstdebug(o);
        if (cast(i64, ds) != 0 && ds.size >= 16) {
            let is *u8 as dbg_b = ds.data;
            if (_read_u32_at(dbg_b, 0) == dbgproto.CSTDEBUG_MAGIC) {
                let is i64 as src_len_b = _read_u32_at(dbg_b, 8);
                if (*out_source_len == 0 && src_len_b > 0) {
                    *out_source = cast(*u8, cast(i64, dbg_b) + 12);
                    *out_source_len = cast(i32, src_len_b);
                }
                let is i64 as loff with mut = 12 + src_len_b;
                while ((loff & 3) != 0) { loff = loff + 1; }
                let is i64 as n_b = _read_u32_at(dbg_b, loff);
                let is i64 as base_b = loff + 4;
                let is i64 as t_off_b = o.text_offset;
                let is i64 as li_b with mut = 0;
                while (li_b < n_b && merged_count < MERGED_LOC_CAP) {
                    let is i64 as local_b = _read_u32_at(dbg_b, base_b + li_b * 8);
                    let is i64 as line_b  = _read_u32_at(dbg_b, base_b + li_b * 8 + 4);
                    merged_offsets[merged_count] = cast(i32, t_off_b + local_b);
                    merged_lines[merged_count]   = cast(i32, line_b);
                    merged_count = merged_count + 1;
                    li_b = li_b + 1;
                }
            }
        }
        oi = oi + 1;
    }

    if (*out_source_len == 0) { return 0; }
    let is i64 as num_locs = cast(i64, merged_count);

    // 2. Collect text-section gsyms sorted by vaddr.
    let is *linker.GlobalSymTab as gsyms = linker.get_gsyms(ls);
    let is *i32 as idx_arr = cast(*i32, om.opt_alloc(1024 * 4));
    let is *i64 as va_arr  = cast(*i64, om.opt_alloc(1024 * 8));
    let is i32 as func_count with mut = 0;
    let is i32 as gi with mut = 0;
    while (gi < gsyms.count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, gi);
        if (g.defined == 1 && g.section == reader.SECIDX_TEXT && func_count < 1024) {
            idx_arr[func_count] = gi;
            va_arr[func_count] = g.vaddr;
            func_count = func_count + 1;
        }
        gi = gi + 1;
    }
    _sort_indices(idx_arr, va_arr, func_count);

    // 3. Emit CV_SIGNATURE_C13 then raw symbol records (no subsection wrapper).
    reader.buf_emit32_le(out_buf, cast(i64, CV_SIGNATURE_C13));

    // S_OBJNAME
    let is i64 as obj_sym = _start_sym(out_buf, S_OBJNAME);
    reader.buf_emit32_le(out_buf, 0);                // signature
    let is i32 as si with mut = 0;
    while (si < *out_source_len) {
        reader.buf_emit8(out_buf, cast(i32, (*out_source)[si]));
        si = si + 1;
    }
    reader.buf_emit8(out_buf, 0);
    _patch_sym_size(out_buf, obj_sym);

    // S_COMPILE3 — minimal: machine=0xD0 (AMD64), language=0 (C)
    let is i64 as compile_sym = _start_sym(out_buf, S_COMPILE3);
    reader.buf_emit32_le(out_buf, 0);                // flags + language byte (lang=0 C)
    reader.buf_emit16_le(out_buf, 208);              // CV_CFL_X64 = 0xD0
    reader.buf_emit16_le(out_buf, 0); reader.buf_emit16_le(out_buf, 0);
    reader.buf_emit16_le(out_buf, 0); reader.buf_emit16_le(out_buf, 0);
    reader.buf_emit16_le(out_buf, 0); reader.buf_emit16_le(out_buf, 0);
    reader.buf_emit16_le(out_buf, 0); reader.buf_emit16_le(out_buf, 0);
    let is *u8 as cstr = "Caustic 0.1";
    let is i32 as ci with mut = 0;
    while (ci < 11) { reader.buf_emit8(out_buf, cast(i32, cstr[ci])); ci = ci + 1; }
    reader.buf_emit8(out_buf, 0);
    _patch_sym_size(out_buf, compile_sym);

    // S_BUILDINFO — references LF_BUILDINFO in IPI at known slot. Layout:
    // u16 RecLen, u16 Kind, u32 BuildId. Total 8 bytes (4-aligned, no pad).
    let is i64 as bi_sym = _start_sym(out_buf, S_BUILDINFO);
    reader.buf_emit32_le(out_buf, cast(i64, buildinfo_ipi_index(func_count)));
    _patch_sym_size(out_buf, bi_sym);

    // S_GPROC32 + S_FRAMEPROC + S_END per function
    let is i32 as fi with mut = 0;
    while (fi < func_count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, idx_arr[fi]);
        let is i64 as fn_off = g.vaddr - text_section_va;
        let is i64 as fn_end with mut = ls.text_vaddr + cast(i64, ls.text_size);
        if (fi + 1 < func_count) {
            let is *linker.GlobalSym as ng = linker.gsym_get(gsyms, idx_arr[fi + 1]);
            fn_end = ng.vaddr;
        }
        let is i64 as fn_size = fn_end - g.vaddr;

        // S_GPROC32_ID uses an IPI item index (LF_FUNC_ID) — one per
        // function in VA-sorted order, allocated sequentially from
        // IPI_INDEX_BEGIN. `fi` is exactly that ordinal.
        let is i64 as proc_sym = _start_sym(out_buf, S_GPROC32_ID);
        reader.buf_emit32_le(out_buf, 0);             // pParent
        reader.buf_emit32_le(out_buf, 0);             // pEnd (patched later, leave 0)
        reader.buf_emit32_le(out_buf, 0);             // pNext
        reader.buf_emit32_le(out_buf, fn_size);       // codeSize
        reader.buf_emit32_le(out_buf, 0);             // dbgStart
        reader.buf_emit32_le(out_buf, fn_size);       // dbgEnd
        reader.buf_emit32_le(out_buf, cast(i64, IPI_INDEX_BEGIN + fi));  // funcIdIndex → LF_FUNC_ID
        reader.buf_emit32_le(out_buf, fn_off);        // offset
        reader.buf_emit16_le(out_buf, 1);             // segment = .text
        reader.buf_emit8(out_buf, 0);                 // flags
        let is i32 as ni with mut = 0;
        while (ni < g.name_len) {
            reader.buf_emit8(out_buf, cast(i32, g.name[ni]));
            ni = ni + 1;
        }
        reader.buf_emit8(out_buf, 0);
        _patch_sym_size(out_buf, proc_sym);

        // S_FRAMEPROC (minimal) — struct layout per LLVM FrameProcSym:
        // 4*u32 (frame metrics) + u32 ehOffset + u16 ehSection + u16 pad +
        // u32 flags = 28 bytes. Missing the pad u16 makes the consumer
        // mis-parse the next record's header.
        let is i64 as fp_sym = _start_sym(out_buf, S_FRAMEPROC);
        reader.buf_emit32_le(out_buf, fn_size);       // total frame size (approx)
        reader.buf_emit32_le(out_buf, 0);             // padSize
        reader.buf_emit32_le(out_buf, 0);             // padOff
        reader.buf_emit32_le(out_buf, 0);             // saveRegsCount
        reader.buf_emit32_le(out_buf, 0);             // ehOffset
        reader.buf_emit16_le(out_buf, 0);             // ehSection
        reader.buf_emit16_le(out_buf, 0);             // pad
        reader.buf_emit32_le(out_buf, 0);             // flags
        _patch_sym_size(out_buf, fp_sym);

        // S_LOCAL + S_DEFRANGE_FRAMEPOINTER_REL per local from .cstlocals.
        // Locals (params + lets) live at [rbp - var_offset]; the debugger
        // wants the offset relative to the frame pointer (rbp here), so we
        // negate. The defrange covers the function's whole code span.
        let is *reader.ObjSection as loc_sec = cast(*reader.ObjSection, 0);
        let is i64 as loc_off with mut = 0;
        if (_lookup_locals(ls, g.name, g.name_len, &loc_sec, &loc_off) == 1) {
            let is *u8 as lp = loc_sec.data;
            let is i64 as num_locals = _read_u32_at(lp, loc_off);
            let is i64 as cursor with mut = loc_off + 4;
            let is i64 as li2 with mut = 0;
            while (li2 < num_locals && cursor + 4 <= loc_sec.size) {
                let is i64 as lnl = _read_u32_at(lp, cursor);
                if (cursor + 4 + lnl + 12 > loc_sec.size) { li2 = num_locals; continue; }
                cursor = cursor + 4;
                let is *u8 as lname = cast(*u8, cast(i64, lp) + cursor);
                cursor = cursor + lnl;
                let is i64 as voff = _read_u32_at(lp, cursor);            cursor = cursor + 4;
                let is i32 as tk   = cast(i32, _read_u32_at(lp, cursor)); cursor = cursor + 4;
                let is i32 as te   = cast(i32, _read_u32_at(lp, cursor)); cursor = cursor + 4;

                // S_LOCAL: u16 RecLen, u16 Kind, u32 TypeIndex, u16 Flags,
                //          name + null + pad. TypeIndex resolution:
                //   primitive  → built-in CV index
                //   void*      → T_PVOID
                //   struct     → struct_indices[extra]
                //   composite  → typemap lookup (pre-built by build_tpi_body)
                //   otherwise  → T_NOTYPE (name/offset still display)
                let is i32 as lcv with mut = 0;
                if (tk >= 0 && tk <= 13) { lcv = _prim_to_cv(tk); }
                else if (tk == 400) { lcv = 1539; }
                else if (tk == 300) {
                    if (te >= 0 && te < num_structs) { lcv = struct_indices[te]; }
                } else {
                    let is i64 as tk_key = (cast(i64, tk) * 4294967296) + cast(i64, te);
                    let is i32 as found = _typemap_find(typemap_keys, typemap_count, tk_key);
                    if (found >= 0) { lcv = typemap_vals[found]; }
                }
                let is i64 as local_sym = _start_sym(out_buf, S_LOCAL);
                reader.buf_emit32_le(out_buf, cast(i64, lcv));
                reader.buf_emit16_le(out_buf, 0);              // flags (0 = local var)
                let is i32 as lni with mut = 0;
                while (lni < cast(i32, lnl)) {
                    reader.buf_emit8(out_buf, cast(i32, lname[lni]));
                    lni = lni + 1;
                }
                reader.buf_emit8(out_buf, 0);
                _patch_sym_size(out_buf, local_sym);

                // S_DEFRANGE_FRAMEPOINTER_REL: u16 RecLen, u16 Kind,
                //   u32 OffsetFP (i32 = -var_offset),
                //   u32 OffsetStart, u16 ISectStart, u16 Range.
                // Range is u16 — clamp giant function bodies so the field
                // doesn't wrap to a small value and tell the debugger the
                // local stops being visible early.
                let is i64 as def_sym = _start_sym(out_buf, S_DEFRANGE_FPR);
                let is i64 as neg_off = 0 - voff;
                let is i64 as range_val with mut = fn_size;
                if (range_val > 65535) { range_val = 65535; }
                reader.buf_emit32_le(out_buf, neg_off);
                reader.buf_emit32_le(out_buf, fn_off);          // section-rel start
                reader.buf_emit16_le(out_buf, 1);               // .text segment
                reader.buf_emit16_le(out_buf, range_val);
                _patch_sym_size(out_buf, def_sym);

                li2 = li2 + 1;
            }
        }

        // S_END
        let is i64 as end_sym = _start_sym(out_buf, S_END);
        _patch_sym_size(out_buf, end_sym);

        fi = fi + 1;
    }
    // End of raw symbol records — anything from here is C13 line info.
    *out_sym_size = cast(i32, out_buf.len);

    // 3b. LINES subsection per function. .cstdebug uses obj-text frame
    //     (offset 0 = start of obj's .text); gsym vaddrs use section frame
    //     (text_section_va + STUB_SIZE shift). Match in obj-text frame.
    fi = 0;
    while (fi < func_count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, idx_arr[fi]);
        let is i64 as fn_section_off = g.vaddr - text_section_va;
        let is i64 as fn_obj_off = g.vaddr - ls.text_vaddr;       // may be < 0 for stub fns
        let is i64 as fn_obj_end with mut = cast(i64, ls.text_size);
        if (fi + 1 < func_count) {
            let is *linker.GlobalSym as ng = linker.gsym_get(gsyms, idx_arr[fi + 1]);
            fn_obj_end = ng.vaddr - ls.text_vaddr;
        }
        let is i64 as fn_size = fn_obj_end - fn_obj_off;

        // Count lines in [fn_obj_off, fn_obj_end). Linker-emitted helpers
        // (e.g. __caustic_chkstk) sit at negative obj offsets so the
        // window excludes them — no .cstdebug entries map there.
        let is *i32 as line_idx = cast(*i32, om.opt_alloc(4096 * 4));
        let is i32 as line_count with mut = 0;
        let is i64 as li with mut = 0;
        while (li < num_locs) {
            let is i64 as e_off = cast(i64, merged_offsets[li]);
            if (e_off >= fn_obj_off && e_off < fn_obj_end && line_count < 4096) {
                line_idx[line_count] = cast(i32, li);
                line_count = line_count + 1;
            }
            li = li + 1;
        }
        if (line_count == 0) { fi = fi + 1; continue; }

        let is i64 as ln_sub = _start_subsec(out_buf, DEBUG_S_LINES);
        reader.buf_emit32_le(out_buf, fn_section_off); // offCon
        reader.buf_emit16_le(out_buf, 1);             // segCon = .text
        reader.buf_emit16_le(out_buf, 0);             // flags
        reader.buf_emit32_le(out_buf, fn_size);       // cbCon
        reader.buf_emit32_le(out_buf, 0);             // offFile (always 0 — single file)
        reader.buf_emit32_le(out_buf, cast(i64, line_count));
        reader.buf_emit32_le(out_buf, cast(i64, 12 + line_count * 8));    // cbBlock
        let is i32 as lj with mut = 0;
        while (lj < line_count) {
            let is i64 as src_idx = cast(i64, line_idx[lj]);
            let is i64 as e_off  = cast(i64, merged_offsets[src_idx]);
            let is i64 as e_line = cast(i64, merged_lines[src_idx]);
            // offset relative to function start (merged-text frame minus
            // function's start offset in the same frame).
            reader.buf_emit32_le(out_buf, e_off - fn_obj_off);
            // flags = line | (1 << 31) (statement bit)
            reader.buf_emit32_le(out_buf, (e_line & 16777215) + 2147483648);
            lj = lj + 1;
        }
        _patch_subsec_size(out_buf, ln_sub);

        fi = fi + 1;
    }

    // 3c. STRINGTABLE — single empty initial string followed by source path.
    let is i64 as str_sub = _start_subsec(out_buf, DEBUG_S_STRINGTABLE);
    reader.buf_emit8(out_buf, 0);                     // empty string at offset 0
    let is i32 as ssi with mut = 0;
    while (ssi < *out_source_len) {
        reader.buf_emit8(out_buf, cast(i32, (*out_source)[ssi]));
        ssi = ssi + 1;
    }
    reader.buf_emit8(out_buf, 0);
    _patch_subsec_size(out_buf, str_sub);

    // 3d. FILECHKSMS — one entry pointing at the source string (offset 1).
    let is i64 as chk_sub = _start_subsec(out_buf, DEBUG_S_FILECHKSMS);
    reader.buf_emit32_le(out_buf, 1);                 // offset into strtab
    reader.buf_emit8(out_buf, 0);                     // cbChecksum
    reader.buf_emit8(out_buf, 0);                     // checksumKind = None
    reader.buf_emit16_le(out_buf, 0);                 // pad
    _patch_subsec_size(out_buf, chk_sub);

    // Capture C13 byte size before the trailing GlobalRefsSize sentinel.
    *out_c13_size = cast(i32, out_buf.len - cast(i64, *out_sym_size));

    // GlobalRefsSize sentinel — 0 means no global refs follow.
    reader.buf_emit32_le(out_buf, 0);

    return cast(i32, out_buf.len);
}

// Locate .cstlocals section in an obj. Per-function records of:
//   u32 name_len, byte[name_len] name, u32 num_locals,
//   per local: u32 name_len, byte[name_len] name, u32 var_offset,
//              u32 type_kind, u32 type_extra
fn _find_cstlocals(obj as *reader.ObjFile) as *reader.ObjSection {
    let is *i64 as names = cast(*i64, obj.csec_names);
    let is *i32 as nlens = cast(*i32, obj.csec_name_lens);
    let is i32 as i with mut = 0;
    while (i < obj.csec_count) {
        let is *u8 as nm = cast(*u8, names[i]);
        if (nlens[i] == 10 && reader.streq(nm, 10, ".cstlocals", 10) == 1) {
            return cast(*reader.ObjSection,
                cast(i64, obj.csec_data) + cast(i64, i) * sizeof(reader.ObjSection));
        }
        i = i + 1;
    }
    return cast(*reader.ObjSection, 0);
}

// Find a function's locals in any obj's .cstlocals. Returns 1 on hit;
// out_section is set to the section, out_record_off to the start of the
// function's record (just past name+name_len), so the caller can read
// num_locals and iterate.
fn _lookup_locals(ls as *linker.LinkerState, name as *u8, name_len as i32,
                  out_section as **reader.ObjSection, out_record_off as *i64) as i32 {
    let is i32 as oi with mut = 0;
    while (oi < ls.obj_count) {
        let is *reader.ObjFile as o = linker.get_obj(ls, oi);
        let is *reader.ObjSection as ss = _find_cstlocals(o);
        if (cast(i64, ss) != 0 && ss.size > 0) {
            let is *u8 as p = ss.data;
            let is i64 as off with mut = 0;
            while (off + 8 <= ss.size) {
                let is i64 as nl = _read_u32_at(p, off);
                if (off + 4 + nl + 4 > ss.size) { off = ss.size; continue; }
                let is i64 as nl_off = off + 4;
                let is i64 as num_locals_off = nl_off + nl;
                let is i64 as num_locals = _read_u32_at(p, num_locals_off);

                // Compute end of this function's record (locals are variable-
                // length: 4+namelen + 12 each). A malformed lnl could overflow
                // ss.size — guard the advance so we never read past the
                // section boundary.
                let is i64 as li with mut = 0;
                let is i64 as cur with mut = num_locals_off + 4;
                while (li < num_locals && cur + 4 <= ss.size) {
                    let is i64 as lnl = _read_u32_at(p, cur);
                    if (cur + 4 + lnl + 12 > ss.size) { cur = ss.size; li = num_locals; continue; }
                    cur = cur + 4 + lnl + 12;
                    li = li + 1;
                }

                if (cast(i32, nl) == name_len) {
                    let is i32 as k with mut = 0;
                    let is i32 as eq with mut = 1;
                    while (k < name_len) {
                        let is *u8 as np = cast(*u8, cast(i64, p) + nl_off + cast(i64, k));
                        if (*np != name[k]) { eq = 0; k = name_len; }
                        k = k + 1;
                    }
                    if (eq == 1) {
                        *out_section = ss;
                        *out_record_off = num_locals_off;
                        return 1;
                    }
                }
                off = cur;
            }
        }
        oi = oi + 1;
    }
    return 0;
}

// Locate .cststructs section in an obj. Format documented in
// src/codegen/emit_driver.cst:emit_cststructs.
fn _find_cststructs(obj as *reader.ObjFile) as *reader.ObjSection {
    let is *i64 as names = cast(*i64, obj.csec_names);
    let is *i32 as nlens = cast(*i32, obj.csec_name_lens);
    let is i32 as i with mut = 0;
    while (i < obj.csec_count) {
        let is *u8 as nm = cast(*u8, names[i]);
        if (nlens[i] == 11 && reader.streq(nm, 11, ".cststructs", 11) == 1) {
            return cast(*reader.ObjSection,
                cast(i64, obj.csec_data) + cast(i64, i) * sizeof(reader.ObjSection));
        }
        i = i + 1;
    }
    return cast(*reader.ObjSection, 0);
}

// Emit LF_NUMERIC-encoded unsigned size. For values < 0x8000 just a u16;
// otherwise LF_ULONG (0x8004) + u32. Returns bytes written.
fn _emit_lf_numeric(out_buf as *reader.ByteBuffer, value as i32) as i32 {
    if (value >= 0 && value < 32768) {
        reader.buf_emit16_le(out_buf, cast(i64, value));
        return 2;
    }
    reader.buf_emit16_le(out_buf, 32772);                    // LF_ULONG
    reader.buf_emit32_le(out_buf, cast(i64, value));
    return 6;
}

// Read .cststructs from the first obj that has one, emit LF_FIELDLIST +
// LF_STRUCTURE per struct, fill struct_indices[struct_idx] → CV TPI index.
// next_index is bumped for each record. Returns the number of structs
// emitted (0 if no .cststructs section is present).
//
// Each struct emission is: first the LF_FIELDLIST (so its index is known
// before the LF_STRUCTURE that references it), then the LF_STRUCTURE.
fn build_struct_records(ls as *linker.LinkerState,
                        out_buf as *reader.ByteBuffer, next_index as *i32,
                        struct_indices as *i32) as i32 {
    let is i32 as oi with mut = 0;
    let is i32 as total_structs with mut = 0;
    while (oi < ls.obj_count) {
        let is *reader.ObjFile as o = linker.get_obj(ls, oi);
        let is *reader.ObjSection as ss = _find_cststructs(o);
        if (cast(i64, ss) != 0 && ss.size > 0) {
            let is *u8 as p = ss.data;
            let is i64 as off with mut = 0;
            while (off + 12 <= ss.size) {
                // Read struct name
                let is i64 as nl = _read_u32_at(p, off);
                off = off + 4;
                let is *u8 as sname = cast(*u8, cast(i64, p) + off);
                off = off + nl;
                let is i64 as size_bytes = _read_u32_at(p, off);
                off = off + 4;
                let is i64 as num_fields = _read_u32_at(p, off);
                off = off + 4;

                // Pass 1: read fields into a small array (name, offset, kind, extra)
                let is *i64 as f_names  = cast(*i64, om.opt_alloc(64 * 8));
                let is *i32 as f_nlens  = cast(*i32, om.opt_alloc(64 * 4));
                let is *i32 as f_offs   = cast(*i32, om.opt_alloc(64 * 4));
                let is *i32 as f_kinds  = cast(*i32, om.opt_alloc(64 * 4));
                let is *i32 as f_extras = cast(*i32, om.opt_alloc(64 * 4));
                let is i32 as fi with mut = 0;
                while (fi < cast(i32, num_fields) && fi < 64) {
                    let is i64 as fnl = _read_u32_at(p, off);
                    off = off + 4;
                    f_names[fi] = cast(i64, p) + off;
                    f_nlens[fi] = cast(i32, fnl);
                    off = off + fnl;
                    f_offs[fi]   = cast(i32, _read_u32_at(p, off));      off = off + 4;
                    f_kinds[fi]  = cast(i32, _read_u32_at(p, off));      off = off + 4;
                    f_extras[fi] = cast(i32, _read_u32_at(p, off));      off = off + 4;
                    fi = fi + 1;
                }

                // Emit LF_FIELDLIST: u16 RecLen, u16 Kind = 0x1203,
                // then per-member: u16 Kind=0x150D, u16 Attr=3, u32 Type,
                // LF_NUMERIC offset, name+null, pad.
                let is i32 as fl_start = cast(i32, out_buf.len);
                reader.buf_emit16_le(out_buf, 0);                        // RecLen placeholder
                reader.buf_emit16_le(out_buf, cast(i64, LF_FIELDLIST));
                fi = 0;
                while (fi < cast(i32, num_fields) && fi < 64) {
                    reader.buf_emit16_le(out_buf, cast(i64, LF_MEMBER));
                    reader.buf_emit16_le(out_buf, 3);                    // public
                    // Field type: resolve primitive/pointer/array; nested struct → T_NOTYPE
                    let is i32 as ft with mut = 0;
                    if (f_kinds[fi] >= 0 && f_kinds[fi] <= 13) {
                        ft = _prim_to_cv(f_kinds[fi]);
                    } else if (f_kinds[fi] >= 100 && f_kinds[fi] <= 113) {
                        ft = _resolve_type(f_kinds[fi], f_extras[fi], out_buf, next_index, struct_indices, total_structs);
                    } else if (f_kinds[fi] >= 200 && f_kinds[fi] <= 213) {
                        ft = _resolve_type(f_kinds[fi], f_extras[fi], out_buf, next_index, struct_indices, total_structs);
                    } else if (f_kinds[fi] == 300) {
                        // Nested struct — must reference an already-emitted index.
                        if (f_extras[fi] >= 0 && f_extras[fi] < total_structs) {
                            ft = struct_indices[f_extras[fi]];
                        }
                    } else if (f_kinds[fi] == 400) {
                        ft = 1539;                                       // T_PVOID
                    }
                    reader.buf_emit32_le(out_buf, cast(i64, ft));
                    _emit_lf_numeric(out_buf, f_offs[fi]);
                    let is i32 as ni with mut = 0;
                    let is *u8 as fnp = cast(*u8, f_names[fi]);
                    while (ni < f_nlens[fi]) {
                        reader.buf_emit8(out_buf, cast(i32, fnp[ni]));
                        ni = ni + 1;
                    }
                    reader.buf_emit8(out_buf, 0);
                    let is i32 as pad with mut = 241;
                    while ((cast(i32, out_buf.len) & 3) != 0) {
                        reader.buf_emit8(out_buf, pad);
                        pad = pad + 1;
                    }
                    fi = fi + 1;
                }
                // Patch LF_FIELDLIST RecLen
                let is i32 as fl_end = cast(i32, out_buf.len);
                let is *u8 as bufd = out_buf.data;
                let is i32 as fl_rec_len = fl_end - fl_start - 2;
                bufd[fl_start]     = cast(u8, fl_rec_len & 255);
                bufd[fl_start + 1] = cast(u8, (fl_rec_len >> 8) & 255);
                let is i32 as fieldlist_idx = *next_index;
                *next_index = fieldlist_idx + 1;

                // Emit LF_STRUCTURE: u16 RecLen, u16 Kind, u16 Count, u16 Property=0,
                // u32 FieldList, u32 DerivedFrom=0, u32 VShape=0, LF_NUMERIC Size,
                // name+null, pad.
                let is i32 as st_start = cast(i32, out_buf.len);
                reader.buf_emit16_le(out_buf, 0);                        // RecLen placeholder
                reader.buf_emit16_le(out_buf, cast(i64, LF_STRUCTURE));
                reader.buf_emit16_le(out_buf, num_fields);               // Count
                reader.buf_emit16_le(out_buf, 0);                        // Property
                reader.buf_emit32_le(out_buf, cast(i64, fieldlist_idx));
                reader.buf_emit32_le(out_buf, 0);                        // DerivedFrom
                reader.buf_emit32_le(out_buf, 0);                        // VShape
                _emit_lf_numeric(out_buf, cast(i32, size_bytes));
                let is i32 as sni with mut = 0;
                while (sni < cast(i32, nl)) {
                    reader.buf_emit8(out_buf, cast(i32, sname[sni]));
                    sni = sni + 1;
                }
                reader.buf_emit8(out_buf, 0);
                let is i32 as spad with mut = 241;
                while ((cast(i32, out_buf.len) & 3) != 0) {
                    reader.buf_emit8(out_buf, spad);
                    spad = spad + 1;
                }
                let is i32 as st_end = cast(i32, out_buf.len);
                let is i32 as st_rec_len = st_end - st_start - 2;
                bufd[st_start]     = cast(u8, st_rec_len & 255);
                bufd[st_start + 1] = cast(u8, (st_rec_len >> 8) & 255);

                struct_indices[total_structs] = *next_index;
                *next_index = *next_index + 1;
                total_structs = total_structs + 1;
            }
        }
        oi = oi + 1;
    }
    return total_structs;
}

// Locate .cstsigs section in an obj. Format: per-function records of
//   u32 name_len, byte[name_len] name, u32 return_type, u32 num_args
// Records run back-to-back until end of section; no padding.
fn _find_cstsigs(obj as *reader.ObjFile) as *reader.ObjSection {
    let is *i64 as names = cast(*i64, obj.csec_names);
    let is *i32 as nlens = cast(*i32, obj.csec_name_lens);
    let is i32 as i with mut = 0;
    while (i < obj.csec_count) {
        let is *u8 as nm = cast(*u8, names[i]);
        if (nlens[i] == 8 && reader.streq(nm, 8, ".cstsigs", 8) == 1) {
            return cast(*reader.ObjSection,
                cast(i64, obj.csec_data) + cast(i64, i) * sizeof(reader.ObjSection));
        }
        i = i + 1;
    }
    return cast(*reader.ObjSection, 0);
}

// Find a function's signature in any obj's .cstsigs. Linear scan; N is
// small. .cstsigs v2 per-function record:
//   u32 name_len, byte[name_len] name, u32 num_args,
//   (u32 kind, u32 extra)[1 + num_args]   ; ret first, then args
//
// On hit: fills *out_num_args; copies (1 + num_args) (kind, extra) pairs
// into the caller's out_pairs buffer (size = 2 * (1 + num_args) i32s).
fn _lookup_sig(ls as *linker.LinkerState, name as *u8, name_len as i32,
               out_num_args as *i32, out_pairs as *i32) as i32 {
    let is i32 as oi with mut = 0;
    while (oi < ls.obj_count) {
        let is *reader.ObjFile as o = linker.get_obj(ls, oi);
        let is *reader.ObjSection as ss = _find_cstsigs(o);
        if (cast(i64, ss) != 0 && ss.size > 0) {
            let is *u8 as p = ss.data;
            let is i64 as off with mut = 0;
            while (off + 8 <= ss.size) {
                let is i64 as nl = _read_u32_at(p, off);
                if (off + 4 + nl + 4 > ss.size) { off = ss.size; continue; }
                let is i64 as na_off = off + 4 + nl;
                let is i64 as num_args = _read_u32_at(p, na_off);
                let is i64 as type_pairs_off = na_off + 4;
                let is i64 as record_end = type_pairs_off + (1 + num_args) * 8;
                if (record_end > ss.size) { off = ss.size; continue; }
                if (cast(i32, nl) == name_len) {
                    let is i32 as k with mut = 0;
                    let is i32 as eq with mut = 1;
                    while (k < name_len) {
                        let is *u8 as np = cast(*u8, cast(i64, p) + off + 4 + cast(i64, k));
                        if (*np != name[k]) { eq = 0; k = name_len; }
                        k = k + 1;
                    }
                    if (eq == 1) {
                        *out_num_args = cast(i32, num_args);
                        let is i32 as pi with mut = 0;
                        while (pi < cast(i32, 2 * (1 + num_args))) {
                            out_pairs[pi] = cast(i32,
                                _read_u32_at(p, type_pairs_off + cast(i64, pi) * 4));
                            pi = pi + 1;
                        }
                        return 1;
                    }
                }
                off = record_end;
            }
        }
        oi = oi + 1;
    }
    return 0;
}

// Map a primitive Caustic type kind (TY_*) to a CV built-in type index.
fn _prim_to_cv(kind as i32) as i32 {
    if (kind == 0)  { return 3; }       // void → T_VOID
    if (kind == 1)  { return 104; }     // i8 → T_INT1 (0x68)
    if (kind == 2)  { return 17; }      // i16 → T_SHORT
    if (kind == 3)  { return 116; }     // i32 → T_INT4 (0x74)
    if (kind == 4)  { return 19; }      // i64 → T_QUAD
    if (kind == 5)  { return 32; }      // u8 → T_UCHAR
    if (kind == 6)  { return 33; }      // u16 → T_USHORT
    if (kind == 7)  { return 117; }     // u32 → T_UINT4 (0x75)
    if (kind == 8)  { return 35; }      // u64 → T_UQUAD
    if (kind == 9)  { return 64; }      // f32 → T_REAL32
    if (kind == 10) { return 65; }      // f64 → T_REAL64
    if (kind == 11) { return 48; }      // bool → T_BOOL08
    if (kind == 12) { return 112; }     // char → T_RCHAR
    if (kind == 13) { return 1568; }    // string → T_PUCHAR (0x620)
    return 116;                         // fallback T_INT4
}

// Resolve a (kind, extra) type pair to a CV type index. May emit LF_POINTER
// or LF_ARRAY records into out_buf, in which case *next_index is bumped.
//   kind 0..13     primitive
//   kind 100..113  pointer-to-primitive (kind - 100)
//   kind 200..213  array-of-primitive  (kind - 200), element count in extra
//   kind 300       struct (T_NOTYPE fallback for now — E adds real records)
//   kind 400       function pointer → T_PVOID
fn _resolve_type(kind as i32, extra as i32,
                 out_buf as *reader.ByteBuffer, next_index as *i32,
                 struct_indices as *i32, num_structs as i32) as i32 {
    if (kind >= 0 && kind <= 13) {
        return _prim_to_cv(kind);
    }
    if (kind == 400) { return 1539; }   // T_PVOID = 0x603
    if (kind == 300) {
        if (extra >= 0 && extra < num_structs) { return struct_indices[extra]; }
        return 0;                        // T_NOTYPE fallback
    }
    if (kind == 500) {
        // Pointer-to-struct: emit LF_POINTER referencing the struct's index.
        let is i32 as struct_cv with mut = 0;
        if (extra >= 0 && extra < num_structs) { struct_cv = struct_indices[extra]; }
        reader.buf_emit16_le(out_buf, 10);
        reader.buf_emit16_le(out_buf, cast(i64, LF_POINTER));
        reader.buf_emit32_le(out_buf, cast(i64, struct_cv));
        reader.buf_emit32_le(out_buf, cast(i64, CV_PTR_ATTR_NEAR64));
        let is i32 as idx = *next_index;
        *next_index = idx + 1;
        return idx;
    }
    if (kind >= 100 && kind <= 113) {
        // LF_POINTER to primitive
        let is i32 as inner = _prim_to_cv(kind - 100);
        reader.buf_emit16_le(out_buf, 10);                  // RecLen value
        reader.buf_emit16_le(out_buf, cast(i64, LF_POINTER));
        reader.buf_emit32_le(out_buf, cast(i64, inner));
        reader.buf_emit32_le(out_buf, cast(i64, CV_PTR_ATTR_NEAR64));
        let is i32 as idx = *next_index;
        *next_index = idx + 1;
        return idx;
    }
    if (kind >= 200 && kind <= 213) {
        // LF_ARRAY of primitive — Size field stores TOTAL bytes (count *
        // element_size). For small sizes (<0x8000) the LF_NUMERIC encoding
        // is just a raw u16. Element size table mirrors _prim_to_cv but in
        // bytes.
        let is i32 as prim = kind - 200;
        let is i32 as elem_cv = _prim_to_cv(prim);
        let is i32 as elem_size with mut = 4;
        if (prim == 0)  { elem_size = 0; }
        else if (prim == 1)  { elem_size = 1; }
        else if (prim == 2)  { elem_size = 2; }
        else if (prim == 3)  { elem_size = 4; }
        else if (prim == 4)  { elem_size = 8; }
        else if (prim == 5)  { elem_size = 1; }
        else if (prim == 6)  { elem_size = 2; }
        else if (prim == 7)  { elem_size = 4; }
        else if (prim == 8)  { elem_size = 8; }
        else if (prim == 9)  { elem_size = 4; }
        else if (prim == 10) { elem_size = 8; }
        else if (prim == 11) { elem_size = 1; }
        else if (prim == 12) { elem_size = 1; }
        else if (prim == 13) { elem_size = 8; }
        let is i32 as total_bytes = elem_size * extra;
        // Numeric encoding: if total_bytes < 0x8000 raw u16, else need long form
        let is i32 as size_field_bytes with mut = 2;
        if (total_bytes >= 32768) { size_field_bytes = 6; }       // LF_ULONG (0x8004) + u32

        // LF_ARRAY layout:
        //   u16 RecLen, u16 Kind, u32 ElementType, u32 IndexType,
        //   <size field>, u8 0 (empty name), pad to 4.
        let is i32 as payload = 11 + size_field_bytes;             // Kind(2)+Elem(4)+Idx(4)+size+name(1)
        let is i32 as total with mut = 2 + payload;                  // includes RecLen
        while ((total & 3) != 0) { total = total + 1; }
        reader.buf_emit16_le(out_buf, cast(i64, total - 2));
        reader.buf_emit16_le(out_buf, cast(i64, LF_ARRAY));
        reader.buf_emit32_le(out_buf, cast(i64, elem_cv));
        reader.buf_emit32_le(out_buf, 117);                          // IndexType = T_UINT4
        if (size_field_bytes == 2) {
            reader.buf_emit16_le(out_buf, cast(i64, total_bytes));
        } else {
            reader.buf_emit16_le(out_buf, 32772);                    // LF_ULONG = 0x8004
            reader.buf_emit32_le(out_buf, cast(i64, total_bytes));
        }
        reader.buf_emit8(out_buf, 0);                                // empty name
        while ((cast(i32, out_buf.len) & 3) != 0) { reader.buf_emit8(out_buf, 0); }
        let is i32 as idx = *next_index;
        *next_index = idx + 1;
        return idx;
    }
    return 0;   // T_NOTYPE fallback
}

// Build TPI body. For each defined TEXT-section gsym (VA-sorted), resolve
// return + arg types (may emit LF_POINTER / LF_ARRAY), then emit one
// LF_ARGLIST + LF_PROCEDURE per function. proc_indices[i] receives the CV
// TPI index of function i's LF_PROCEDURE so build_ipi_body's LF_FUNC_ID can
// reference it. Returns the count of records written (used by the TPI
// header's TypeIndexEnd field).
// Memoization map for composite-type CV indices. Keys are packed
// (kind << 32) | extra; values are the assigned TPI index. Built during
// build_tpi_body and consulted by S_LOCAL emission in build_module_stream
// so locals reference real LF_POINTER/LF_ARRAY records (rather than the
// T_NOTYPE fallback that was visible to the debugger before).
fn _typemap_find(keys as *i64, count as i32, key as i64) as i32 {
    let is i32 as i with mut = 0;
    while (i < count) {
        if (keys[i] == key) { return i; }
        i = i + 1;
    }
    let is i32 as neg with mut = 0;
    neg = neg - 1;
    return neg;
}

fn build_tpi_body(ls as *linker.LinkerState, out_buf as *reader.ByteBuffer,
                  proc_indices as *i32,
                  out_struct_indices as **i32, out_num_structs as *i32,
                  out_typemap_keys as **i64, out_typemap_vals as **i32,
                  out_typemap_count as *i32) as i32 {
    let is *linker.GlobalSymTab as gsyms = linker.get_gsyms(ls);
    let is *i32 as idx_arr = cast(*i32, om.opt_alloc(1024 * 4));
    let is *i64 as va_arr  = cast(*i64, om.opt_alloc(1024 * 8));
    let is i32 as fcount with mut = 0;
    let is i32 as gi with mut = 0;
    while (gi < gsyms.count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, gi);
        if (g.defined == 1 && g.section == reader.SECIDX_TEXT && fcount < 1024) {
            idx_arr[fcount] = gi;
            va_arr[fcount] = g.vaddr;
            fcount = fcount + 1;
        }
        gi = gi + 1;
    }
    _sort_indices(idx_arr, va_arr, fcount);

    let is i32 as next_index with mut = TYPE_INDEX_BEGIN_LINKER;

    // Emit struct records first so function signatures can reference them
    // by index. struct_indices[struct_idx] → CV TPI index.
    let is *i32 as struct_indices = cast(*i32, om.opt_alloc(256 * 4));
    let is i32 as num_structs = build_struct_records(ls, out_buf, &next_index, struct_indices);

    let is *i32 as arg_cv = cast(*i32, om.opt_alloc(64 * 4));   // up to 16 args
    let is *i32 as pairs  = cast(*i32, om.opt_alloc(64 * 4));   // (kind,extra)*17

    let is i32 as fi with mut = 0;
    while (fi < fcount) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, idx_arr[fi]);
        let is i32 as num_args with mut = 0;
        let is i32 as found = _lookup_sig(ls, g.name, g.name_len, &num_args, pairs);

        // Resolve return type (pair index 0) and each arg (pairs 1..1+num_args).
        // Missing .cstsigs entry (linker-emitted helper) → void return, 0 args.
        let is i32 as ret_cv with mut = 3;     // T_VOID default
        if (found == 1) {
            ret_cv = _resolve_type(pairs[0], pairs[1], out_buf, &next_index, struct_indices, num_structs);
        }
        let is i32 as ai with mut = 0;
        while (ai < num_args) {
            let is i32 as kpos = 2 * (1 + ai);
            arg_cv[ai] = _resolve_type(pairs[kpos], pairs[kpos + 1], out_buf, &next_index, struct_indices, num_structs);
            ai = ai + 1;
        }

        // LF_ARGLIST: u32 numArgs + numArgs * u32 arg CV indices
        let is i32 as arglist_raw = 8 + 4 * num_args;
        let is i32 as arglist_total with mut = arglist_raw;
        while ((arglist_total & 3) != 0) { arglist_total = arglist_total + 1; }
        reader.buf_emit16_le(out_buf, cast(i64, arglist_total - 2));
        reader.buf_emit16_le(out_buf, cast(i64, LF_ARGLIST));
        reader.buf_emit32_le(out_buf, cast(i64, num_args));
        ai = 0;
        while (ai < num_args) {
            reader.buf_emit32_le(out_buf, cast(i64, arg_cv[ai]));
            ai = ai + 1;
        }
        while ((cast(i32, out_buf.len) & 3) != 0) { reader.buf_emit8(out_buf, 0); }
        let is i32 as arglist_idx = next_index;
        next_index = next_index + 1;

        // LF_PROCEDURE
        reader.buf_emit16_le(out_buf, 14);
        reader.buf_emit16_le(out_buf, cast(i64, LF_PROCEDURE));
        reader.buf_emit32_le(out_buf, cast(i64, ret_cv));
        reader.buf_emit8(out_buf, 0);                   // CallConv NEAR_C
        reader.buf_emit8(out_buf, 0);                   // FuncAttr
        reader.buf_emit16_le(out_buf, cast(i64, num_args));
        reader.buf_emit32_le(out_buf, cast(i64, arglist_idx));
        let is i32 as proc_idx = next_index;
        next_index = next_index + 1;

        proc_indices[fi] = proc_idx;
        fi = fi + 1;
    }

    // Pre-scan .cstlocals across all objs so S_LOCAL records can reference
    // real CV types instead of T_NOTYPE. For each unique composite (kind,
    // extra) pair seen in locals, emit the matching LF_POINTER/LF_ARRAY and
    // memoize the assigned CV index. Primitive and struct types resolve
    // without emission and aren't cached.
    let is *i64 as tm_keys = cast(*i64, om.opt_alloc(512 * 8));
    let is *i32 as tm_vals = cast(*i32, om.opt_alloc(512 * 4));
    let is i32 as tm_count with mut = 0;
    let is i32 as oi2 with mut = 0;
    while (oi2 < ls.obj_count) {
        let is *reader.ObjFile as o = linker.get_obj(ls, oi2);
        let is *reader.ObjSection as ls_sec = _find_cstlocals(o);
        if (cast(i64, ls_sec) != 0 && ls_sec.size > 0) {
            let is *u8 as lp = ls_sec.data;
            let is i64 as off with mut = 0;
            while (off + 4 <= ls_sec.size) {
                let is i64 as fnl = _read_u32_at(lp, off);
                if (off + 4 + fnl + 4 > ls_sec.size) { off = ls_sec.size; continue; }
                off = off + 4 + fnl;
                let is i64 as nlc = _read_u32_at(lp, off);
                off = off + 4;
                let is i64 as lj with mut = 0;
                while (lj < nlc) {
                    let is i64 as lnl = _read_u32_at(lp, off);
                    if (off + 4 + lnl + 12 > ls_sec.size) { lj = nlc; off = ls_sec.size; continue; }
                    off = off + 4 + lnl + 4;                       // skip name + var_offset
                    let is i32 as tk = cast(i32, _read_u32_at(lp, off)); off = off + 4;
                    let is i32 as te = cast(i32, _read_u32_at(lp, off)); off = off + 4;
                    let is i32 as needs_emit with mut = 0;
                    if (tk >= 100 && tk <= 113) { needs_emit = 1; }
                    else if (tk >= 200 && tk <= 213) { needs_emit = 1; }
                    else if (tk == 500) { needs_emit = 1; }
                    if (needs_emit == 1 && tm_count < 512) {
                        let is i64 as key = (cast(i64, tk) * 4294967296) + cast(i64, te);
                        if (_typemap_find(tm_keys, tm_count, key) < 0) {
                            let is i32 as cv = _resolve_type(tk, te, out_buf, &next_index,
                                                             struct_indices, num_structs);
                            tm_keys[tm_count] = key;
                            tm_vals[tm_count] = cv;
                            tm_count = tm_count + 1;
                        }
                    }
                    lj = lj + 1;
                }
            }
        }
        oi2 = oi2 + 1;
    }

    *out_struct_indices = struct_indices;
    *out_num_structs = num_structs;
    *out_typemap_keys = tm_keys;
    *out_typemap_vals = tm_vals;
    *out_typemap_count = tm_count;
    return next_index - TYPE_INDEX_BEGIN_LINKER;
}

// Emit one LF_STRING_ID record. Returns nothing — record always advances
// out_buf.len; callers track index assignment positionally.
fn _emit_lf_string_id(out_buf as *reader.ByteBuffer, s as *u8, slen as i32) as void {
    // Layout: u16 RecLen, u16 Kind, u32 ParentId=0, string name+null, pad.
    // Raw size before pad: 2 + 2 + 4 + slen + 1 = 9 + slen. RecLen value =
    // total - 2 in post-pad form.
    let is i32 as raw = 9 + slen;
    let is i32 as total with mut = raw;
    while ((total & 3) != 0) { total = total + 1; }
    reader.buf_emit16_le(out_buf, cast(i64, total - 2));
    reader.buf_emit16_le(out_buf, cast(i64, LF_STRING_ID));
    reader.buf_emit32_le(out_buf, 0);                              // ParentId
    let is i32 as i with mut = 0;
    while (i < slen) {
        reader.buf_emit8(out_buf, cast(i32, s[i]));
        i = i + 1;
    }
    reader.buf_emit8(out_buf, 0);
    let is i32 as pad with mut = 241;
    while ((cast(i32, out_buf.len) & 3) != 0) {
        reader.buf_emit8(out_buf, pad);
        pad = pad + 1;
    }
}

// Emit one LF_FUNC_ID per defined TEXT-section gsym, in VA-sorted order, so
// the i-th LF_FUNC_ID lives at IPI index IPI_INDEX_BEGIN+i — matching what
// the S_GPROC32_ID records in build_module_stream reference. Sorts gsyms
// independently of build_module_stream; both pipelines must produce the
// same order, so the sort key (vaddr) and predicate (defined && TEXT) are
// identical between them.
//
// After LF_FUNC_IDs, this also emits 5 LF_STRING_IDs followed by 1
// LF_BUILDINFO, in that fixed order. Final IPI layout (with N functions):
//   [0..N)            LF_FUNC_ID
//   [N..N+5)          LF_STRING_ID (cwd, tool, src, pdb, args)
//   N+5               LF_BUILDINFO
fn build_ipi_body(ls as *linker.LinkerState, out_buf as *reader.ByteBuffer,
                  src_path as *u8, src_path_len as i32,
                  pdb_path as *u8, pdb_path_len as i32,
                  proc_indices as *i32) as i32 {
    let is *linker.GlobalSymTab as gsyms = linker.get_gsyms(ls);
    let is *i32 as idx_arr = cast(*i32, om.opt_alloc(1024 * 4));
    let is *i64 as va_arr  = cast(*i64, om.opt_alloc(1024 * 8));
    let is i32 as fcount with mut = 0;
    let is i32 as gi with mut = 0;
    while (gi < gsyms.count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, gi);
        if (g.defined == 1 && g.section == reader.SECIDX_TEXT && fcount < 1024) {
            idx_arr[fcount] = gi;
            va_arr[fcount] = g.vaddr;
            fcount = fcount + 1;
        }
        gi = gi + 1;
    }
    _sort_indices(idx_arr, va_arr, fcount);

    let is i32 as fi with mut = 0;
    while (fi < fcount) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, idx_arr[fi]);
        // LF_FUNC_ID layout: u16 RecLen, u16 Kind, u32 scopeId, u32 typeId,
        //                    string name (null-term, padded with 0xF1/F2/F3).
        // typeId points at the per-function LF_PROCEDURE in TPI (2 type
        // indices per function: arglist at 2*i, procedure at 2*i+1).
        let is i32 as raw = 12 + g.name_len + 1;
        let is i32 as total with mut = raw;
        while ((total & 3) != 0) { total = total + 1; }
        let is i32 as proc_idx = proc_indices[fi];
        reader.buf_emit16_le(out_buf, cast(i64, total - 2));
        reader.buf_emit16_le(out_buf, cast(i64, LF_FUNC_ID));
        reader.buf_emit32_le(out_buf, 0);                              // scopeId
        reader.buf_emit32_le(out_buf, cast(i64, proc_idx));            // typeId
        let is i32 as ni with mut = 0;
        while (ni < g.name_len) {
            reader.buf_emit8(out_buf, cast(i32, g.name[ni]));
            ni = ni + 1;
        }
        reader.buf_emit8(out_buf, 0);
        let is i32 as pad with mut = 241;
        while ((cast(i32, out_buf.len) & 3) != 0) {
            reader.buf_emit8(out_buf, pad);
            pad = pad + 1;
        }
        fi = fi + 1;
    }

    // 5 LF_STRING_ID records — order is fixed by LF_BUILDINFO contract:
    //   0 CurrentDirectory, 1 BuildTool, 2 SourceFile, 3 Pdb, 4 Args.
    // We don't have getcwd or argv in the linker, so cwd/args are empty.
    let is *u8 as tool_name = "caustic";
    _emit_lf_string_id(out_buf, "", 0);                          // cwd
    _emit_lf_string_id(out_buf, tool_name, 7);                   // build tool
    _emit_lf_string_id(out_buf, src_path, src_path_len);         // source file
    _emit_lf_string_id(out_buf, pdb_path, pdb_path_len);         // pdb path
    _emit_lf_string_id(out_buf, "", 0);                          // command args

    // LF_BUILDINFO: u16 RecLen, u16 Kind, u16 NumArgs=5, u32[5] StringIds.
    // Raw = 2 + 2 + 2 + 5*4 = 26. Pad to 28. RecLen value = 26.
    let is i32 as bi_first = IPI_INDEX_BEGIN + fcount;
    reader.buf_emit16_le(out_buf, 26);
    reader.buf_emit16_le(out_buf, cast(i64, LF_BUILDINFO));
    reader.buf_emit16_le(out_buf, 5);                              // NumArgs
    reader.buf_emit32_le(out_buf, cast(i64, bi_first + 0));
    reader.buf_emit32_le(out_buf, cast(i64, bi_first + 1));
    reader.buf_emit32_le(out_buf, cast(i64, bi_first + 2));
    reader.buf_emit32_le(out_buf, cast(i64, bi_first + 3));
    reader.buf_emit32_le(out_buf, cast(i64, bi_first + 4));
    let is i32 as bipad with mut = 241;
    while ((cast(i32, out_buf.len) & 3) != 0) {
        reader.buf_emit8(out_buf, bipad);
        bipad = bipad + 1;
    }

    // Total IPI records: fcount LF_FUNC_IDs + 5 LF_STRING_IDs + 1 LF_BUILDINFO.
    return fcount + 6;
}

// Compute the IPI index where the LF_BUILDINFO will live, given the number of
// LF_FUNC_IDs (= text-section gsyms) that precede it. Used so build_module_stream
// can emit S_BUILDINFO with the right reference before build_ipi_body runs.
fn buildinfo_ipi_index(num_funcs as i32) as i32 {
    return IPI_INDEX_BEGIN + num_funcs + 5;
}

// Patch SizeOfData / AddressOfRawData / PointerToRawData in IMAGE_DEBUG_DIRECTORY
// now that rodata_rva and rodata_file are known.
fn _patch_debug_dir(rodata_buf as *reader.ByteBuffer,
                    dir_off as i64, rsds_off as i64,
                    rsds_size as i32,
                    rodata_rva as i64, rodata_file as i64) as void {
    let is *u8 as p = rodata_buf.data;
    // SizeOfData at dir_off + 16
    let is i64 as sz_off = dir_off + 16;
    p[sz_off]     = cast(u8, rsds_size & 255);
    p[sz_off + 1] = cast(u8, (rsds_size >> 8) & 255);
    p[sz_off + 2] = cast(u8, (rsds_size >> 16) & 255);
    p[sz_off + 3] = cast(u8, (rsds_size >> 24) & 255);
    // AddressOfRawData at dir_off + 20
    let is i64 as ar_off = dir_off + 20;
    let is i64 as rsds_rva = rodata_rva + rsds_off;
    p[ar_off]     = cast(u8, rsds_rva & 255);
    p[ar_off + 1] = cast(u8, (rsds_rva >> 8) & 255);
    p[ar_off + 2] = cast(u8, (rsds_rva >> 16) & 255);
    p[ar_off + 3] = cast(u8, (rsds_rva >> 24) & 255);
    // PointerToRawData at dir_off + 24
    let is i64 as pr_off = dir_off + 24;
    let is i64 as rsds_file = rodata_file + rsds_off;
    p[pr_off]     = cast(u8, rsds_file & 255);
    p[pr_off + 1] = cast(u8, (rsds_file >> 8) & 255);
    p[pr_off + 2] = cast(u8, (rsds_file >> 16) & 255);
    p[pr_off + 3] = cast(u8, (rsds_file >> 24) & 255);
}

// ====================================================================
// PE export directory (--shared → .dll). Appended to .rdata, like the
// debug directory; DataDirectory[0] points at it. Lets a DLL export its
// defined functions so another PE can import them (GetProcAddress).
// ====================================================================
let is *u8 as PE_DLL_NAME with imut = "caustic.dll";
let is i64 as PE_DLL_NAME_LEN with imut = 11;

fn _pe_name_lt(a as *u8, alen as i32, b as *u8, blen as i32) as i32 {
    let is i32 as n with mut = alen;
    if (blen < n) { n = blen; }
    let is i32 as i with mut = 0;
    while (i < n) {
        if (a[i] != b[i]) { if (a[i] < b[i]) { return 1; } return 0; }
        i = i + 1;
    }
    if (alen < blen) { return 1; }
    return 0;
}

fn _pe_patch_add(buf as *reader.ByteBuffer, off as i64, delta as i64) as void {
    let is *u8 as d = buf.data;
    let is i64 as v with mut = cast(i64, d[off]) + (cast(i64, d[off+1]) << 8) + (cast(i64, d[off+2]) << 16) + (cast(i64, d[off+3]) << 24);
    v = v + delta;
    d[off] = cast(u8, v & 255);
    d[off+1] = cast(u8, (v >> 8) & 255);
    d[off+2] = cast(u8, (v >> 16) & 255);
    d[off+3] = cast(u8, (v >> 24) & 255);
}

// Appends IMAGE_EXPORT_DIRECTORY + AddressOf{Functions,Names,NameOrdinals} +
// strings to rodata_buf. AddressOfFunctions holds final RVAs; the directory
// pointer fields and AddressOfNames entries are rodata-relative and fixed by
// _pe_patch_export_dir once rodata_rva is known.
fn build_pe_export_dir(ls as *linker.LinkerState, rodata_buf as *reader.ByteBuffer,
                       out_dir_off as *i64, out_n as *i32, out_names_off as *i64,
                       stub_size as i64) as void {
    let is *linker.GlobalSymTab as gsyms = linker.get_gsyms(ls);
    let is *i32 as idx = cast(*i32, om.opt_alloc(cast(i64, gsyms.count) * 4 + 4));
    let is i32 as n with mut = 0;
    let is i32 as gi with mut = 0;
    while (gi < gsyms.count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, gi);
        if (g.defined == 1 && g.name_len > 0 && g.section == 1) { idx[n] = gi; n = n + 1; }
        gi = gi + 1;
    }
    // selection sort by name — AddressOfNames must be sorted for GetProcAddress
    let is i32 as a with mut = 0;
    while (a < n) {
        let is i32 as mn with mut = a;
        let is i32 as b with mut = a + 1;
        while (b < n) {
            let is *linker.GlobalSym as gb = linker.gsym_get(gsyms, idx[b]);
            let is *linker.GlobalSym as gm = linker.gsym_get(gsyms, idx[mn]);
            if (_pe_name_lt(gb.name, gb.name_len, gm.name, gm.name_len) == 1) { mn = b; }
            b = b + 1;
        }
        let is i32 as t = idx[a]; idx[a] = idx[mn]; idx[mn] = t;
        a = a + 1;
    }
    *out_n = n;
    while ((cast(i64, rodata_buf.len) & 3) != 0) { reader.buf_emit8(rodata_buf, 0); }
    let is i64 as dir_off = cast(i64, rodata_buf.len);
    *out_dir_off = dir_off;
    let is i64 as funcs_off = dir_off + 40;
    let is i64 as names_off = funcs_off + cast(i64, n) * 4;
    let is i64 as ords_off  = names_off + cast(i64, n) * 4;
    let is i64 as strs_off  = ords_off + cast(i64, n) * 2;
    *out_names_off = names_off;

    reader.buf_emit32_le(rodata_buf, 0);              // Characteristics
    reader.buf_emit32_le(rodata_buf, 0);              // TimeDateStamp
    reader.buf_emit32_le(rodata_buf, 0);              // Major/Minor Version
    reader.buf_emit32_le(rodata_buf, strs_off);       // Name (→ dll name string)
    reader.buf_emit32_le(rodata_buf, 1);              // Base (ordinal)
    reader.buf_emit32_le(rodata_buf, cast(i64, n));   // NumberOfFunctions
    reader.buf_emit32_le(rodata_buf, cast(i64, n));   // NumberOfNames
    reader.buf_emit32_le(rodata_buf, funcs_off);      // AddressOfFunctions
    reader.buf_emit32_le(rodata_buf, names_off);      // AddressOfNames
    reader.buf_emit32_le(rodata_buf, ords_off);       // AddressOfNameOrdinals

    let is i32 as k with mut = 0;
    while (k < n) {                                   // AddressOfFunctions: absolute RVAs
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, idx[k]);
        // +stub_size: the PE writer prepends the entry stub to .text, shifting
        // every function by STUB_SIZE past the assign_addresses vaddr.
        reader.buf_emit32_le(rodata_buf, g.vaddr - ls.base_addr + stub_size);
        k = k + 1;
    }
    let is i64 as cur with mut = strs_off + PE_DLL_NAME_LEN + 1;
    k = 0;
    while (k < n) {                                   // AddressOfNames: rodata-rel string offsets
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, idx[k]);
        reader.buf_emit32_le(rodata_buf, cur);
        cur = cur + cast(i64, g.name_len) + 1;
        k = k + 1;
    }
    k = 0;
    while (k < n) { reader.buf_emit16_le(rodata_buf, k); k = k + 1; }   // ordinals = index
    reader.buf_append(rodata_buf, PE_DLL_NAME, PE_DLL_NAME_LEN);        // strings
    reader.buf_emit8(rodata_buf, 0);
    k = 0;
    while (k < n) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, idx[k]);
        reader.buf_append(rodata_buf, g.name, cast(i64, g.name_len));
        reader.buf_emit8(rodata_buf, 0);
        k = k + 1;
    }
}

fn _pe_patch_export_dir(rodata_buf as *reader.ByteBuffer, dir_off as i64, names_off as i64, n as i32, rodata_rva as i64) as void {
    _pe_patch_add(rodata_buf, dir_off + 12, rodata_rva);   // Name
    _pe_patch_add(rodata_buf, dir_off + 28, rodata_rva);   // AddressOfFunctions
    _pe_patch_add(rodata_buf, dir_off + 32, rodata_rva);   // AddressOfNames
    _pe_patch_add(rodata_buf, dir_off + 36, rodata_rva);   // AddressOfNameOrdinals
    let is i32 as k with mut = 0;
    while (k < n) { _pe_patch_add(rodata_buf, names_off + cast(i64, k) * 4, rodata_rva); k = k + 1; }
}

fn write_pe_executable(ls as *linker.LinkerState, output_path as *u8) as i32 {
    let is reader.ByteBuffer as out = reader.buf_init(65536);

    // The entry stub unconditionally calls ExitProcess (to terminate) and
    // GetCommandLineA (to feed __caustic_parse_argv). Synthesize the imports
    // if the user program didn't reference them so the IAT is always populated.
    if (_has_cstimport(ls, "GetCommandLineA", 15) == 0) {
        linker.add_cstimport(ls, "kernel32.dll", 12, "GetCommandLineA", 15);
    }
    if (_has_cstimport(ls, "ExitProcess", 11) == 0) {
        linker.add_cstimport(ls, "kernel32.dll", 12, "ExitProcess", 11);
    }

    // Sizes of the three pieces of code we prepend to .text. Declared up
    // front because build_reloc_blob (called below) needs TEXT_RVA +
    // STUB_SIZE to compute the final RVA of each text-section relocation,
    // and the SEH builder later derives the internal helpers' begin/end
    // RVAs from the same constants.
    let is i64 as ENTRY_STUB_SIZE = 47;
    let is i64 as CHKSTK_SIZE     = 57;
    let is i64 as PARSE_ARGV_SIZE = 228;
    let is i64 as STUB_SIZE       = ENTRY_STUB_SIZE + CHKSTK_SIZE + PARSE_ARGV_SIZE;

    // Compute headers footprint: PE+COFF (128+4+20) + OptHdr (240) + sections.
    // Aligned up to FILE_ALIGN. With 2 sections fits in 0x200; 3 sections
    // also fits exactly; 4 sections overflows, need 0x400.

    // 1. Compute section layout. Up to 4 sections: .text, .rdata (if rodata),
    //    .data (if data), .idata. Each at next SECTION_ALIGN boundary.
    let is *reader.ByteBuffer as rodata_buf = linker.get_rodata(ls);

    // CodeView debug entries land at the end of .rdata so DataDirectory[6]
    // can point inside an existing section. Appended BEFORE rodata_virt is
    // measured so the section header reflects the final size. RVA / file
    // offset fields are patched once the layout is resolved.
    let is i64 as debug_dir_off with mut = 0;
    let is i64 as debug_rsds_off with mut = 0;
    let is [16]u8 as debug_guid;
    let is *u8 as debug_pdb_path with mut = cast(*u8, 0);
    let is i32 as debug_pdb_path_len with mut = 0;
    let is i32 as debug_rsds_size = _emit_debug_entries(rodata_buf, output_path,
        &debug_dir_off, &debug_rsds_off,
        cast(*u8, &debug_guid[0]), &debug_pdb_path, &debug_pdb_path_len);

    // --shared: append the export directory to .rdata (ships in an existing
    // section, like the debug directory). Pointer RVAs patched after layout.
    let is i64 as export_dir_off with mut = 0;
    let is i32 as export_n with mut = 0;
    let is i64 as export_names_off with mut = 0;
    if (ls.is_shared == 1) {
        build_pe_export_dir(ls, rodata_buf, &export_dir_off, &export_n, &export_names_off, STUB_SIZE);
    }

    let is i64 as rodata_virt = rodata_buf.len;
    let is i64 as rodata_raw with mut = rodata_virt;
    if (rodata_raw > 0 && (rodata_raw % FILE_ALIGN) != 0) {
        rodata_raw = rodata_raw + (FILE_ALIGN - (rodata_raw % FILE_ALIGN));
    }
    let is i32 as has_rodata with mut = 0;
    if (rodata_virt > 0) { has_rodata = 1; }

    let is *reader.ByteBuffer as data_buf = linker.get_data(ls);
    let is i64 as data_virt = data_buf.len;
    let is i64 as data_raw with mut = data_virt;
    if (data_raw > 0 && (data_raw % FILE_ALIGN) != 0) {
        data_raw = data_raw + (FILE_ALIGN - (data_raw % FILE_ALIGN));
    }
    let is i32 as has_data with mut = 0;
    if (data_virt > 0) { has_data = 1; }

    // Section RVA layout: each section gets a slot starting at the next
    // SECTION_ALIGN-aligned RVA after the previous section's virtual size.
    // Earlier this code hardcoded idata=0x2000, rodata=0x3000, data=0x4000
    // assuming .text fit in a single page; that broke once .text exceeded
    // 4 KiB (PE loader maps each section header for one page of mapped
    // virtual range — sections starting inside an already-mapped page get
    // overlapped, and execute access to the would-be-code page fires a
    // fault because the loader marked it as data).
    //
    // Empirical (Wine): .idata must precede .rdata/.data in RVA order or
    // the IAT silently doesn't get patched. Keep that invariant by giving
    // it the slot immediately after .text.
    //
    // Section table is emitted in RVA-ascending order: .text, .idata,
    // [.rdata,] [.data], .pdata, .xdata, [.reloc] — loader monotonicity ok.
    let is i64 as text_virt_for_layout = linker.get_text(ls).len + STUB_SIZE;
    let is i64 as text_pages = (text_virt_for_layout + SECTION_ALIGN - 1) / SECTION_ALIGN;
    let is i64 as idata_rva = TEXT_RVA + text_pages * SECTION_ALIGN;
    // .idata always fits in 1 page for any realistic import set (a few DLLs,
    // a few dozen symbols). compute_idata_layout below allocates within that.
    let is i64 as rodata_rva with mut = idata_rva + SECTION_ALIGN;
    let is i64 as rodata_pages with mut = 0;
    if (has_rodata == 1) {
        rodata_pages = (rodata_virt + SECTION_ALIGN - 1) / SECTION_ALIGN;
    }
    let is i64 as data_rva with mut = rodata_rva + rodata_pages * SECTION_ALIGN;
    // BSS lives appended to .data in memory (`with mut` uninitialized
    // globals get loader-zero-fill via VirtualSize > RawSize). Section
    // page count MUST cover .data + BSS, otherwise BSS spills into the
    // next section's readonly page and trips a write fault.
    let is i64 as data_virt_total = data_virt + ls.bss_total;
    let is i64 as data_pages with mut = 0;
    if (has_data == 1 || ls.bss_total > 0) {
        data_pages = (data_virt_total + SECTION_ALIGN - 1) / SECTION_ALIGN;
        has_data = 1;
    }
    let is i64 as pdata_rva = data_rva + data_pages * SECTION_ALIGN;
    let is i64 as xdata_rva = pdata_rva + SECTION_ALIGN;
    let is i64 as reloc_rva with mut = xdata_rva + SECTION_ALIGN;

    let is ImportLayout as lay = compute_idata_layout(ls, idata_rva);

    // Build .reloc up front so we know whether to reserve a section header
    // slot for it. text_rva_base = TEXT_RVA + STUB_SIZE matches what
    // apply_relocations will use as ls.text_vaddr below.
    let is reader.ByteBuffer as reloc_buf = reader.buf_init(256);
    let is i64 as reloc_blob_size = build_reloc_blob(ls, &reloc_buf,
                                                     TEXT_RVA + STUB_SIZE,
                                                     rodata_rva, data_rva);
    let is i32 as has_reloc with mut = 0;
    if (reloc_blob_size > 0) { has_reloc = 1; }
    let is i64 as reloc_raw with mut = reloc_blob_size;
    if (has_reloc == 1 && (reloc_raw % FILE_ALIGN) != 0) {
        reloc_raw = reloc_raw + (FILE_ALIGN - (reloc_raw % FILE_ALIGN));
    }

    // Pre-compute final section count so we can size headers correctly.
    // .pdata + .xdata are always present (the 3 internal helpers alone
    // justify them; programs without those would still need them for
    // RtlVirtualUnwind correctness).
    let is i32 as nsec with mut = 4;     // .text, .idata, .pdata, .xdata
    if (has_rodata == 1) { nsec = nsec + 1; }
    if (has_data == 1) { nsec = nsec + 1; }
    if (has_reloc == 1) { nsec = nsec + 1; }
    // Headers end at 0x188 + nsec*40. Align up to FILE_ALIGN.
    let is i64 as headers_size with mut = 0x188 + cast(i64, nsec) * 40;
    if ((headers_size % FILE_ALIGN) != 0) {
        headers_size = headers_size + (FILE_ALIGN - (headers_size % FILE_ALIGN));
    }
    let is i64 as text_file_local = headers_size;

    // 2. Lay out text. We prepend three small routines BEFORE the merged
    //    object .text: entry stub (47), __caustic_chkstk (43), and
    //    __caustic_parse_argv (65). Together they reserve STUB_SIZE bytes
    //    at the start of .text; obj-local symbol vaddrs are shifted by
    //    that amount via the loop below.
    let is *reader.ByteBuffer as text_buf = linker.get_text(ls);
    let is i64 as text_virt = text_buf.len + STUB_SIZE;
    let is i64 as text_raw with mut = text_virt;
    if (text_raw % FILE_ALIGN != 0) {
        text_raw = text_raw + (FILE_ALIGN - text_raw % FILE_ALIGN);
    }
    if (text_raw < FILE_ALIGN) { text_raw = FILE_ALIGN; }

    // 3. Set text_vaddr in LinkerState — main offsets start AFTER the stub.
    //    obj.text_offset (set in merge_sections) is relative to text_buf
    //    start, but in the EXE main lives at text_vaddr + STUB_SIZE + offset.
    //    Easiest: set ls.text_vaddr = base + TEXT_RVA + STUB_SIZE so all
    //    obj-local symbol vaddrs already include the stub shift.
    // Save OLD vaddrs (set by linker's assign_addresses, used by build_symtab
    // when populating gsym vaddrs). We need them to compute per-symbol shift.
    let is i64 as old_rodata_vaddr = ls.rodata_vaddr;
    let is i64 as old_data_vaddr = ls.data_vaddr;
    let is i64 as old_bss_vaddr = ls.bss_vaddr;

    ls.text_vaddr = ls.base_addr + TEXT_RVA + STUB_SIZE;
    ls.rodata_vaddr = ls.base_addr + rodata_rva;
    ls.data_vaddr = ls.base_addr + data_rva;
    // BSS lives at the end of .data in the PE image — uninitialized `with mut`
    // globals get zero-fill in the .data section (we don't emit a separate
    // .bss section; size already accounted for via data_virt).
    ls.bss_vaddr = ls.data_vaddr + ls.data_size;

    // 4. Set entry to the stub itself, not main. Also rebuild main_vaddr.
    let is *linker.GlobalSymTab as gsyms2 = linker.get_gsyms(ls);
    let is i32 as ent_gi = linker.gsym_find(gsyms2, ls.entry_name, _strlen_i32(ls.entry_name));
    let is i64 as main_vaddr with mut = 0;
    if (ent_gi >= 0) {
        // main_vaddr was assigned by build_symtab using OLD text_vaddr
        // (before our STUB_SIZE shift). Reassign based on its obj-local
        // offset by walking the original obj table is complex; simpler:
        // gsym vaddr was set to (old_text_vaddr + offset). Adjust by
        // adding STUB_SIZE since we shifted text_vaddr by that amount.
        let is *linker.GlobalSym as eg = linker.gsym_get(gsyms2, ent_gi);
        eg.vaddr = eg.vaddr + STUB_SIZE;
        main_vaddr = eg.vaddr;
    }
    // Shift ALL defined gsyms based on which section they live in:
    //   .text   → shift by STUB_SIZE (text moves down by stub bytes)
    //   .rodata → reposition relative to NEW rodata_vaddr
    //   .data   → reposition relative to NEW data_vaddr
    // build_symtab populated gsym.vaddr using the OLD per-section vaddrs;
    // we recompute as new_vaddr = NEW_section_vaddr + (old - OLD_vaddr).
    let is i32 as gi with mut = 0;
    while (gi < gsyms2.count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms2, gi);
        if (g.defined == 1 && gi != ent_gi) {
            if (g.section == reader.SECIDX_TEXT) {
                g.vaddr = g.vaddr + STUB_SIZE;
            } else if (g.section == reader.SECIDX_RODATA) {
                g.vaddr = ls.rodata_vaddr + (g.vaddr - old_rodata_vaddr);
            } else if (g.section == reader.SECIDX_DATA) {
                g.vaddr = ls.data_vaddr + (g.vaddr - old_data_vaddr);
            } else if (g.section == reader.SECIDX_BSS) {
                g.vaddr = ls.bss_vaddr + (g.vaddr - old_bss_vaddr);
            }
        }
        gi = gi + 1;
    }

    // 5. Register __imp_<sym> globals so PC32 relocations resolve to IAT.
    //    Must run AFTER the section-shift loop above so the IAT-slot vaddrs
    //    we assign here aren't clobbered by the SECIDX_DATA branch.
    register_imp_gsyms(ls, &lay);

    // 5b. Synthesize __caustic_chkstk gsym pointing at the chkstk trampoline
    //     we emit right after the entry stub at TEXT_RVA + ENTRY_STUB_SIZE.
    //     Upsert: if any obj already referenced it as undefined, patch in
    //     the resolved vaddr; otherwise add fresh.
    let is i64 as chkstk_vaddr = ls.base_addr + TEXT_RVA + ENTRY_STUB_SIZE;
    let is i32 as chk_existing = linker.gsym_find(gsyms2, "__caustic_chkstk", 16);
    if (chk_existing >= 0) {
        let is *linker.GlobalSym as cg = linker.gsym_get(gsyms2, chk_existing);
        cg.vaddr = chkstk_vaddr;
        cg.section = reader.SECIDX_TEXT;
        cg.defined = 1;
    } else {
        linker.gsym_add(gsyms2, "__caustic_chkstk", 16,
                        reader.SECIDX_TEXT, chkstk_vaddr, 0, 1);
    }

    // Entry = stub's RVA (= TEXT_RVA, because stub is at the start of .text)
    ls.entry_vaddr = ls.base_addr + TEXT_RVA;

    // 5c. Build SEH tables (.pdata + .xdata).
    //
    // .xdata gets one UNWIND_INFO blob per function. For the three internal
    // helpers (entry stub, __caustic_chkstk, __caustic_parse_argv) we emit
    // hand-built blobs; for user functions we decode the prolog from text_buf
    // and emit a matching blob. text_buf still holds raw obj bytes here —
    // apply_relocations runs below and only patches operand fields, never
    // the push/sub bytes that form the prolog.
    //
    // .pdata gets one RUNTIME_FUNCTION (12 bytes) per function: BeginAddress,
    // EndAddress, UnwindInfoAddress. Loader requires the array to be sorted
    // by BeginAddress, which we satisfy by emitting in vaddr-ascending order.
    //
    // Each field is conceptually an IMAGE_REL_AMD64_ADDR32NB (image-relative
    // 32-bit RVA) — we write the resolved RVA directly as a u32, because the
    // linker computes the final layout here and there's no relocation to
    // apply later. The runtime ADDs ImageBase at load time to turn each RVA
    // into a VA. ADDR32NB only matters when these tables come from a .obj.
    let is reader.ByteBuffer as xdata_buf = reader.buf_init(1024);
    let is reader.ByteBuffer as pdata_buf = reader.buf_init(512);

    // Helper to push one RUNTIME_FUNCTION entry given begin/end RVAs and the
    // .xdata-relative offset where its UNWIND_INFO lives.
    // Inline three internal entries first, then walk user TEXT gsyms.
    let is i64 as stub_begin = TEXT_RVA;
    let is i64 as stub_end   = TEXT_RVA + ENTRY_STUB_SIZE;
    let is i64 as cks_begin  = stub_end;
    let is i64 as cks_end    = cks_begin + CHKSTK_SIZE;
    let is i64 as pa_begin   = cks_end;
    let is i64 as pa_end     = pa_begin + PARSE_ARGV_SIZE;

    let is i64 as stub_xoff = emit_entry_stub_unwind(&xdata_buf);
    reader.buf_emit32_le(&pdata_buf, stub_begin);
    reader.buf_emit32_le(&pdata_buf, stub_end);
    reader.buf_emit32_le(&pdata_buf, xdata_rva + stub_xoff);

    let is i64 as cks_xoff = emit_chkstk_unwind(&xdata_buf);
    reader.buf_emit32_le(&pdata_buf, cks_begin);
    reader.buf_emit32_le(&pdata_buf, cks_end);
    reader.buf_emit32_le(&pdata_buf, xdata_rva + cks_xoff);

    let is i64 as pa_xoff = emit_parse_argv_unwind(&xdata_buf);
    reader.buf_emit32_le(&pdata_buf, pa_begin);
    reader.buf_emit32_le(&pdata_buf, pa_end);
    reader.buf_emit32_le(&pdata_buf, xdata_rva + pa_xoff);

    // User functions: enumerate gsyms with section=TEXT && defined=1 EXCEPT
    // __caustic_chkstk (already covered above). Sort by vaddr ascending so
    // we can use the next entry's vaddr as the current function's end.
    let is [256]i32 as user_idxs;
    let is i32 as n_user with mut = 0;
    let is i32 as ui with mut = 0;
    while (ui < gsyms2.count && n_user < 256) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms2, ui);
        if (g.defined == 1 && g.section == reader.SECIDX_TEXT
            && reader.streq(g.name, g.name_len, "__caustic_chkstk", 16) == 0) {
            user_idxs[n_user] = ui;
            n_user = n_user + 1;
        }
        ui = ui + 1;
    }
    // Insertion sort by gsym.vaddr.
    let is i32 as si with mut = 1;
    while (si < n_user) {
        let is i32 as key = user_idxs[si];
        let is i64 as key_vaddr = linker.gsym_get(gsyms2, key).vaddr;
        let is i32 as sj with mut = si - 1;
        while (sj >= 0 && linker.gsym_get(gsyms2, user_idxs[sj]).vaddr > key_vaddr) {
            user_idxs[sj + 1] = user_idxs[sj];
            sj = sj - 1;
        }
        user_idxs[sj + 1] = key;
        si = si + 1;
    }

    // Decode each user function's prolog and emit pdata/xdata entries.
    let is [8]u8 as up_offsets;
    let is [8]u8 as up_ops;
    let is [8]u8 as up_infos;
    let is [8]i32 as up_extras;
    let is i64 as text_end_rva = TEXT_RVA + STUB_SIZE + text_buf.len;
    let is i32 as fi with mut = 0;
    while (fi < n_user) {
        let is *linker.GlobalSym as gf = linker.gsym_get(gsyms2, user_idxs[fi]);
        let is i64 as begin = gf.vaddr - ls.base_addr;
        let is i64 as end with mut = text_end_rva;
        if (fi + 1 < n_user) {
            end = linker.gsym_get(gsyms2, user_idxs[fi + 1]).vaddr - ls.base_addr;
        }
        // Decode at text_buf offset = vaddr - ls.text_vaddr.
        let is i64 as tb_off = gf.vaddr - ls.text_vaddr;
        let is i32 as max_bytes = cast(i32, end - begin);
        let is i32 as prolog_size with mut = 0;
        let is i32 as n_ops with mut = 0;
        if (tb_off >= 0 && tb_off < cast(i64, text_buf.len)) {
            n_ops = decode_user_prologue(cast(*u8, cast(i64, text_buf.data) + tb_off),
                                         max_bytes,
                                         cast(*u8, &up_offsets), cast(*u8, &up_ops),
                                         cast(*u8, &up_infos), cast(*i32, &up_extras),
                                         &prolog_size);
        }
        let is i64 as u_xoff = emit_unwind_info(&xdata_buf, prolog_size,
                                                cast(*u8, &up_offsets), cast(*u8, &up_ops),
                                                cast(*u8, &up_infos), cast(*i32, &up_extras),
                                                n_ops);
        reader.buf_emit32_le(&pdata_buf, begin);
        reader.buf_emit32_le(&pdata_buf, end);
        reader.buf_emit32_le(&pdata_buf, xdata_rva + u_xoff);
        fi = fi + 1;
    }

    let is i64 as pdata_size = pdata_buf.len;
    let is i64 as xdata_size = xdata_buf.len;
    let is i64 as pdata_raw with mut = pdata_size;
    if (pdata_raw % FILE_ALIGN != 0) {
        pdata_raw = pdata_raw + (FILE_ALIGN - pdata_raw % FILE_ALIGN);
    }
    let is i64 as xdata_raw with mut = xdata_size;
    if (xdata_raw % FILE_ALIGN != 0) {
        xdata_raw = xdata_raw + (FILE_ALIGN - xdata_raw % FILE_ALIGN);
    }

    // 6. Apply relocations — patches .text bytes with resolved addresses.
    linker.apply_relocations(ls);

    // 7. Write DOS header (128 bytes)
    reader.buf_emit8(&out, 77); reader.buf_emit8(&out, 90);   // "MZ"
    pad_to(&out, 60);
    reader.buf_emit32_le(&out, 128);                          // e_lfanew
    pad_to(&out, 128);

    // 8. PE signature
    reader.buf_emit8(&out, 80); reader.buf_emit8(&out, 69);
    reader.buf_emit8(&out, 0);  reader.buf_emit8(&out, 0);

    // 9. COFF header
    reader.buf_emit16_le(&out, IMAGE_FILE_MACHINE_AMD64);
    let is i32 as num_sections = 2 + has_rodata + has_data + 2 + has_reloc;
    reader.buf_emit16_le(&out, num_sections);                 // NumberOfSections
    reader.buf_emit32_le(&out, 0);                            // TimeDateStamp
    reader.buf_emit32_le(&out, 0);                            // PointerToSymbolTable
    reader.buf_emit32_le(&out, 0);                            // NumberOfSymbols
    reader.buf_emit16_le(&out, 240);                          // SizeOfOptionalHeader
    // IMAGE_FILE_DLL = 0x2000 when --shared (8192).
    reader.buf_emit16_le(&out, IMAGE_FILE_EXECUTABLE_IMAGE + IMAGE_FILE_LARGE_ADDRESS_AWARE + ls.is_shared * 8192);

    // 10. Optional header PE32+
    let is i64 as entry_rva with mut = ls.entry_vaddr - ls.base_addr;
    if (ls.is_shared == 1) { entry_rva = 0; }   // a DLL has no DllMain entry
    // SizeOfImage = end-of-last-section's VIRTUAL placement (not file).
    // With the new layout, last section in VA order is the highest of
    // idata/rodata/data.
    let is i64 as last_va_end with mut = idata_rva + lay.idata_virt_size;
    if (has_rodata == 1) {
        let is i64 as rd_end = rodata_rva + rodata_virt;
        if (rd_end > last_va_end) { last_va_end = rd_end; }
    }
    if (has_data == 1) {
        let is i64 as dt_end = data_rva + data_virt;
        if (dt_end > last_va_end) { last_va_end = dt_end; }
    }
    if (has_reloc == 1) {
        let is i64 as rl_end = reloc_rva + reloc_blob_size;
        if (rl_end > last_va_end) { last_va_end = rl_end; }
    }
    let is i64 as pd_end = pdata_rva + pdata_size;
    if (pd_end > last_va_end) { last_va_end = pd_end; }
    let is i64 as xd_end = xdata_rva + xdata_size;
    if (xd_end > last_va_end) { last_va_end = xd_end; }
    let is i64 as size_of_image with mut = last_va_end;
    if (size_of_image % SECTION_ALIGN != 0) {
        size_of_image = size_of_image + (SECTION_ALIGN - size_of_image % SECTION_ALIGN);
    }
    let is i64 as size_init_data = lay.idata_raw_size + rodata_raw + data_raw + pdata_raw + xdata_raw + reloc_raw;

    reader.buf_emit16_le(&out, PE_OPT_MAGIC_PE32PLUS);
    reader.buf_emit8(&out, 1); reader.buf_emit8(&out, 0);    // Linker version 1.0
    reader.buf_emit32_le(&out, text_raw);                     // SizeOfCode
    reader.buf_emit32_le(&out, size_init_data);               // SizeOfInitializedData
    reader.buf_emit32_le(&out, 0);                            // SizeOfUninitializedData
    reader.buf_emit32_le(&out, entry_rva);                    // AddressOfEntryPoint
    reader.buf_emit32_le(&out, TEXT_RVA);                     // BaseOfCode
    reader.buf_emit64_le(&out, ls.base_addr);                 // ImageBase
    reader.buf_emit32_le(&out, SECTION_ALIGN);
    reader.buf_emit32_le(&out, FILE_ALIGN);
    reader.buf_emit16_le(&out, 6); reader.buf_emit16_le(&out, 0);  // OSVer 6.0
    reader.buf_emit16_le(&out, 0); reader.buf_emit16_le(&out, 0);  // ImageVer 0.0
    reader.buf_emit16_le(&out, 6); reader.buf_emit16_le(&out, 0);  // SubsystemVer 6.0
    reader.buf_emit32_le(&out, 0);                            // Win32Version
    reader.buf_emit32_le(&out, size_of_image);                // SizeOfImage
    reader.buf_emit32_le(&out, headers_size);                 // SizeOfHeaders (dynamic)
    reader.buf_emit32_le(&out, 0);                            // CheckSum
    reader.buf_emit16_le(&out, IMAGE_SUBSYSTEM_WINDOWS_CUI);
    // DllCharacteristics: HIGH_ENTROPY_VA (0x20) | DYNAMIC_BASE (0x40) |
    // NX_COMPAT (0x100). HIGH_ENTROPY_VA lets the loader use the full 64-bit
    // address space for ASLR. When .reloc is absent, .text is PC-relative
    // and the image stays position-independent.
    reader.buf_emit16_le(&out, 352);                          // 0x160
    reader.buf_emit64_le(&out, 1048576);                      // StackReserve
    reader.buf_emit64_le(&out, 4096);                         // StackCommit
    reader.buf_emit64_le(&out, 1048576);                      // HeapReserve
    reader.buf_emit64_le(&out, 4096);                         // HeapCommit
    reader.buf_emit32_le(&out, 0);                            // LoaderFlags
    reader.buf_emit32_le(&out, 16);                           // NumberOfRvaAndSizes

    // 11. Data directories (16 × 8 = 128 bytes)
    let is i64 as iid_rva = idata_rva + lay.iat_total_size;
    let is i64 as iid_total_size = cast(i64, lay.dll_count + 1) * 20;
    let is i64 as i_dd with mut = 0;
    while (i_dd < 16) {
        if (i_dd == 0 && ls.is_shared == 1) {
            // IMAGE_DIRECTORY_ENTRY_EXPORT — the .dll export directory in .rdata
            reader.buf_emit32_le(&out, rodata_rva + export_dir_off);
            reader.buf_emit32_le(&out, rodata_virt - export_dir_off);
        } else if (i_dd == 1) {
            reader.buf_emit32_le(&out, iid_rva);
            reader.buf_emit32_le(&out, iid_total_size);
        } else if (i_dd == 3) {
            // IMAGE_DIRECTORY_ENTRY_EXCEPTION — points at the .pdata
            // RUNTIME_FUNCTION table (used by RtlLookupFunctionEntry).
            reader.buf_emit32_le(&out, pdata_rva);
            reader.buf_emit32_le(&out, pdata_size);
        } else if (i_dd == 5 && has_reloc == 1) {
            // IMAGE_DIRECTORY_ENTRY_BASERELOC
            reader.buf_emit32_le(&out, reloc_rva);
            reader.buf_emit32_le(&out, reloc_blob_size);
        } else if (i_dd == 6 && has_rodata == 1) {
            // IMAGE_DIRECTORY_ENTRY_DEBUG — IMAGE_DEBUG_DIRECTORY at the
            // tail of .rdata. WinDbg / VS use it to find the matching PDB.
            reader.buf_emit32_le(&out, rodata_rva + debug_dir_off);
            reader.buf_emit32_le(&out, DEBUG_DIR_SIZE);
        } else if (i_dd == 12) {
            reader.buf_emit32_le(&out, idata_rva);
            reader.buf_emit32_le(&out, lay.iat_total_size);
        } else {
            reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
        }
        i_dd = i_dd + 1;
    }

    // 12. Section table — RVA-ascending order: .text, .idata, [.rdata,] [.data],
    //     .pdata, .xdata, [.reloc]. File content laid out in the SAME order.
    let is i64 as idata_file with mut = text_file_local + text_raw;
    let is i64 as rodata_file with mut = idata_file + lay.idata_raw_size;

    // Now that rodata_rva and rodata_file are pinned down, patch the placeholder
    // fields in IMAGE_DEBUG_DIRECTORY we appended to rodata_buf earlier.
    _patch_debug_dir(rodata_buf, debug_dir_off, debug_rsds_off,
                     debug_rsds_size, rodata_rva, rodata_file);
    if (ls.is_shared == 1) {
        _pe_patch_export_dir(rodata_buf, export_dir_off, export_names_off, export_n, rodata_rva);
    }
    let is i64 as data_file with mut = rodata_file + rodata_raw;
    let is i64 as pdata_file with mut = data_file + data_raw;
    let is i64 as xdata_file with mut = pdata_file + pdata_raw;
    let is i64 as reloc_file with mut = xdata_file + xdata_raw;

    // Record section-table start so we can hand the 40-byte IMAGE_SECTION_HEADER
    // array to the PDB writer for its Section Headers stream. Without this,
    // WinDbg can't resolve section-relative offsets back to RVAs / source.
    let is i64 as sectab_start = out.len;

    // .text
    emit_str(&out, ".text", 5); pad_to(&out, out.len + 3);
    reader.buf_emit32_le(&out, text_virt);
    reader.buf_emit32_le(&out, TEXT_RVA);
    reader.buf_emit32_le(&out, text_raw);
    reader.buf_emit32_le(&out, text_file_local);
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
    reader.buf_emit16_le(&out, 0); reader.buf_emit16_le(&out, 0);
    reader.buf_emit32_le(&out, IMAGE_SCN_CNT_CODE + IMAGE_SCN_MEM_EXECUTE + IMAGE_SCN_MEM_READ);

    // .idata — always RVA 0x2000, immediately after .text
    emit_str(&out, ".idata", 6); pad_to(&out, out.len + 2);
    reader.buf_emit32_le(&out, lay.idata_virt_size);
    reader.buf_emit32_le(&out, idata_rva);
    reader.buf_emit32_le(&out, lay.idata_raw_size);
    reader.buf_emit32_le(&out, idata_file);
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
    reader.buf_emit16_le(&out, 0); reader.buf_emit16_le(&out, 0);
    reader.buf_emit32_le(&out, IMAGE_SCN_CNT_INITIALIZED_DATA + IMAGE_SCN_MEM_READ + IMAGE_SCN_MEM_WRITE);

    // .rdata (only if non-empty rodata) — read-only data
    if (has_rodata == 1) {
        emit_str(&out, ".rdata", 6); pad_to(&out, out.len + 2);
        reader.buf_emit32_le(&out, rodata_virt);
        reader.buf_emit32_le(&out, rodata_rva);
        reader.buf_emit32_le(&out, rodata_raw);
        reader.buf_emit32_le(&out, rodata_file);
        reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
        reader.buf_emit16_le(&out, 0); reader.buf_emit16_le(&out, 0);
        reader.buf_emit32_le(&out, IMAGE_SCN_CNT_INITIALIZED_DATA + IMAGE_SCN_MEM_READ);
    }

    // .data (only if non-empty) — readable + writable initialized data.
    // VirtualSize includes BSS (loader zero-fills the gap between RawSize
    // and VirtualSize, giving us .bss without a separate section header).
    if (has_data == 1) {
        emit_str(&out, ".data", 5); pad_to(&out, out.len + 3);
        reader.buf_emit32_le(&out, data_virt_total);
        reader.buf_emit32_le(&out, data_rva);
        reader.buf_emit32_le(&out, data_raw);
        reader.buf_emit32_le(&out, data_file);
        reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
        reader.buf_emit16_le(&out, 0); reader.buf_emit16_le(&out, 0);
        reader.buf_emit32_le(&out, IMAGE_SCN_CNT_INITIALIZED_DATA + IMAGE_SCN_MEM_READ + IMAGE_SCN_MEM_WRITE);
    }

    // .pdata — RUNTIME_FUNCTION table. Read-only initialized data.
    emit_str(&out, ".pdata", 6); pad_to(&out, out.len + 2);
    reader.buf_emit32_le(&out, pdata_size);
    reader.buf_emit32_le(&out, pdata_rva);
    reader.buf_emit32_le(&out, pdata_raw);
    reader.buf_emit32_le(&out, pdata_file);
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
    reader.buf_emit16_le(&out, 0); reader.buf_emit16_le(&out, 0);
    reader.buf_emit32_le(&out, IMAGE_SCN_CNT_INITIALIZED_DATA + IMAGE_SCN_MEM_READ);

    // .xdata — UNWIND_INFO blobs. Read-only initialized data.
    emit_str(&out, ".xdata", 6); pad_to(&out, out.len + 2);
    reader.buf_emit32_le(&out, xdata_size);
    reader.buf_emit32_le(&out, xdata_rva);
    reader.buf_emit32_le(&out, xdata_raw);
    reader.buf_emit32_le(&out, xdata_file);
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
    reader.buf_emit16_le(&out, 0); reader.buf_emit16_le(&out, 0);
    reader.buf_emit32_le(&out, IMAGE_SCN_CNT_INITIALIZED_DATA + IMAGE_SCN_MEM_READ);

    // .reloc — base relocations (only if we collected any ADDR64 sites)
    // Characteristics: INITIALIZED_DATA | MEM_READ | MEM_DISCARDABLE (0x02000000)
    if (has_reloc == 1) {
        emit_str(&out, ".reloc", 6); pad_to(&out, out.len + 2);
        reader.buf_emit32_le(&out, reloc_blob_size);
        reader.buf_emit32_le(&out, reloc_rva);
        reader.buf_emit32_le(&out, reloc_raw);
        reader.buf_emit32_le(&out, reloc_file);
        reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
        reader.buf_emit16_le(&out, 0); reader.buf_emit16_le(&out, 0);
        reader.buf_emit32_le(&out, IMAGE_SCN_CNT_INITIALIZED_DATA + IMAGE_SCN_MEM_READ + 33554432);
    }

    let is i64 as sectab_end = out.len;
    let is i64 as sectab_size = sectab_end - sectab_start;

    // 13. Pad to headers_size (FILE_ALIGN-aligned)
    pad_to(&out, headers_size);

    // 14. .text raw data — entry stub + chkstk + parse_argv FIRST, then
    //     the merged object .text. All three live at fixed offsets
    //     within the prefix; see PREFIX_SIZE = STUB_SIZE up top.
    let is i64 as exit_iat_rva = _find_iat_rva(ls, &lay, "ExitProcess", 11);
    if (exit_iat_rva < 0) {
        io._write_fd(io.STDERR, "caustic-ld: ExitProcess not in cstimport — PE entry stub needs kernel32!ExitProcess\n", 84);
        return 1;
    }
    let is i64 as getcmdline_iat_rva = _find_iat_rva(ls, &lay, "GetCommandLineA", 15);
    if (getcmdline_iat_rva < 0) {
        io._write_fd(io.STDERR, "caustic-ld: GetCommandLineA not in cstimport — PE entry stub needs kernel32!GetCommandLineA\n", 92);
        return 1;
    }
    let is i64 as parse_argv_rva = TEXT_RVA + ENTRY_STUB_SIZE + CHKSTK_SIZE;
    emit_win_entry_stub(&out, main_vaddr - ls.base_addr,
                        getcmdline_iat_rva, parse_argv_rva,
                        exit_iat_rva, TEXT_RVA);
    // __caustic_chkstk at TEXT_RVA + ENTRY_STUB_SIZE — registered as a gsym
    // below so codegen-emitted `call __caustic_chkstk` resolves via PC32.
    emit_caustic_chkstk(&out);
    // __caustic_parse_argv at TEXT_RVA + ENTRY_STUB_SIZE + CHKSTK_SIZE.
    emit_caustic_parse_argv(&out);
    let is i64 as tb_len = text_buf.len;
    let is i64 as ti with mut = 0;
    while (ti < tb_len) {
        reader.buf_emit8(&out, cast(i32, text_buf.data[ti]));
        ti = ti + 1;
    }
    pad_to(&out, text_file_local + text_raw);
    // .idata raw data emitted next (in section 15 below at idata_file = right after text)
    // After .idata, we'll emit .rdata and .data so file order matches RVA order.

    // 15. .idata raw data
    // 15a. IAT region — each entry = RVA to hint/name (loader patches at load time)
    let is *i64 as hr_w = cast(*i64, lay.hint_rvas);
    let is *i64 as ldp_w = cast(*i64, ls.cstimport_dll_ptrs);
    let is *i32 as ldl_w = cast(*i32, ls.cstimport_dll_lens);
    // Walk DLLs, emit each DLL's IAT entries followed by null terminator.
    let is i32 as didx with mut = 0;
    while (didx < lay.dll_count) {
        let is i32 as ii with mut = 0;
        while (ii < ls.cstimport_count) {
            let is i32 as this_didx = _find_dll_idx(&lay, cast(*u8, ldp_w[ii]), ldl_w[ii]);
            if (this_didx == didx) {
                reader.buf_emit64_le(&out, hr_w[ii]);
            }
            ii = ii + 1;
        }
        reader.buf_emit64_le(&out, 0);  // null terminator for this DLL
        didx = didx + 1;
    }

    // 15b. IID array
    let is *i64 as diatf_w = cast(*i64, lay.dll_iat_first_rvas);
    let is *i64 as diltf_w = cast(*i64, lay.dll_ilt_first_rvas);
    let is *i64 as dnr_w = cast(*i64, lay.dll_name_rvas);
    didx = 0;
    while (didx < lay.dll_count) {
        reader.buf_emit32_le(&out, diltf_w[didx]);  // OriginalFirstThunk (ILT)
        reader.buf_emit32_le(&out, 0);              // TimeDateStamp
        reader.buf_emit32_le(&out, 0);              // ForwarderChain
        reader.buf_emit32_le(&out, dnr_w[didx]);    // Name (DLL name RVA)
        reader.buf_emit32_le(&out, diatf_w[didx]);  // FirstThunk (IAT)
        didx = didx + 1;
    }
    // Null IID terminator
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
    reader.buf_emit32_le(&out, 0); reader.buf_emit32_le(&out, 0);
    reader.buf_emit32_le(&out, 0);

    // 15c. ILT region (mirrors IAT)
    didx = 0;
    while (didx < lay.dll_count) {
        let is i32 as ii2 with mut = 0;
        while (ii2 < ls.cstimport_count) {
            let is i32 as this_didx = _find_dll_idx(&lay, cast(*u8, ldp_w[ii2]), ldl_w[ii2]);
            if (this_didx == didx) {
                reader.buf_emit64_le(&out, hr_w[ii2]);
            }
            ii2 = ii2 + 1;
        }
        reader.buf_emit64_le(&out, 0);
        didx = didx + 1;
    }

    // 15d. Hint/name entries (in cstimport order, padded to 16 bytes)
    let is *i64 as lsp_w = cast(*i64, ls.cstimport_sym_ptrs);
    let is *i32 as lsl_w = cast(*i32, ls.cstimport_sym_lens);
    let is i32 as i_hn with mut = 0;
    while (i_hn < ls.cstimport_count) {
        reader.buf_emit16_le(&out, 0);             // hint
        emit_str(&out, cast(*u8, lsp_w[i_hn]), cast(i64, lsl_w[i_hn]));
        reader.buf_emit8(&out, 0);                  // NUL
        let is i64 as entry_sz with mut = 2 + cast(i64, lsl_w[i_hn]) + 1;
        while ((entry_sz & 15) != 0) { reader.buf_emit8(&out, 0); entry_sz = entry_sz + 1; }
        i_hn = i_hn + 1;
    }

    // 15e. DLL name strings (padded to 16 bytes)
    let is *i64 as dnp_w = cast(*i64, lay.dll_name_ptrs);
    let is *i32 as dnl_w = cast(*i32, lay.dll_name_lens);
    didx = 0;
    while (didx < lay.dll_count) {
        emit_str(&out, cast(*u8, dnp_w[didx]), cast(i64, dnl_w[didx]));
        reader.buf_emit8(&out, 0);
        let is i64 as entry_sz with mut = cast(i64, dnl_w[didx]) + 1;
        while ((entry_sz & 15) != 0) { reader.buf_emit8(&out, 0); entry_sz = entry_sz + 1; }
        didx = didx + 1;
    }

    pad_to(&out, idata_file + lay.idata_raw_size);

    // 15f. .rdata raw data (after .idata in file)
    if (has_rodata == 1) {
        let is i64 as rd_len = rodata_buf.len;
        let is i64 as rdi with mut = 0;
        while (rdi < rd_len) {
            reader.buf_emit8(&out, cast(i32, rodata_buf.data[rdi]));
            rdi = rdi + 1;
        }
        pad_to(&out, rodata_file + rodata_raw);
    }

    // 15g. .data raw data (after .rdata in file)
    if (has_data == 1) {
        let is i64 as dd_len = data_buf.len;
        let is i64 as ddi with mut = 0;
        while (ddi < dd_len) {
            reader.buf_emit8(&out, cast(i32, data_buf.data[ddi]));
            ddi = ddi + 1;
        }
        pad_to(&out, data_file + data_raw);
    }

    // 15g2. .pdata raw — RUNTIME_FUNCTION table
    let is i64 as pdi with mut = 0;
    while (pdi < pdata_size) {
        reader.buf_emit8(&out, cast(i32, pdata_buf.data[pdi]));
        pdi = pdi + 1;
    }
    pad_to(&out, pdata_file + pdata_raw);

    // 15g3. .xdata raw — UNWIND_INFO blobs
    let is i64 as xdi with mut = 0;
    while (xdi < xdata_size) {
        reader.buf_emit8(&out, cast(i32, xdata_buf.data[xdi]));
        xdi = xdi + 1;
    }
    pad_to(&out, xdata_file + xdata_raw);

    // 15h. .reloc raw data (last section in file). NOTE: build_reloc_blob
    //      collects RVAs from the OBJ relocs which were already shifted to
    //      their final positions via the gsym-shift loop above. The bytes
    //      we wrote into reloc_buf at the start of this function are still
    //      valid because the RVAs depend on layout constants (TEXT_RVA +
    //      STUB_SIZE, rodata_rva, data_rva), all of which are computed
    //      before the shift loop runs.
    if (has_reloc == 1) {
        let is i64 as rli with mut = 0;
        while (rli < reloc_blob_size) {
            reader.buf_emit8(&out, cast(i32, reloc_buf.data[rli]));
            rli = rli + 1;
        }
        pad_to(&out, reloc_file + reloc_raw);
    }

    // 16. Write to file
    let is i64 as fd = io._open_write(output_path);
    if (fd < 0) {
        io._write_fd(io.STDERR, "caustic-ld: cannot create output\n", 33);
        return 1;
    }
    io._write_fd(fd, out.data, out.len);
    io._close_fd(fd);
    io.make_executable(output_path);

    // 17. Build Publics + Symbol Records + Module Stream from gsyms+.cstdebug.
    //     Then emit the matching .pdb sidecar. The GUID written into
    //     IMAGE_DEBUG_DIRECTORY's RSDS record must be the same value embedded
    //     in the PDB Info stream — debuggers match on (GUID, Age) and reject
    //     mismatched sidecars.
    let is reader.ByteBuffer as symrec_buf = reader.buf_init(4096);
    let is reader.ByteBuffer as publics_buf = reader.buf_init(1024);
    let is i64 as text_section_va = ls.base_addr + TEXT_RVA;
    build_publics_buffers(ls, text_section_va, &symrec_buf, &publics_buf);

    // TPI is built FIRST so the module stream's S_LOCAL records can
    // reference real CV type indices (LF_POINTER, LF_ARRAY, LF_STRUCTURE)
    // produced during type-record emission. build_tpi_body returns:
    //   proc_indices    — function i → its LF_PROCEDURE TPI index
    //   struct_indices  — struct ordinal → its LF_STRUCTURE TPI index
    //   tm_keys/tm_vals — (kind, extra) → composite-type CV index map
    let is reader.ByteBuffer as tpi_body_buf = reader.buf_init(1024);
    let is *i32 as proc_indices = cast(*i32, om.opt_alloc(1024 * 4));
    let is *i32 as tpi_struct_indices with mut = cast(*i32, 0);
    let is i32 as tpi_num_structs with mut = 0;
    let is *i64 as tpi_tm_keys with mut = cast(*i64, 0);
    let is *i32 as tpi_tm_vals with mut = cast(*i32, 0);
    let is i32 as tpi_tm_count with mut = 0;
    let is i32 as tpi_num_types = build_tpi_body(ls, &tpi_body_buf, proc_indices,
        &tpi_struct_indices, &tpi_num_structs,
        &tpi_tm_keys, &tpi_tm_vals, &tpi_tm_count);

    let is reader.ByteBuffer as module_buf = reader.buf_init(4096);
    let is *u8 as mod_source with mut = cast(*u8, 0);
    let is i32 as mod_source_len with mut = 0;
    let is i32 as mod_sym_size with mut = 0;
    let is i32 as mod_c13_size with mut = 0;
    build_module_stream(ls, text_section_va, &module_buf,
                        &mod_source, &mod_source_len,
                        &mod_sym_size, &mod_c13_size,
                        tpi_struct_indices, tpi_num_structs,
                        tpi_tm_keys, tpi_tm_vals, tpi_tm_count);

    let is reader.ByteBuffer as ipi_body_buf = reader.buf_init(1024);
    let is i32 as ipi_num_records = build_ipi_body(ls, &ipi_body_buf,
        mod_source, mod_source_len,
        debug_pdb_path, debug_pdb_path_len,
        proc_indices);

    pdbw.write_pdb(debug_pdb_path, cast(*u8, &debug_guid[0]),
                   cast(*u8, cast(i64, out.data) + sectab_start),
                   cast(i32, sectab_size / 40),
                   symrec_buf.data, cast(i32, symrec_buf.len),
                   publics_buf.data, cast(i32, publics_buf.len),
                   module_buf.data, cast(i32, module_buf.len),
                   mod_source, mod_source_len,
                   mod_sym_size, mod_c13_size,
                   cast(i32, ls.text_size + STUB_SIZE),
                   ipi_body_buf.data, cast(i32, ipi_body_buf.len),
                   ipi_num_records,
                   tpi_body_buf.data, cast(i32, tpi_body_buf.len),
                   tpi_num_types);

    return 0;
}

fn _strlen_i32(s as *u8) as i32 {
    let is i32 as i with mut = 0;
    while (s[i] != cast(u8, 0)) { i = i + 1; }
    return i;
}

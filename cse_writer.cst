// =======================================================
// cse_writer.cst — Caustic Standard Executable (CSE) output
//
// Emitted for --target=caustic-x86_64 (object_format == 3). Three modes,
// selected by tgt.g_target.cse_mode:
//   0 = pure   : 32-byte CST_ header + flat image, runs on CausticOS only
//   1 = compat : APE-style polyglot (PE + shell + CST)        [Phase 4]
//   2 = bundle : polyglot w/ standalone PE + ELF + CST bodies [Phase 4]
//
// write_cse() is the entry point; it runs relocation + dispatches by mode.
//
// PURE layout (v1, fixed-base flat mapping):
//   [0x00..0x20) 32-byte CST_ header
//   [.. text_off) zero padding
//   [text_off ..) .text        (file_off = text_vaddr - base)
//   [.. rodata)   .rodata      (file_off = rodata_vaddr - base)
//   [.. data)     .data        (file_off = data_vaddr - base)
//   [.. csec..)   custom sections, each at (csec_vaddr - base)
//   bss: not stored; loader zeroes bss_size bytes after the image.
// Flat mapping invariant: vaddr == base_addr + file_off for every byte, so
// the vaddrs produced by assign_addresses() (and baked into relocations by
// apply_relocations()) stay valid without any address fix-up in the loader.
//
// Header (32 bytes):
//   0x00 4  magic "CST_"      (43 53 54 5f)
//   0x04 2  version = 1       (u16 LE)
//   0x06 1  arch    = 1       (x86_64)
//   0x07 1  flags   = 0
//   0x08 8  entry_point       (u64 LE, absolute vaddr = ls.entry_vaddr)
//   0x10 4  text_off          (u32 LE, file offset of .text)
//   0x14 4  text_size         (u32 LE)
//   0x18 8  bss_size          (u64 LE = ls.bss_total)
// =======================================================

use "../std/io.cst" as io;
use "elf_reader.cst" as reader;
use "elf_writer.cst" as elfw;
use "linker.cst" as linker;
use "../src/codegen/target.cst" as tgt;

let is i32 as CSE_VERSION with imut = 1;
let is i32 as CSE_ARCH_X86_64 with imut = 1;
let is i64 as CSE_PAGE with imut = 4096;

// Write a finished output buffer to disk. Mirrors elf_writer's helper so
// cse_writer stays independent of the (large) elf_writer module.
fn cse_write_buf_to_file(out as *reader.ByteBuffer, output_path as *u8) as i32 {
    let is i64 as fd = io._open_write(output_path);
    if (fd < 0) {
        io._write_fd(io.STDERR, "caustic-ld: cannot create ", 26);
        io._write_fd(io.STDERR, output_path, cast(i64, reader.strlen(output_path)));
        io._write_fd(io.STDERR, "\n", 1);
        return 1;
    }
    io._write_fd(fd, out.data, out.len);
    io._close_fd(fd);
    return 0;
}

// Emit a compact CST_ v2 image into `out` (which must start at the image's
// own offset 0). Layout — header + segment table + tightly packed segment
// bytes, NO page padding. The CausticOS loader reads the segment table and,
// for each entry, copies file_size bytes from (image_start + file_off) to
// vaddr, zero-fills up to mem_size (bss), and applies perms. Memory stays
// page-aligned (vaddrs unchanged from assign_addresses, so relocations remain
// valid) while the file carries only real bytes.
//
//   Header (32 bytes):
//     0x00 4  "CST_"      0x04 2 version=2   0x06 1 arch   0x07 1 flags
//     0x08 8  entry_point (abs vaddr)
//     0x10 8  base_addr
//     0x18 4  seg_count   0x1C 4 app_version_off (file offset of a NUL-term
//                                version string; 0 = none)
//   Segment table: seg_count * 24 bytes, from 0x20:
//     +0x00 8 vaddr   +0x08 4 file_off (rel to image, 0 if bss)
//     +0x0C 4 file_size   +0x10 4 mem_size   +0x14 4 perms (1=R 2=W 4=X)
//   Then: packed segment data.
//
// file_off is relative to the image start, so the same bytes work standalone
// (pure, image at file 0) and embedded (combiner records the image's base via
// the CST* mini-header; loader adds it).
fn cse_emit_cst_v2(out as *reader.ByteBuffer, ls as *linker.LinkerState) as void {
    let is *reader.ByteBuffer as text_buf = linker.get_text(ls);
    let is *reader.ByteBuffer as rodata_buf = linker.get_rodata(ls);
    let is *reader.ByteBuffer as data_buf = linker.get_data(ls);
    let is *reader.ByteBuffer as csec_mbufs = cast(*reader.ByteBuffer, ls.csec_bufs);
    let is *i64 as csec_sizes = cast(*i64, ls.csec_sizes);
    let is *i64 as csec_vaddrs = cast(*i64, ls.csec_vaddrs);

    let is [40]i64 as sv;     // vaddr
    let is [40]i64 as sptr;   // *u8 file bytes (0 = zero-fill / bss)
    let is [40]i64 as sfsz;   // file_size
    let is [40]i64 as smsz;   // mem_size
    let is [40]i32 as sperm;  // perms: 1=R 2=W 4=X
    let is i32 as n with mut = 0;

    if (ls.text_size > 0) {
        sv[n] = ls.text_vaddr; sptr[n] = cast(i64, text_buf.data);
        sfsz[n] = ls.text_size; smsz[n] = ls.text_size; sperm[n] = 5; n = n + 1;   // R+X
    }
    if (ls.rodata_size > 0) {
        sv[n] = ls.rodata_vaddr; sptr[n] = cast(i64, rodata_buf.data);
        sfsz[n] = ls.rodata_size; smsz[n] = ls.rodata_size; sperm[n] = 1; n = n + 1; // R
    }
    if (ls.data_size > 0) {
        sv[n] = ls.data_vaddr; sptr[n] = cast(i64, data_buf.data);
        sfsz[n] = ls.data_size; smsz[n] = ls.data_size; sperm[n] = 3; n = n + 1;     // R+W
    }
    let is i32 as ci with mut = 0;
    while (ci < ls.csec_count) {
        if (csec_sizes[ci] > 0 && n < 39) {
            sv[n] = csec_vaddrs[ci]; sptr[n] = cast(i64, csec_mbufs[ci].data);
            sfsz[n] = csec_sizes[ci]; smsz[n] = csec_sizes[ci]; sperm[n] = 3; n = n + 1;
        }
        ci = ci + 1;
    }
    if (ls.bss_total > 0) {
        sv[n] = ls.bss_vaddr; sptr[n] = 0;
        sfsz[n] = 0; smsz[n] = ls.bss_total; sperm[n] = 3; n = n + 1;
    }

    // Pack file offsets after header + segment table.
    let is [40]i64 as sfoff;
    let is i64 as cursor with mut = 32 + cast(i64, n) * 24;
    let is i32 as i with mut = 0;
    while (i < n) {
        if (sfsz[i] > 0) { sfoff[i] = cursor; cursor = cursor + sfsz[i]; }
        else { sfoff[i] = 0; }
        i = i + 1;
    }

    // Optional free-form program version: a NUL-terminated string appended
    // after the segment data. The header @0x1C holds its file offset (0 if
    // unset). `cursor` is the end of segment data = where it will go.
    let is *u8 as ver_ptr = tgt.app_version_ptr_get();
    let is i32 as ver_len = tgt.app_version_len_get();
    let is i64 as ver_off with mut = 0;
    if (ver_len > 0) { ver_off = cursor; }

    // Header.
    reader.buf_emit8(out, 67); reader.buf_emit8(out, 83);
    reader.buf_emit8(out, 84); reader.buf_emit8(out, 95);   // "CST_"
    reader.buf_emit16_le(out, 2);                  // version 2 (segmented)
    reader.buf_emit8(out, CSE_ARCH_X86_64);
    reader.buf_emit8(out, 0);                      // flags
    reader.buf_emit64_le(out, ls.entry_vaddr);     // entry_point
    reader.buf_emit64_le(out, ls.base_addr);       // base_addr
    reader.buf_emit32_le(out, cast(i64, n));       // seg_count
    reader.buf_emit32_le(out, ver_off);            // 0x1C app_version file offset (0 = none)

    // Segment table.
    i = 0;
    while (i < n) {
        reader.buf_emit64_le(out, sv[i]);
        reader.buf_emit32_le(out, sfoff[i]);
        reader.buf_emit32_le(out, sfsz[i]);
        reader.buf_emit32_le(out, smsz[i]);
        reader.buf_emit32_le(out, cast(i64, sperm[i]));
        i = i + 1;
    }

    // Packed segment bytes (same order as the table).
    i = 0;
    while (i < n) {
        if (sfsz[i] > 0) { reader.buf_append(out, cast(*u8, sptr[i]), sfsz[i]); }
        i = i + 1;
    }

    // Append the version string (NUL-terminated) at ver_off.
    if (ver_len > 0) {
        reader.buf_append(out, ver_ptr, cast(i64, ver_len));
        reader.buf_emit8(out, 0);
    }
}

// Pure mode: compact CST_ v2 image. Runs on CausticOS via its loader.
fn write_cse_pure(ls as *linker.LinkerState, output_path as *u8) as i32 {
    // Resolve relocations against the assigned vaddrs (static; CausticOS
    // syscall ABI means no dynamic linking in the MVP).
    linker.apply_relocations(ls);
    let is reader.ByteBuffer as out = reader.buf_init(65536);
    cse_emit_cst_v2(&out, ls);
    return cse_write_buf_to_file(&out, output_path);
}

// === compat / bundle: self-extracting Linux + CST output ===
//
// This is the in-process path: a single caustic-target link produces one
// object set (relocated at the ELF base), so it can emit a native-Linux
// self-extractor carrying the CST body — but NOT a native Windows PE (that
// needs a separate windows-x86_64 build with its own relocation + imports).
// For the full tri-format Windows+Linux+CausticOS polyglot, build the three
// targets separately and weld them with `caustic-ld --cse-combine`
// (write_cse_combine_ape above — empirically verified under wine, sh and
// bash). compat and bundle here emit a portable self-extracting executable:
//
//   #!/bin/sh
//   <extractor: dd the embedded ELF out of $0, chmod +x, exec it with "$@">
//   exit 1
//   #### padding to CSE_BODY_OFF (keeps the shell-parsed region NUL-free)
//   [CSE_BODY_OFF] standalone ELF body   (native Linux execution)
//   [.. aligned ]  CST body (CST_ header + flat image) for CausticOS
//
// The ELF body runs natively on Linux; the CST body carries the CausticOS
// image (locatable by its "CST_" magic). bundle keeps the ELF and CST as two
// independent complete bodies. compat currently shares this layout — the
// shared-.text + native-PE optimisation (Cosmopolitan-style) is future work
// (needs a NUL-free header bash won't reject + a second PE-base relocation).
let is i64 as CSE_BODY_OFF with imut = 512;  // shell stub fits here; ELF starts at 512

// Append the decimal text of n (>= 0) to out.
fn cse_emit_decimal(out as *reader.ByteBuffer, n as i64) as void {
    if (n == 0) { reader.buf_emit8(out, 48); return; }
    let is [24]u8 as tmp;
    let is i32 as i with mut = 0;
    let is i64 as v with mut = n;
    while (v > 0) {
        tmp[i] = cast(u8, 48 + cast(i32, v % 10));
        v = v / 10;
        i = i + 1;
    }
    while (i > 0) {
        i = i - 1;
        reader.buf_emit8(out, cast(i32, tmp[i]));
    }
}

// Append a literal NUL-terminated string to out.
fn cse_emit_str(out as *reader.ByteBuffer, s as *u8) as void {
    reader.buf_append(out, s, reader.strlen(s));
}

// Read the whole file at `path` into `out` (appended at the current position),
// in fixed chunks so no heap allocation is needed. Returns total bytes read,
// or -1 on open error.
fn cse_read_file_into(out as *reader.ByteBuffer, path as *u8) as i64 {
    let is i64 as fd = io._open_read(path);
    if (fd < 0) { return 0 - 1; }
    let is [8192]u8 as chunk;
    let is i64 as total with mut = 0;
    let is i64 as got with mut = io._read_fd(fd, cast(*u8, &chunk), 8192);
    while (got > 0) {
        reader.buf_append(out, cast(*u8, &chunk), got);
        total = total + got;
        got = io._read_fd(fd, cast(*u8, &chunk), 8192);
    }
    io._close_fd(fd);
    return total;
}

// Build the CST body (CST_ header + flat image) into a fresh buffer; returns
// it by writing the buffer struct through `out_body`. Caller appends it.
fn cse_build_cst_body(ls as *linker.LinkerState, out_body as *reader.ByteBuffer) as void {
    cse_emit_cst_v2(out_body, ls);
}

// Shared implementation for compat + bundle.
fn write_cse_selfextract(ls as *linker.LinkerState, output_path as *u8) as i32 {
    linker.apply_relocations(ls);

    // 1. Produce a standalone ELF body via the existing ELF writer, then read
    //    it back. The ELF is relocated at base 0x400000 (same as ls), so it is
    //    a valid Linux executable when extracted.
    let is *u8 as elf_tmp = "__cse_elf_body.tmp";
    let is i32 as elf_err = elfw.write_executable(ls, elf_tmp);
    if (elf_err != 0) {
        io._write_fd(io.STDERR, "caustic-ld: CSE: failed to build inner ELF body\n", 48);
        return 1;
    }

    let is reader.ByteBuffer as elf_body = reader.buf_init(131072);
    let is i64 as elf_size = cse_read_file_into(&elf_body, elf_tmp);
    io.unlink(elf_tmp);
    if (elf_size <= 0) {
        io._write_fd(io.STDERR, "caustic-ld: CSE: failed to read inner ELF body\n", 47);
        return 1;
    }

    // 2. Build the CST body (CausticOS image).
    let is reader.ByteBuffer as cst_body = reader.buf_init(65536);
    cse_build_cst_body(ls, &cst_body);

    // 3. Assemble the polyglot.
    let is reader.ByteBuffer as out = reader.buf_init(262144);
    cse_emit_str(&out, "#!/bin/sh\n");
    // Extractor: copy ELF bytes [CSE_BODY_OFF, +elf_size) to a temp file, exec.
    cse_emit_str(&out, "__o=");
    cse_emit_decimal(&out, CSE_BODY_OFF);
    cse_emit_str(&out, ";__s=");
    cse_emit_decimal(&out, elf_size);
    cse_emit_str(&out, ";__t=$(mktemp);tail -c +$((__o+1)) \"$0\"|head -c $__s>\"$__t\";chmod +x \"$__t\";exec \"$__t\" \"$@\"\n");
    cse_emit_str(&out, "exit 1\n");
    // Pad with '#' comment bytes to CSE_BODY_OFF (NUL-free shell region).
    while (out.len < CSE_BODY_OFF) { reader.buf_emit8(&out, 35); }  // '#'

    // ELF body at CSE_BODY_OFF.
    reader.buf_append(&out, elf_body.data, elf_size);
    // CST body 8-aligned after the ELF (carries its own CST_ magic).
    let is i64 as cst_off = (out.len + 7) & (0 - 8);
    reader.buf_pad_to(&out, cst_off);
    reader.buf_append(&out, cst_body.data, cst_body.len);

    return cse_write_buf_to_file(&out, output_path);
}

// === Full tri-format APE polyglot combiner ===
//
// EMPIRICALLY VERIFIED: a single file can be a valid Windows PE, a Linux shell
// script that extracts+execs an embedded ELF, AND carry a CST body — running
// natively on Windows (wine), Linux (sh/bash), and CausticOS. The shell-trick
// works because bash/sh only binary-check the FIRST line: starting with
// `MZqFpD='\n` keeps line 1 clean (MZ for PE + an opening single-quote), and
// the NUL bytes of e_lfanew (0x3C) then sit harmlessly inside the multi-line
// quoted string.
//
// The three bodies must be built separately (different relocation bases /
// import tables), so this combiner takes three finished executables:
//   --pe  <windows-x86_64 build>   (runs under Windows/wine)
//   --elf <linux-x86_64 build>     (extracted + exec'd on Linux)
//   --cst <caustic pure .cse>      (CausticOS image; optional)
// and welds them into one APE. The PE is shifted by CSE_APE_SHIFT so its file
// offsets clear the shell stub; e_lfanew and every PointerToRawData (plus the
// COFF symbol-table pointer) are bumped by the same amount.
let is i64 as CSE_APE_SHIFT with imut = 512;   // 0x200 — multiple of PE FileAlignment

fn cse_rd_u16(p as *u8, off as i32) as i32 {
    return cast(i32, p[off]) + cast(i32, p[off + 1]) * 256;
}
fn cse_rd_u32(p as *u8, off as i32) as i64 {
    return cast(i64, p[off]) + cast(i64, p[off + 1]) * 256
         + cast(i64, p[off + 2]) * 65536 + cast(i64, p[off + 3]) * 16777216;
}
fn cse_wr_u32(p as *u8, off as i32, v as i64) as void {
    p[off]     = cast(u8, v & 255);
    p[off + 1] = cast(u8, (v >> 8) & 255);
    p[off + 2] = cast(u8, (v >> 16) & 255);
    p[off + 3] = cast(u8, (v >> 24) & 255);
}
fn cse_pad_spaces(out as *reader.ByteBuffer, target as i64) as void {
    while (out.len < target) { reader.buf_emit8(out, 32); }  // ' '
}

fn write_cse_combine_ape(pe_path as *u8, elf_path as *u8, cst_path as *u8,
                         output_path as *u8) as i32 {
    let is reader.ByteBuffer as pe = reader.buf_init(262144);
    let is i64 as pe_size = cse_read_file_into(&pe, pe_path);
    if (pe_size <= 0) {
        io._write_fd(io.STDERR, "caustic-ld: --cse-combine: cannot read PE\n", 42);
        return 1;
    }
    let is reader.ByteBuffer as elf = reader.buf_init(262144);
    let is i64 as elf_size = cse_read_file_into(&elf, elf_path);
    if (elf_size <= 0) {
        io._write_fd(io.STDERR, "caustic-ld: --cse-combine: cannot read ELF\n", 43);
        return 1;
    }
    let is reader.ByteBuffer as cst = reader.buf_init(131072);
    let is i64 as cst_size with mut = 0;
    if (cast(i64, cst_path) != 0) { cst_size = cse_read_file_into(&cst, cst_path); }

    let is *u8 as pd = pe.data;
    // Validate MZ + locate PE header.
    if (pd[0] != 77 || pd[1] != 90) {   // 'M','Z'
        io._write_fd(io.STDERR, "caustic-ld: --cse-combine: --pe is not a PE (no MZ)\n", 51);
        return 1;
    }
    let is i64 as orig_elfanew = cse_rd_u32(pd, 0x3C);
    let is i64 as H = orig_elfanew + CSE_APE_SHIFT;   // new e_lfanew = room for shell stub

    // Patch PE file offsets in-place (all shift by CSE_APE_SHIFT).
    let is i32 as eo = cast(i32, orig_elfanew);
    let is i64 as symptr = cse_rd_u32(pd, eo + 8);
    if (symptr != 0) { cse_wr_u32(pd, eo + 8, symptr + CSE_APE_SHIFT); }
    let is i32 as nsec = cse_rd_u16(pd, eo + 6);
    let is i32 as opt_sz = cse_rd_u16(pd, eo + 20);
    let is i32 as sect = eo + 24 + opt_sz;
    let is i32 as i with mut = 0;
    while (i < nsec) {
        let is i32 as so = sect + i * 40;
        let is i64 as rp = cse_rd_u32(pd, so + 20);   // PointerToRawData
        if (rp != 0) { cse_wr_u32(pd, so + 20, rp + CSE_APE_SHIFT); }
        i = i + 1;
    }

    // elf_off in the final file = (pe bytes after stub) end. pe_part is
    // pd[orig_elfanew:], placed at H, so it ends at H + (pe_size-orig_elfanew)
    // = pe_size + CSE_APE_SHIFT.
    let is i64 as elf_off = pe_size + CSE_APE_SHIFT;
    // CST body is 8-aligned after the ELF body. Known up front so the CST*
    // mini-header (@0x40) can record its offset.
    let is i64 as cst_off = (elf_off + elf_size + 7) & (0 - 8);

    // Assemble the polyglot.
    let is reader.ByteBuffer as out = reader.buf_init(524288);
    cse_emit_str(&out, "MZqFpD='\n");          // MZ (PE) + open quote + early newline
    cse_pad_spaces(&out, 0x3C);
    reader.buf_emit32_le(&out, H);             // e_lfanew @ 0x3C (NULs ok inside quote)
    // CST* mini-header @0x40 (32 bytes) — the CausticOS loader reads this to
    // locate the CST body without scanning for the CST_ magic. It lives inside
    // the single-quoted shell region (NULs fine; the offset/size bytes avoid
    // 0x27 in practice and are asserted clean by the hexdump check).
    cse_emit_str(&out, "CST*");                 // 0x40 magic
    reader.buf_emit16_le(&out, CSE_VERSION);    // 0x44 version
    reader.buf_emit16_le(&out, 0);              // 0x46 reserved
    reader.buf_emit64_le(&out, cst_off);        // 0x48 cst_body_offset
    let is i64 as cst_body_size = cast(i64, cst_size);
    reader.buf_emit64_le(&out, cst_body_size);  // 0x50 cst_body_size
    reader.buf_emit32_le(&out, 32);             // 0x58 mini_header_size
    reader.buf_emit32_le(&out, 0);              // 0x5C reserved  (ends at 0x60)
    cse_emit_str(&out, "'\n");                  // close quote @0x60
    // Extractor (pure ASCII, no NUL): dd the ELF out of $0 and exec it.
    cse_emit_str(&out, "__o=");
    cse_emit_decimal(&out, elf_off);
    cse_emit_str(&out, ";__s=");
    cse_emit_decimal(&out, elf_size);
    cse_emit_str(&out, ";__t=$(mktemp);tail -c +$((__o+1)) \"$0\"|head -c $__s>\"$__t\";chmod +x \"$__t\";exec \"$__t\" \"$@\"\n");
    cse_emit_str(&out, "exit 1\n");
    while (out.len < H) { reader.buf_emit8(&out, 35); }  // '#' pad to PE header

    // Shifted PE (header + sections), then ELF body, then CST body.
    reader.buf_append(&out, cast(*u8, cast(i64, pd) + orig_elfanew), pe_size - orig_elfanew);
    reader.buf_append(&out, elf.data, elf_size);
    if (cst_size > 0) {
        reader.buf_pad_to(&out, cst_off);   // == align8(elf_off+elf_size); recorded in mini-header
        reader.buf_append(&out, cst.data, cst_size);
    }
    return cse_write_buf_to_file(&out, output_path);
}

// === .csl — Caustic Standard Library (shared lib, CSE family) =========
// A CSL_ image: CST_ v2-style segment table + an EXPORT table (name->vaddr)
// so our loader can resolve a program's stdlib imports. No entry point.
// flags bit 0: 0 = pure (CausticOS only), 1 = compat (polyglot, our loader).
//   Header (32 bytes):
//     0x00 4 "CSL_"  0x04 2 version  0x06 1 arch  0x07 1 flags
//     0x08 8 base_addr   0x10 4 seg_count   0x14 4 export_count   0x18 8 export_off
//   Segment table: seg_count * 24 (vaddr, file_off, file_size, mem_size, perms)
//   Packed segment bytes.
//   Export table @export_off: export_count * 12 (name_off u32, vaddr u64),
//     then a packed NUL-terminated string blob (name_off is an abs file offset).
fn cse_emit_csl_image(out as *reader.ByteBuffer, ls as *linker.LinkerState, flags as i32) as void {
    let is *reader.ByteBuffer as text_buf = linker.get_text(ls);
    let is *reader.ByteBuffer as rodata_buf = linker.get_rodata(ls);
    let is *reader.ByteBuffer as data_buf = linker.get_data(ls);
    let is *linker.GlobalSymTab as gsyms = linker.get_gsyms(ls);

    let is [40]i64 as sv;
    let is [40]i64 as sptr;
    let is [40]i64 as sfsz;
    let is [40]i64 as smsz;
    let is [40]i32 as sperm;
    let is i32 as n with mut = 0;
    if (ls.text_size > 0) { sv[n] = ls.text_vaddr; sptr[n] = cast(i64, text_buf.data); sfsz[n] = ls.text_size; smsz[n] = ls.text_size; sperm[n] = 5; n = n + 1; }
    if (ls.rodata_size > 0) { sv[n] = ls.rodata_vaddr; sptr[n] = cast(i64, rodata_buf.data); sfsz[n] = ls.rodata_size; smsz[n] = ls.rodata_size; sperm[n] = 1; n = n + 1; }
    if (ls.data_size > 0) { sv[n] = ls.data_vaddr; sptr[n] = cast(i64, data_buf.data); sfsz[n] = ls.data_size; smsz[n] = ls.data_size; sperm[n] = 3; n = n + 1; }
    if (ls.bss_total > 0) { sv[n] = ls.bss_vaddr; sptr[n] = 0; sfsz[n] = 0; smsz[n] = ls.bss_total; sperm[n] = 3; n = n + 1; }

    let is i32 as ne with mut = 0;
    let is i32 as gi with mut = 0;
    while (gi < gsyms.count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, gi);
        if (g.defined == 1 && g.name_len > 0 && g.section != 0) { ne = ne + 1; }
        gi = gi + 1;
    }

    let is [40]i64 as sfoff;
    let is i64 as cursor with mut = 32 + cast(i64, n) * 24;
    let is i32 as i with mut = 0;
    while (i < n) {
        if (sfsz[i] > 0) { sfoff[i] = cursor; cursor = cursor + sfsz[i]; } else { sfoff[i] = 0; }
        i = i + 1;
    }
    let is i64 as export_off = cursor;
    let is i64 as estr_off = export_off + cast(i64, ne) * 12;

    reader.buf_emit8(out, 67); reader.buf_emit8(out, 83); reader.buf_emit8(out, 76); reader.buf_emit8(out, 95);  // "CSL_"
    reader.buf_emit16_le(out, 1);
    reader.buf_emit8(out, CSE_ARCH_X86_64);
    reader.buf_emit8(out, flags);
    reader.buf_emit64_le(out, ls.base_addr);
    reader.buf_emit32_le(out, cast(i64, n));
    reader.buf_emit32_le(out, cast(i64, ne));
    reader.buf_emit64_le(out, export_off);

    i = 0;
    while (i < n) {
        reader.buf_emit64_le(out, sv[i]);
        reader.buf_emit32_le(out, sfoff[i]);
        reader.buf_emit32_le(out, sfsz[i]);
        reader.buf_emit32_le(out, smsz[i]);
        reader.buf_emit32_le(out, cast(i64, sperm[i]));
        i = i + 1;
    }
    i = 0;
    while (i < n) { if (sfsz[i] > 0) { reader.buf_append(out, cast(*u8, sptr[i]), sfsz[i]); } i = i + 1; }

    // export entries
    let is i64 as cur_str with mut = 0;
    gi = 0;
    while (gi < gsyms.count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, gi);
        if (g.defined == 1 && g.name_len > 0 && g.section != 0) {
            reader.buf_emit32_le(out, estr_off + cur_str);
            reader.buf_emit64_le(out, g.vaddr);
            cur_str = cur_str + cast(i64, g.name_len) + 1;
        }
        gi = gi + 1;
    }
    // string blob
    gi = 0;
    while (gi < gsyms.count) {
        let is *linker.GlobalSym as g = linker.gsym_get(gsyms, gi);
        if (g.defined == 1 && g.name_len > 0 && g.section != 0) {
            reader.buf_append(out, g.name, cast(i64, g.name_len));
            reader.buf_emit8(out, 0);
        }
        gi = gi + 1;
    }
}

fn write_csl(ls as *linker.LinkerState, output_path as *u8, flags as i32) as i32 {
    linker.apply_relocations(ls);
    let is reader.ByteBuffer as out = reader.buf_init(65536);
    cse_emit_csl_image(&out, ls, flags);
    return cse_write_buf_to_file(&out, output_path);
}

// Mode dispatcher: relocation + per-mode emission (mirrors the PE writer,
// which also owns relocation internally).
fn write_cse(ls as *linker.LinkerState, output_path as *u8) as i32 {
    let is i32 as mode = tgt.cse_mode_get();
    if (ls.is_shared == 1) {
        // .csl shared library: pure (mode 0) or compat (mode 1/2) flag.
        let is i32 as flags with mut = 0;
        if (mode != 0) { flags = 1; }
        return write_csl(ls, output_path, flags);
    }
    if (mode == 0) { return write_cse_pure(ls, output_path); }
    if (mode == 1) { return write_cse_selfextract(ls, output_path); }  // compat
    if (mode == 2) { return write_cse_selfextract(ls, output_path); }  // bundle
    io._write_fd(io.STDERR, "caustic-ld: unknown CSE mode\n", 28);
    return 1;
}
